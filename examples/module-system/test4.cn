/**
 * CN语言模块系统完整功能展示
 * 
 * 功能演示:
 * 1. 多层路径导入
 * 2. 选择性导入
 * 3. 通配符导入
 * 4. 包导入(自动查找__包__.cn)
 * 5. 嵌套导入(包重新导出子模块)
 * 6. 命名空间导入
 * 7. 模块缓存(多次导入同一模块只编译一次)
 */

// 功能6: 命名空间导入
导入 module_using_simple;

函数 主程序() -> 整数 {
    打印("=== CN语言模块系统功能展示 ===\n\n");
        
    // 使用命名空间导入
    打印("4. 命名空间导入:\n");
    整数 使用值 = module_using_simple.使用测试();
    打印("  模块函数返回: ");
    打印(使用值);
    打印("\n\n");
    
    打印("=== 所有功能测试通过! ===\n");
    
    返回 0;
}
