/**
 * 测试模块/包双向回退查找功能
 * 
 * 场景1：导入 ./simple_module - 相对路径导入
 *   - 先查找 simple_module/__包__.cn（不存在）
 *   - 回退查找 simple_module.cn（存在）✓
 * 
 * 场景2：从 ./simple_module 导入 - 相对路径从导入
 *   - 先查找 simple_module/__包__.cn（不存在）
 *   - 回退查找 simple_module.cn（存在）✓
 */

// 场景1：纯导入相对路径（应该先查包，回退到模块）
导入 ./simple_module;

// 场景2：从相对路径导入成员（应该先查包，回退到模块）
从 ./module_using_simple 导入 { 使用测试 };

函数 主程序() -> 整数 {
    打印("测试双向回退查找功能\n");
    
    // 使用场景1的导入
    整数 值1 = simple_module.测试函数();
    打印("场景1结果: ");
    打印(值1);
    打印("\n");
    
    // 使用场景2的导入
    整数 值2 = 使用测试();
    打印("场景2结果: ");
    打印(值2);
    打印("\n");
    
    返回 0;
}
