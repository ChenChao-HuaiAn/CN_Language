/**
 * 测试基本的模块导入语法
 * 测试同文件内模块的路径导入
 */

// 定义工具模块
模块 工具 {
    公开:
    
    函数 打招呼() -> 整数 {
        打印("你好!\n");
        返回 0;
    }
    
    函数 计算(整数 a, 整数 b) -> 整数 {
        返回 a + b;
    }
}

// 定义数学模块
模块 数学 {
    公开:
    
    函数 加法(整数 a, 整数 b) -> 整数 {
        返回 a + b;
    }
    
    函数 减法(整数 a, 整数 b) -> 整数 {
        返回 a - b;
    }
}

// 测试1: 传统方式导入模块
导入 工具;

// 测试2: 使用路径语法导入(现在暂不支持跨文件,只测试解析)
// 导入 工具.子模块;  // 如果有子模块

// 主程序
函数 主程序() -> 整数 {
    // 使用导入的模块
    工具.打招呼();
    整数 结果 = 工具.计算(10, 20);
    
    // 直接使用另一个模块(不导入)
    整数 和 = 数学.加法(5, 3);
    整数 差 = 数学.减法(10, 4);
    
    返回 0;
}
