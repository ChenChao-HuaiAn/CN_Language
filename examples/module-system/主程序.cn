/**
 * 示例项目：CN语言 Python风格模块系统演示
 * 
 * 主程序文件：演示如何使用模块导入功能
 */

// 导入工具包中的数学模块
从 工具.数学.数学 导入 { 加法, 减法 };

// 导入整个工具模块
导入 工具;

// 主程序入口
函数 主程序() -> 整数 {
    // 使用导入的函数
    整数 结果1 = 加法(10, 20);
    整数 结果2 = 减法(30, 15);
    
    打印("加法结果: ");
    打印(结果1);
    打印("\n");
    
    打印("减法结果: ");
    打印(结果2);
    打印("\n");
    
    返回 0;
}
