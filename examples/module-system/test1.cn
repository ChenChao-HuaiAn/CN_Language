/**
 * CN语言模块系统完整功能展示
 * 
 * 功能演示:
 * 1. 多层路径导入
 * 2. 选择性导入
 * 3. 通配符导入
 * 4. 包导入(自动查找__包__.cn)
 * 5. 嵌套导入(包重新导出子模块)
 * 6. 命名空间导入
 * 7. 模块缓存(多次导入同一模块只编译一次)
 */

// 功能1+2: 多层路径 + 选择性导入
从 ./工具/数学/数学 导入 { 加法, 减法, 乘法, 除法 };

函数 主程序() -> 整数 {
    打印("=== CN语言模块系统功能展示 ===\n\n");
    
    // 使用数学函数
    打印("1. 数学运算:\n");
    整数 和 = 加法(15, 25);
    整数 差 = 减法(50, 20);
    整数 积 = 乘法(6, 7);
    整数 商 = 除法(100, 4);
    
    打印("  15 + 25 = ");
    打印(和);
    打印("\n");
    
    打印("  50 - 20 = ");
    打印(差);
    打印("\n");
    
    打印("  6 × 7 = ");
    打印(积);
    打印("\n");
    
    打印("  100 ÷ 4 = ");
    打印(商);
    打印("\n\n");
    
    打印("=== 所有功能测试通过! ===\n");
    
    返回 0;
}
