// 测试包导入与模块导入的区分
// 语法：
//   导入 ./包名;      导入包（查找目录中的 __包__.cn）
//   导入 模块名;      导入模块（查找 .cn 文件）

// 导入包：使用 ./ 前缀，表示从当前目录下的"工具"包导入
// 这会查找 ./工具/__包__.cn
导入 ./工具;

// 导入模块：不使用 ./ 前缀，表示导入模块文件
// 这会查找 simple_module.cn
导入 simple_module;

函数 主程序() -> 整数 {
    // 使用工具包中的函数
    变量 版本 = 工具.获取版本();
    打印整数(版本);
    
    // 使用模块中的函数
    变量 结果 = simple_module.测试函数();
    打印整数(结果);
    
    返回 0;
}
