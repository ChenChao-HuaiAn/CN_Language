// 模块别名与选择性导入组合测试
// 文件即模块：配置模块和工具模块合并

// 配置模块成员
公开: 整数 版本 = 1;
公开: 整数 端口 = 8080;
公开: 字符串 主机 = "localhost";

公开: 函数 获取配置() {
    返回 版本;
}

// 工具模块成员
公开: 整数 工具版本 = 2;

公开: 函数 帮助函数A() {
    返回 100;
}

公开: 函数 帮助函数B() {
    返回 200;
}

公开: 函数 帮助函数C() {
    返回 300;
}

函数 主程序() {
    // 直接访问成员（文件即模块设计）
    变量 v = 版本;
    打印整数(v);  // 输出: 1
    
    变量 p = 端口;
    打印整数(p);  // 输出: 8080
    
    变量 cfg = 获取配置();
    打印整数(cfg);  // 输出: 1
    
    // 直接调用函数
    变量 a = 帮助函数A();
    打印整数(a);  // 输出: 100
    
    变量 b = 帮助函数B();
    打印整数(b);  // 输出: 200
    
    // 直接调用函数
    变量 c = 帮助函数C();
    打印整数(c);  // 输出: 300
    
    // 直接访问变量
    变量 tv = 工具版本;
    打印整数(tv);  // 输出: 2
    
    返回 0;
}
