// 测试 Python 风格模块系统语法
// 本文件用于验证阶段B实现的语法解析功能

// 传统导入语法（已支持）
导入 数学;
导入 工具(我的工具);  // 模块别名

// 新语法：从...导入（阶段B实现）
从 数学 导入 { 平方根, 绝对值 };
从 工具.数学 导入 { 加法 };
从 工具 导入 *;
从 .本地模块 导入 { 函数A };
从 ..父模块 导入 成员A;

// 文件级公开/私有块（阶段B实现）
公开:
    整数 全局常量 = 42;
    
    函数 公开函数(整数 x) -> 整数 {
        返回 x * 2;
    }

私有:
    整数 私有变量 = 100;
    
    函数 内部辅助(整数 a, 整数 b) -> 整数 {
        返回 a + b;
    }

公开:
    函数 主程序() -> 整数 {
        整数 结果 = 公开函数(21);
        返回 0;
    }
