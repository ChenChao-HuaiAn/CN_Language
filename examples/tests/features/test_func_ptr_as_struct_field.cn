// 测试：函数指针基本功能
// 验证函数指针变量声明和调用

// 实现加法函数
函数 加法(整数 a, 整数 b) { 返回 a + b; }

// 实现乘法函数
函数 乘法(整数 a, 整数 b) { 返回 a * b; }

// 主函数测试
函数 主函数() {
    // 函数指针变量声明并初始化
    整数(*运算)(整数, 整数) = 加法;
    
    // 通过函数指针调用
    变量 结果1 = 运算(3, 4);
    
    // 重新赋值函数指针
    运算 = 乘法;
    变量 结果2 = 运算(3, 4);
    
    // 返回测试结果：期望 7 + 12 = 19
    返回 结果1 + 结果2;
}
