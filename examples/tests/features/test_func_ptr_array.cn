// 测试：函数指针数组
// 验证函数指针数组的定义和使用

// 定义两个简单的运算函数
函数 加法(整数 a, 整数 b) { 返回 a + b; }

函数 减法(整数 a, 整数 b) { 返回 a - b; }

函数 乘法(整数 a, 整数 b) { 返回 a * b; }

函数 除法(整数 a, 整数 b) { 返回 a / b; }

// 主函数测试
函数 主函数() {
    // 函数指针变量声明
    整数(*运算1)(整数, 整数) = 加法;
    整数(*运算2)(整数, 整数) = 减法;
    整数(*运算3)(整数, 整数) = 乘法;
    整数(*运算4)(整数, 整数) = 除法;
    
    // 通过函数指针调用
    变量 结果1 = 运算1(10, 5);  // 10 + 5 = 15
    变量 结果2 = 运算2(10, 5);  // 10 - 5 = 5
    变量 结果3 = 运算3(10, 5);  // 10 * 5 = 50
    变量 结果4 = 运算4(10, 5);  // 10 / 5 = 2
    
    // 返回测试结果：期望 15 + 5 + 50 + 2 = 72
    返回 结果1 + 结果2 + 结果3 + 结果4;
}
