// 测试用例：多个静态变量
// 目的：验证一个函数内可以有多个静态变量
// 期望：多个静态变量各自独立保持状态

函数 复杂计数() -> 整数 {
    静态 整数 调用次数 = 0;
    静态 小数 累计值 = 0.0;
    
    调用次数 = 调用次数 + 1;
    累计值 = 累计值 + 1.5;
    
    返回 调用次数;  // 返回调用次数用于验证
}

函数 主程序() -> 整数 {
    变量 r1 = 复杂计数();  // 期望：1
    变量 r2 = 复杂计数();  // 期望：2
    变量 r3 = 复杂计数();  // 期望：3
    
    返回 r1 + r2 + r3;  // 返回 6 表示测试通过
}
