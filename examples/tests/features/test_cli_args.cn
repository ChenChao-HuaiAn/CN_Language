// 命令行参数示例程序
// 演示如何使用CN语言的命令行参数标准库接口

// 引入标准库
引入 "标准库"

// 主函数
函数 主函数(): 整数 {
    // 获取参数个数
    整数 参数总数 = 获取参数个数()
    打印字符串("参数个数: ")
    打印整数(参数总数)
    打印换行()
    
    // 获取程序名称
    字符指针 程序名 = 获取程序名称()
    打印字符串("程序名称: ")
    打印字符串(程序名)
    打印换行()
    
    // 打印所有参数
    打印字符串("所有参数:")
    打印换行()
    整数 索引 = 0
    当 索引 < 参数总数 {
        打印字符串("  [")
        打印整数(索引)
        打印字符串("]: ")
        打印字符串(获取参数(索引))
        打印换行()
        索引 = 索引 + 1
    }
    
    // 检查选项是否存在
    打印换行()
    打印字符串("选项检查:")
    打印换行()
    
    如果 选项存在("v") {
        打印字符串("  -v 选项存在")
        打印换行()
    }
    
    如果 选项存在("verbose") {
        打印字符串("  --verbose 选项存在")
        打印换行()
    }
    
    如果 选项存在("h") {
        打印字符串("  -h 选项存在")
        打印换行()
    }
    
    如果 选项存在("help") {
        打印字符串("  --help 选项存在")
        打印换行()
    }
    
    // 获取选项值
    打印换行()
    打印字符串("选项值:")
    打印换行()
    
    字符指针 输出文件 = 查找选项("o")
    如果 输出文件 != 空指针 {
        打印字符串("  -o 值: ")
        打印字符串(输出文件)
        打印换行()
    }
    
    字符指针 输入文件 = 查找选项("input")
    如果 输入文件 != 空指针 {
        打印字符串("  --input 值: ")
        打印字符串(输入文件)
        打印换行()
    }
    
    // 获取位置参数
    打印换行()
    整数 位置参数个数 = 获取位置参数个数()
    打印字符串("位置参数个数: ")
    打印整数(位置参数个数)
    打印换行()
    
    打印字符串("位置参数:")
    打印换行()
    整数 位置索引 = 0
    当 位置索引 < 位置参数个数 {
        打印字符串("  [")
        打印整数(位置索引)
        打印字符串("]: ")
        打印字符串(获取位置参数(位置索引))
        打印换行()
        位置索引 = 位置索引 + 1
    }
    
    返回 0
}
