// 测试新函数语法
// 验证重写关键字位置和返回类型语法
// 根据语法规范文档，子类重写函数时只需要"重写"关键字，不需要"虚拟"关键字

// 基类：动物
类 动物 {
公开:
    // 虚函数
    虚拟 函数 说话() {
        打印("动物发声\n");
    }
    
    // 虚函数带返回类型
    虚拟 函数 获取名称() -> 字符串 {
        返回 "动物";
    }
};

// 派生类：狗
类 狗 : 动物 {
公开:
    // 重写函数（根据语法规范，不需要"虚拟"关键字）
    重写 函数 说话() {
        打印("汪汪汪！\n");
    }
    
    // 重写有返回值函数
    重写 函数 获取名称() -> 字符串 {
        返回 "狗";
    }
};

// 派生类：猫
类 猫 : 动物 {
公开:
    // 重写无返回值函数
    重写 函数 说话() {
        打印("喵喵喵！\n");
    }
    
    // 重写有返回值函数
    重写 函数 获取名称() -> 字符串 {
        返回 "猫";
    }
};

// 主函数
主函数() {
    狗 小狗;
    猫 小猫;
    
    小狗.说话();
    小猫.说话();
    
    返回 0;
}
