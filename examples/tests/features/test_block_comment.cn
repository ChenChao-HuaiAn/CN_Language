/* 这是一个简单的块注释 */
变量 x = 10;

/*
 * 这是一个多行块注释
 * 第二行
 * 第三行
 */
变量 y = 20;

/* 空注释 */变量 a = 1;

/* 包含中文的块注释：测试中文支持 */变量 b = 2;

/* 包含代码的注释：函数 测试() {} */变量 c = 3;

// 单行注释
变量 d = 4;

/* 块注释 */变量 e = 5;

// 另一个单行注释
/*
 * 块注释中的内容
 */变量 f = 6;

函数 主() {
    /* 函数内的块注释 */
    变量 g = 7;
    
    /*
     * 多行块注释
     * 在函数内部
     */
    变量 h = 8;
    
    返回 0;
}
