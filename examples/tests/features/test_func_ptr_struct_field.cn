// 测试：函数指针作为结构体字段
// 验证结构体可以包含函数指针类型的字段

// 实现加法函数
函数 加法(整数 a, 整数 b) { 返回 a + b; }

// 实现乘法函数
函数 乘法(整数 a, 整数 b) { 返回 a * b; }

// 定义包含函数指针字段的结构体
结构体 事件处理器 {
    整数(*点击)(整数, 整数);    // 函数指针字段：接受两个整数参数，返回整数
    整数(*按键)(整数);          // 函数指针字段：接受一个整数参数，返回整数
};

// 主函数测试
函数 主函数() {
    // 声明结构体变量
    变量 处理器: 事件处理器;
    
    // 设置函数指针字段
    处理器.点击 = 加法;
    处理器.按键 = 乘法;
    
    // 通过结构体字段调用函数指针
    变量 结果1 = 处理器.点击(3, 4);      // 期望 7
    变量 结果2 = 处理器.按键(5);          // 期望 25
    
    // 返回测试结果：期望 7 + 25 = 32
    返回 结果1 + 结果2;
}
