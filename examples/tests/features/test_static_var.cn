// 测试静态局部变量声明
// 作者：CN Language 编译器团队
// 日期：2026-03-27

// 测试1：基本静态变量声明
函数 计数器() -> 整数 {
    静态 整数 计数 = 0;
    计数 = 计数 + 1;
    返回 计数;
}

// 测试2：静态变量使用变量关键字
函数 累加器() -> 整数 {
    静态 变量 总和 = 0;
    总和 = 总和 + 10;
    返回 总和;
}

// 测试3：静态小数变量
函数 小数计数() -> 小数 {
    静态 小数 值 = 0.0;
    值 = 值 + 1.5;
    返回 值;
}

// 主函数
函数 主程序() -> 整数 {
    整数 结果1 = 计数器();
    整数 结果2 = 计数器();
    整数 结果3 = 计数器();
    
    返回 0;
}
