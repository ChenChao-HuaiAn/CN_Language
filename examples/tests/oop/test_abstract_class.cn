// 测试抽象类代码生成
// 验证点：
// 1. 抽象类正确生成vtable
// 2. 纯虚函数占位符正确生成
// 3. 派生类正确实现纯虚函数

// 抽象类：动物
抽象 类 动物 {
公开:
    // 纯虚函数
    虚拟 函数 说话() -> 无 抽象;
    
    // 普通虚函数
    虚拟 函数 移动() -> 无 {
        打印("动物在移动\n");
    }
    
    // 普通成员函数
    函数 获取名称() -> 整数 {
        返回 0;
    }
};

// 派生类：狗
类 狗 继承 动物 {
公开:
    // 实现纯虚函数
    虚拟 函数 说话() -> 无 覆盖 {
        打印("汪汪汪！\n");
    }
    
    // 重写虚函数
    虚拟 函数 移动() -> 无 覆盖 {
        打印("狗在奔跑\n");
    }
};

// 派生类：猫
类 猫 继承 动物 {
公开:
    // 实现纯虚函数
    虚拟 函数 说话() -> 无 覆盖 {
        打印("喵喵喵！\n");
    }
};

// 主函数
主函数() {
    // 创建派生类实例
    狗 小狗;
    猫 小猫;
    
    // 调用虚函数
    小狗.说话();
    小狗.移动();
    
    小猫.说话();
    小猫.移动();
    
    返回 0;
}
