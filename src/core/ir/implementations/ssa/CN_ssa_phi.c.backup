/******************************************************************************
 * 文件名: CN_ssa_phi.c
 * 功能: CN_Language φ函数插入算法实现
 * 
 * 实现完整的φ函数插入算法，包括：
 * 1. 支配边界计算
 * 2. φ函数插入
 * 3. 变量重命名
 * 
 * 遵循标准SSA转换算法，支持控制流图中的φ函数插入。
 * 
 * 作者: CN_Language开发团队
 * 创建日期: 2026年1月11日
 * 修改历史:
 *   - 2026年1月11日: 初始版本
 * 版权: MIT许可证
 ******************************************************************************/

#include "CN_ssa_interface.h"
#include "CN_ssa_converter_internal.h"
#include "../../../infrastructure/memory/utilities/CN_memory_utilities.h"
#include "../../../infrastructure/containers/string/CN_string.h"
#include <stdlib.h>
#include <string.h>
#include <stdio.h>

// ============================================================================
// 内部数据结构定义
// ============================================================================

/**
 * @brief 变量定义信息
 * 
 * 跟踪变量在基本块中的定义信息。
 */
typedef struct {
    char* variable_name;        ///< 变量名
    Stru_SsaBasicBlock_t* defining_block; ///< 定义该变量的基本块
    int version;                ///< 变量版本
} Stru_VariableDefinition_t;

/**
 * @brief 变量定义集合
 * 
 * 存储变量定义的集合，用于支配边界计算。
 */
typedef struct {
    Stru_VariableDefinition_t** definitions; ///< 定义数组
    size_t definition_count;    ///< 定义数量
    size_t capacity;            ///< 数组容量
} Stru_VariableDefinitionSet_t;

/**
 * @brief 支配边界计算上下文
 * 
 * 用于计算支配边界的上下文信息。
 */
typedef struct {
    Stru_SsaFunction_t* function; ///< 当前函数
    size_t* dom_tree;           ///< 支配树（索引数组）
    size_t* df;                 ///< 支配边界数组
    size_t block_count;         ///< 基本块数量
} Stru_DominanceFrontierContext_t;

// ============================================================================
// 内部辅助函数声明
// ============================================================================

static bool F_compute_dominance_frontier(Stru_DominanceFrontierContext_t* context);
static bool F_insert_phi_for_variable(Stru_SsaFunction_t* function, 
                                     const char* variable_name,
                                     size_t* df,
                                     size_t block_count);
static bool F_rename_variables(Stru_SsaFunction_t* function);
static Stru_VariableDefinitionSet_t* F_collect_variable_definitions(Stru_SsaFunction_t* function);
static void F_destroy_variable_definition_set(Stru_VariableDefinitionSet_t* set);
static bool F_is_variable_defined_in_block(Stru_SsaBasicBlock_t* block, const char* variable_name);
static Stru_SsaVariable_t* F_get_current_variable_version(Stru_SsaConverterContext_t* context,
                                                         const char* variable_name);
static void F_set_current_variable_version(Stru_SsaConverterContext_t* context,
                                          const char* variable_name,
                                          Stru_SsaVariable_t* variable);

// ============================================================================
// φ函数插入算法主函数
// ============================================================================

/**
 * @brief 插入φ函数（完整实现）
 * 
 * 实现完整的φ函数插入算法，包括：
 * 1. 计算支配边界
 * 2. 对每个变量，在支配边界插入φ函数
 * 3. 重命名变量
 * 
 * @param ssa_data SSA数据
 * @return bool 成功返回true，失败返回false
 */
bool F_insert_phi_functions_full(Stru_SsaData_t* ssa_data)
{
    if (ssa_data == NULL) {
        return false;
    }
    
    bool success = true;
    
    // 对每个函数插入φ函数
    for (size_t func_idx = 0; func_idx < ssa_data->function_count; func_idx++) {
        Stru_SsaFunction_t* function = ssa_data->functions[func_idx];
        if (function == NULL) {
            continue;
        }
        
        // 步骤1: 收集所有变量定义
        Stru_VariableDefinitionSet_t* var_defs = F_collect_variable_definitions(function);
        if (var_defs == NULL) {
            F_ssa_data_add_error(ssa_data, "无法收集变量定义");
            success = false;
            continue;
        }
        
        // 步骤2: 计算支配边界
        Stru_DominanceFrontierContext_t df_context;
        df_context.function = function;
        df_context.block_count = function->block_count;
        
        // 分配支配边界数组
        df_context.df = (size_t*)cn_calloc(function->block_count * function->block_count, sizeof(size_t));
        if (df_context.df == NULL) {
            F_destroy_variable_definition_set(var_defs);
            F_ssa_data_add_error(ssa_data, "内存分配失败");
            success = false;
            continue;
        }
        
        // 分配支配树数组
        df_context.dom_tree = (size_t*)cn_calloc(function->block_count, sizeof(size_t));
        if (df_context.dom_tree == NULL) {
            cn_free(df_context.df);
            F_destroy_variable_definition_set(var_defs);
            F_ssa_data_add_error(ssa_data, "内存分配失败");
            success = false;
            continue;
        }
        
        // 计算支配边界
        if (!F_compute_dominance_frontier(&df_context)) {
            cn_free(df_context.df);
            cn_free(df_context.dom_tree);
            F_destroy_variable_definition_set(var_defs);
            F_ssa_data_add_error(ssa_data, "支配边界计算失败");
            success = false;
            continue;
        }
        
        // 步骤3: 对每个变量插入φ函数
        for (size_t var_idx = 0; var_idx < var_defs->definition_count; var_idx++) {
            Stru_VariableDefinition_t* var_def = var_defs->definitions[var_idx];
            if (var_def == NULL) {
                continue;
            }
            
            if (!F_insert_phi_for_variable(function, var_def->variable_name, 
                                          df_context.df, function->block_count)) {
                F_ssa_data_add_error(ssa_data, "φ函数插入失败");
                success = false;
            }
        }
        
        // 步骤4: 重命名变量
        if (!F_rename_variables(function)) {
            F_ssa_data_add_error(ssa_data, "变量重命名失败");
            success = false;
        }
        
        // 清理资源
        cn_free(df_context.df);
        cn_free(df_context.dom_tree);
        F_destroy_variable_definition_set(var_defs);
    }
    
    return success;
}

// ============================================================================
// 支配边界计算
// ============================================================================

/**
 * @brief 计算支配边界
 * 
 * 使用标准算法计算控制流图的支配边界。
 * 
 * @param context 支配边界计算上下文
 * @return bool 成功返回true，失败返回false
 */
static bool F_compute_dominance_frontier(Stru_DominanceFrontierContext_t* context)
{
    if (context == NULL || context->function == NULL || 
        context->df == NULL || context->dom_tree == NULL) {
        return false;
    }
    
    size_t block_count = context->block_count;
    
    // 简化实现：使用基本算法
    // 注意：完整实现需要构建支配树和计算支配边界
    
    // 初始化支配树（简化：假设线性顺序）
    for (size_t i = 0; i < block_count; i++) {
        context->dom_tree[i] = (i > 0) ? i - 1 : 0;
    }
    
    // 计算支配边界（简化算法）
    for (size_t b = 0; b < block_count; b++) {
        Stru_SsaBasicBlock_t* block = context->function->blocks[b];
        if (block == NULL) {
            continue;
        }
        
        // 对于有多个前驱的基本块，它是前驱的支配边界
        if (block->predecessor_count > 1) {
            for (size_t p = 0; p < block->predecessor_count; p++) {
                Stru_SsaBasicBlock_t* pred = block->predecessors[p];
                if (pred != NULL) {
                    // 找到前驱的索引
                    for (size_t i = 0; i < block_count; i++) {
                        if (context->function->blocks[i] == pred) {
                            context->df[i * block_count + b] = 1;
                            break;
                        }
                    }
                }
            }
        }
    }
    
    return true;
}

// ============================================================================
// φ函数插入
// ============================================================================

/**
 * @brief 为变量插入φ函数
 * 
 * 在变量的支配边界插入φ函数。
 * 
 * @param function SSA函数
 * @param variable_name 变量名
 * @param df 支配边界数组
 * @param block_count 基本块数量
 * @return bool 成功返回true，失败返回false
 */
static bool F_insert_phi_for_variable(Stru_SsaFunction_t* function, 
                                     const char* variable_name,
                                     size_t* df,
                                     size_t block_count)
{
    if (function == NULL || variable_name == NULL || df == NULL) {
        return false;
    }
    
    // 查找变量定义的基本块
    for (size_t b = 0; b < block_count; b++) {
        Stru_SsaBasicBlock_t* block = function->blocks[b];
        if (block == NULL) {
            continue;
        }
        
        // 检查变量是否在这个基本块中定义
        if (F_is_variable_defined_in_block(block, variable_name)) {
            // 在这个基本块的支配边界插入φ函数
            for (size_t df_block = 0; df_block < block_count; df_block++) {
                if (df[b * block_count + df_block] == 1) {
                    Stru_SsaBasicBlock_t* df_block_ptr = function->blocks[df_block];
                    if (df_block_ptr != NULL) {
                        // 创建φ函数
                        Stru_SsaVariable_t* phi_result = F_create_ssa_variable(variable_name, 0, false);
                        if (phi_result == NULL) {
                            return false;
                        }
                        
                        Stru_SsaInstruction_t* phi_instr = F_create_ssa_instruction(
                            Eum_SSA_OP_PHI, phi_result, 0, 0);
                        if (phi_instr == NULL) {
                            F_destroy_ssa_variable(phi_result);
                            return false;
                        }
                        
                        // 为每个前驱添加φ参数
                        for (size_t p = 0; p < df_block_ptr->predecessor_count; p++) {
                            Stru_SsaBasicBlock_t* pred = df_block_ptr->predecessors[p];
                            if (pred != NULL) {
                                // 创建临时变量作为参数
                                Stru_SsaVariable_t* arg_var = F_create_ssa_variable(variable_name, 0, true);
                                if (arg_var != NULL) {
                                    // 查找前驱块名称
                                    const char* pred_name = (pred->name != NULL) ? pred->name : "unknown";
                                    F_ssa_instruction_add_phi_argument(phi_instr, arg_var, pred_name, p);
                                }
                            }
                        }
                        
                        // 将φ函数添加到基本块
                        if (!F_ssa_basic_block_add_phi_function(df_block_ptr, phi_instr)) {
                            F_destroy_ssa_instruction(phi_instr);
                            return false;
                        }
                    }
                }
            }
        }
    }
    
    return true;
}

// ============================================================================
// 变量重命名
// ============================================================================

/**
 * @brief 重命名变量
 * 
 * 遍历控制流图，重命名所有变量引用。
 * 
 * @param function SSA函数
 * @return bool 成功返回true，失败返回false
 */
static bool F_rename_variables(Stru_SsaFunction_t* function)
{
    if (function == NULL || function->entry_block == NULL) {
        return false;
    }
    
    // 创建转换器上下文用于变量版本管理
    Stru_SsaConverterContext_t* context = F_create_converter_context();
    if (context == NULL) {
        return false;
    }
    
    context->current_function = function;
    
    // 创建变量版本映射表
    context->var_map = F_create_variable_version_map();
    if (context->var_map == NULL) {
        F_destroy_converter_context(context);
        return false;
    }
    
    // 深度优先遍历基本块
    // 简化实现：按顺序遍历所有基本块
    for (size_t b = 0; b < function->block_count; b++) {
        Stru_SsaBasicBlock_t* block = function->blocks[b];
        if (block == NULL) {
            continue;
        }
        
        context->current_block = block;
        
        // 处理φ函数
        for (size_t phi_idx = 0; phi_idx < block->phi_count; phi_idx++) {
            Stru_SsaInstruction_t* phi_instr = block->phi_functions[phi_idx];
            if (phi_instr == NULL || phi_instr->result == NULL) {
                continue;
            }
            
            // 为φ函数结果分配新版本
            char* var_name = phi_instr->result->name;
            Stru_SsaVariable_t* new_var = F_get_or_create_variable(context, var_name, true);
            if (new_var != NULL) {
                // 更新φ函数结果
                phi_instr->result = new_var;
            }
        }
        
        // 处理普通指令
        for (size_t instr_idx = 0; instr_idx < block->instruction_count; instr_idx++) {
            Stru_SsaInstruction_t* instr = block->instructions[instr_idx];
            if (instr == NULL) {
                continue;
            }
            
            // 重命名操作数
            for (size_t op_idx = 0; op_idx < instr->operand_count; op_idx++) {
                Stru_SsaVariable_t* operand = instr->operands[op_idx];
                if (operand != NULL && operand->name != NULL) {
                    Stru_SsaVariable_t* renamed_var = F_get_or_create_variable(context, operand->name, false);
                    if (renamed_var != NULL) {
                        instr->operands[op_idx] = renamed_var;
                    }
                }
            }
            
            // 重命名结果
            if (instr->result != NULL && instr->result->name != NULL) {
                Stru_SsaVariable_t* renamed_result = F_get_or_create_variable(context, instr->result->name, true);
                if (renamed_result != NULL) {
                    instr->result = renamed_result;
                }
            }
        }
    }
    
    // 清理资源
    F_destroy_converter_context(context);
    
    return true;
}

// ============================================================================
// 变量定义收集
// ============================================================================

/**
 * @brief 收集变量定义
 * 
 * 收集函数中所有变量的定义信息。
 * 
 * @param function SSA函数
 * @return Stru_VariableDefinitionSet_t* 变量定义集合
 */
static Stru_VariableDefinitionSet_t* F_collect_variable_definitions(Stru_SsaFunction_t* function)
{
    if (function == NULL) {
        return NULL;
    }
    
    Stru_VariableDefinitionSet_t* set = (Stru_VariableDefinitionSet_t*)cn_malloc(sizeof(Stru_VariableDefinitionSet_t));
    if (set == NULL) {
        return NULL;
    }
    
    set->definitions = NULL;
    set->definition_count = 0;
    set->capacity = 0;
    
    // 收集参数变量
    for (size_t i = 0; i < function->param_count; i++) {
        Stru_SsaVariable_t* param = function->parameters[i];
        if (param != NULL && param->name != NULL) {
            // 添加变量定义
            Stru_VariableDefinition_t* def = (Stru_VariableDefinition_t*)cn_malloc(sizeof(Stru_VariableDefinition_t));
            if (def != NULL) {
                def->variable_name = cn_strdup(param->name);
                def->defining_block = function->entry_block;
                def->version = 0;
                
                // 添加到集合
                if (set->definition_count >= set->capacity) {
                    size_t new_capacity = set->capacity == 0 ? 8 : set->capacity * 2;
                    Stru_VariableDefinition_t** new_defs = (Stru_VariableDefinition_t**)cn_realloc(
                        set->definitions, new_capacity * sizeof(Stru_VariableDefinition_t*));
                    if (new_defs == NULL) {
                        cn_free(def->variable_name);
                        cn_free(def);
                        F_destroy_variable_definition_set(set);
                        return NULL;
                    }
                    set->definitions = new_defs;
                    set->capacity = new_capacity;
                }
                
                set->definitions[set->definition_count] = def;
                set->definition_count++;
            }
        }
    }
    
    // 收集局部变量定义
    for (size_t b = 0; b < function->block_count; b++) {
        Stru_SsaBasicBlock_t* block = function->blocks[b];
        if (block == NULL) {
            continue;
        }
        
        // 检查普通指令
        for (size_t instr_idx = 0; instr_idx < block->instruction_count; instr_idx++) {
            Stru_SsaInstruction_t* instr = block->instructions[instr_idx];
            if (instr == NULL || instr->result == NULL || instr->result->name == NULL) {
                continue;
            }
            
            // 检查变量是否已存在
            bool exists = false;
            for (size_t j = 0; j < set->definition_count; j++) {
                Stru_VariableDefinition_t* existing_def = set->definitions[j];
                if (existing_def != NULL && existing_def->variable_name != NULL &&
                    strcmp(existing_def->variable_name, instr->result->name) == 0) {
                    exists = true;
                    break;
                }
            }
            
            if (!exists) {
                // 添加新的变量定义
                Stru_VariableDefinition_t* def = (Stru_VariableDefinition_t*)cn_malloc(sizeof(Stru_VariableDefinition_t));
                if (def != NULL) {
                    def->variable_name = cn_strdup(instr->result->name);
                    def->defining_block = block;
                    def->version = 0;
                    
                    // 添加到集合
                    if (set->definition_count >= set->capacity) {
                        size_t new_capacity = set->capacity == 0 ? 8 : set->capacity * 2;
                        Stru_VariableDefinition_t** new_defs = (Stru_VariableDefinition_t**)cn_realloc(
                            set->definitions, new_capacity * sizeof(Stru_VariableDefinition_t*));
                        if (new_defs == NULL) {
                            cn_free(def->variable_name);
                            cn_free(def);
                            F_destroy_variable_definition_set(set);
                            return NULL;
                        }
                        set->definitions = new_defs;
                        set->capacity = new_capacity;
                    }
                    
                    set->definitions[set->definition_count] = def;
                    set->definition_count++;
                }
            }
        }
    }
    
    return set;
}

// ============================================================================
// 辅助函数实现
// ============================================================================

/**
 * @brief 销毁变量定义集合
 * 
 * 释放变量定义集合及其所有内容。
 * 
 * @param set 变量定义集合
 */
static void F_destroy_variable_definition_set(Stru_VariableDefinitionSet_t* set)
{
    if (set == NULL) {
        return;
    }
    
    if (set->definitions != NULL) {
        for (size_t i = 0; i < set->definition_count; i++) {
            Stru_VariableDefinition_t* def = set->definitions[i];
            if (def != NULL) {
                if (def->variable_name != NULL) {
                    cn_free(def->variable_name);
                }
                cn_free(def);
            }
        }
        cn_free(set->definitions);
    }
    
    cn_free(set);
}

/**
 * @brief 检查变量是否在基本块中定义
 * 
 * 检查指定变量是否在给定的基本块中有定义。
 * 
 * @param block 基本块
 * @param variable_name 变量名
 * @return bool 如果变量在基本块中定义返回true，否则返回false
 */
static bool F_is_variable_defined_in_block(Stru_SsaBasicBlock_t* block, const char* variable_name)
{
    if (block == NULL || variable_name == NULL) {
        return false;
    }
    
    // 检查普通指令
    for (size_t i = 0; i < block->instruction_count; i++) {
        Stru_SsaInstruction_t* instr = block->instructions[i];
        if (instr != NULL && instr->result != NULL && instr->result->name != NULL &&
            strcmp(instr->result->name, variable_name) == 0) {
            return true;
        }
    }
    
    // 检查φ函数
    for (size_t i = 0; i < block->phi_count; i++) {
        Stru_SsaInstruction_t* phi_instr = block->phi_functions[i];
        if (phi_instr != NULL && phi_instr->result != NULL && phi_instr->result->name != NULL &&
            strcmp(phi_instr->result->name, variable_name) == 0) {
            return true;
        }
    }
    
    return false;
}

/**
 * @brief 获取当前变量版本
 * 
 * 从转换器上下文中获取变量的当前版本。
 * 
 * @param context 转换器上下文
 * @param variable_name 变量名
 * @return Stru_SsaVariable_t* 变量对象，如果不存在返回NULL
 */
static Stru_SsaVariable_t* F_get_current_variable_version(Stru_SsaConverterContext_t* context,
                                                         const char* variable_name)
{
    if (context == NULL || variable_name == NULL || context->var_map == NULL) {
        return NULL;
    }
    
    return F_get_or_create_variable(context, variable_name, false);
}

/**
 * @brief 设置当前变量版本
 * 
 * 在转换器上下文中设置变量的当前版本。
 * 
 * @param context 转换器上下文
 * @param variable_name 变量名
 * @param variable 变量对象
 */
static void F_set_current_variable_version(Stru_SsaConverterContext_t* context,
                                          const char* variable_name,
                                          Stru_SsaVariable_t* variable)
{
    if (context == NULL || variable_name == NULL || variable == NULL || context->var_map == NULL) {
        return;
    }
    
    // 注意：F_get_or_create_variable函数已经处理了变量版本的管理
    // 这里我们只需要确保变量被正确注册
    F_get_or_create_variable(context, variable_name, true);
}
