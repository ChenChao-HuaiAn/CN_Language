// =============================================================================
// CN语言类型传播测试
// 测试指针类型的成员访问是否正确生成C代码
// =============================================================================

结构体 符号 {
    整数 种类;
    整数 标志;
};

// 测试指针参数的成员访问
函数 测试指针成员访问(符号* 指针) -> 整数 {
    返回 指针.种类;
}

// 测试结构体值的成员访问
函数 测试值成员访问(符号 值) -> 整数 {
    返回 值.标志;
}

// 主函数
函数 主程序() -> 整数 {
    变量 符号实例 = 符号{};
    符号实例.种类 = 1;
    符号实例.标志 = 2;
    
    变量 结果1 = 测试指针成员访问(&符号实例);
    变量 结果2 = 测试值成员访问(符号实例);
    
    返回 结果1 + 结果2;
}
