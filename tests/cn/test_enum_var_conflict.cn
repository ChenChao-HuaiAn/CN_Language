// 测试枚举成员与局部变量/参数同名冲突
// 问题：当枚举成员与函数参数同名时，IR生成器错误地将参数识别为枚举成员

// 定义一个枚举，其中有一个成员叫 "值"
枚举 状态 {
    值 = 40,  // 枚举成员 "值" = 40
    其他 = 100
};

// 定义一个结构体
结构体 数据 {
    整数 值;      // 结构体字段 "值"
    整数 数量;
};

// 测试函数：参数名与枚举成员同名
函数 测试参数冲突(数据* 值) -> 整数 {
    // 这里 "值" 应该是参数（数据指针），而不是枚举成员（40）
    // 如果错误地识别为枚举成员，会生成 "40.数量" 而不是 "值->数量"
    返回 值.数量;
}

// 主函数
函数 主程序() -> 整数 {
    数据 d;
    d.值 = 10;
    d.数量 = 20;
    
    整数 结果 = 测试参数冲突(&d);
    
    // 测试直接使用枚举成员
    整数 枚举值 = 值;  // 这里 "值" 应该是枚举成员 40
    
    返回 结果;
}
