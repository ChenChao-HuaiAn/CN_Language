// =============================================================================
// CN语言简单测试
// =============================================================================
// 
// 本文件测试CN语言编译器的基本功能：
// - 函数声明和调用
// - 变量声明
// - 基本表达式
// - 控制流语句
//
// =============================================================================

// =============================================================================
// 全局变量测试
// =============================================================================

变量 全局计数 = 0;

// =============================================================================
// 函数定义
// =============================================================================

/// 测试函数声明
函数 测试函数声明() -> 整数 {
    打印行("[测试] 函数声明测试");
    返回 0;
}

/// 测试变量声明
函数 测试变量声明() -> 整数 {
    打印行("[测试] 变量声明测试");
    
    变量 整数值 = 42;
    变量 小数值 = 3.14;
    变量 字符串值 = "你好，CN语言";
    变量 布尔值 = 真;
    
    如果 (整数值 == 42) {
        打印行("  ✓ 整数变量声明正确");
    } 否则 {
        打印行("  ✗ 整数变量声明错误");
        返回 1;
    }
    
    返回 0;
}

/// 测试静态局部变量
函数 测试静态变量() -> 整数 {
    打印行("[测试] 静态局部变量测试");
    
    静态 整数 调用次数 = 0;
    调用次数 = 调用次数 + 1;
    
    打印行("  调用次数: " + 整数转字符串(调用次数));
    
    返回 调用次数;
}

/// 测试控制流
函数 测试控制流() -> 整数 {
    打印行("[测试] 控制流测试");
    
    变量 计数 = 0;
    
    // 如果语句
    如果 (真) {
        计数 = 计数 + 1;
    }
    
    // 循环语句
    变量 循环变量 = 0;
    当 (循环变量 < 5) {
        计数 = 计数 + 1;
        循环变量 = 循环变量 + 1;
    }
    
    如果 (计数 == 6) {
        打印行("  ✓ 控制流测试通过");
        返回 0;
    } 否则 {
        打印行("  ✗ 控制流测试失败");
        返回 1;
    }
}

/// 主函数
函数 主程序() -> 整数 {
    打印行("========================================");
    打印行("CN语言编译器简单测试");
    打印行("========================================");
    打印行("");
    
    变量 错误计数 = 0;
    
    // 运行测试
    错误计数 = 错误计数 + 测试函数声明();
    错误计数 = 错误计数 + 测试变量声明();
    错误计数 = 错误计数 + 测试控制流();
    
    // 测试静态变量（调用两次验证状态保持）
    测试静态变量();
    变量 结果 = 测试静态变量();
    如果 (结果 != 2) {
        打印行("  ✗ 静态变量状态保持失败");
        错误计数 = 错误计数 + 1;
    }
    
    打印行("");
    打印行("========================================");
    打印行("测试完成，错误数: " + 整数转字符串(错误计数));
    打印行("========================================");
    
    返回 错误计数;
}
