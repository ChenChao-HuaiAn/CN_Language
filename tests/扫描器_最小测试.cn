// =============================================================================
// CN语言词法分析器 - 最小测试版本
// =============================================================================

公开:

// 词元类型枚举（简化版）
枚举 词元类型 {
    标识符,
    整数字面量,
    加号,
    减号,
    分号,
    结束,
    错误
};

// 词元结构体
结构体 词元 {
    词元类型 类型;
    字符串 值;
    整数 行号;
    整数 列号;
};

// 扫描器结构体
结构体 扫描器 {
    字符串 源码;
    整数 位置;
    整数 行号;
    整数 列号;
    整数 长度;
};

// 创建扫描器
函数 创建扫描器(字符串 源码内容, 整数 源码长度) -> 扫描器* {
    扫描器* 实例 = 分配内存(24);
    如果 (实例 == 无) {
        返回 无;
    }
    实例->源码 = 源码内容;
    实例->位置 = 0;
    实例->行号 = 1;
    实例->列号 = 1;
    实例->长度 = 源码长度;
    返回 实例;
}

// 销毁扫描器
函数 销毁扫描器(扫描器* 实例) -> 空类型 {
    如果 (实例 != 无) {
        释放内存(实例);
    }
}

// 当前字符
函数 当前字符(扫描器* 实例) -> 整数 {
    如果 (实例 == 无 || 实例->位置 >= 实例->长度) {
        返回 '\0';
    }
    返回 实例->源码[实例->位置];
}

// 前进
函数 前进(扫描器* 实例) -> 整数 {
    整数 c = 当前字符(实例);
    如果 (c != '\0') {
        实例->位置 = 实例->位置 + 1;
        如果 (c == '\n') {
            实例->行号 = 实例->行号 + 1;
            实例->列号 = 1;
        } 否则 {
            实例->列号 = 实例->列号 + 1;
        }
    }
    返回 c;
}

// 是否数字
函数 是数字(整数 c) -> 布尔 {
    返回 c >= '0' && c <= '9';
}

// 是否字母
函数 是字母(整数 c) -> 布尔 {
    返回 (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z');
}

// 是否标识符开头
函数 是标识符开头(整数 c) -> 布尔 {
    返回 c == '_' || 是字母(c) || c >= 0x80;
}

// 是否空白字符
函数 是空白字符(整数 c) -> 布尔 {
    返回 c == ' ' || c == '\t' || c == '\n' || c == '\r';
}

// 跳过空白字符
函数 跳过空白字符(扫描器* 实例) -> 空类型 {
    当 (是空白字符(当前字符(实例))) {
        前进(实例);
    }
}

// 下一个词元
函数 下一个词元(扫描器* 实例) -> 词元 {
    词元 结果;
    
    如果 (实例 == 无) {
        结果.类型 = 错误;
        结果.值 = "";
        结果.行号 = 0;
        结果.列号 = 0;
        返回 结果;
    }
    
    跳过空白字符(实例);
    
    整数 起始行号 = 实例->行号;
    整数 起始列号 = 实例->列号;
    
    整数 c = 当前字符(实例);
    
    如果 (c == '\0') {
        结果.类型 = 结束;
        结果.值 = "";
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    // 数字
    如果 (是数字(c)) {
        当 (是数字(当前字符(实例))) {
            前进(实例);
        }
        结果.类型 = 整数字面量;
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    // 标识符
    如果 (是标识符开头(c)) {
        当 (是标识符开头(当前字符(实例)) || 是数字(当前字符(实例))) {
            前进(实例);
        }
        结果.类型 = 标识符;
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    // 运算符
    如果 (c == '+') {
        前进(实例);
        结果.类型 = 加号;
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    如果 (c == '-') {
        前进(实例);
        结果.类型 = 减号;
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    如果 (c == ';') {
        前进(实例);
        结果.类型 = 分号;
        结果.行号 = 起始行号;
        结果.列号 = 起始列号;
        返回 结果;
    }
    
    // 未知字符
    前进(实例);
    结果.类型 = 错误;
    结果.行号 = 起始行号;
    结果.列号 = 起始列号;
    返回 结果;
}
