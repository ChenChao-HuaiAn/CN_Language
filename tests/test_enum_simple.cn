// 简化测试：枚举成员访问验证
// 测试目标：验证枚举类型和成员访问正常工作

// 定义枚举类型
枚举 词元类型枚举 {
    标识符,     // 0
    整数字面量, // 1
    字符串字面量, // 2
    运算符,     // 3
    分隔符,     // 4
    关键字,     // 5
    错误        // 6
}

// 定义二元运算符枚举
枚举 二元运算符 {
    加法,   // 0
    减法,   // 1
    乘法,   // 2
    除法,   // 3
    取模    // 4
}

函数 主程序() -> 整数 {
    // 测试1：枚举类型变量声明和赋值
    词元类型枚举 类型 = 词元类型枚举.标识符;
    
    // 测试2：枚举成员访问和比较
    如果 (类型 == 词元类型枚举.标识符) {
        // 正确识别枚举成员
    } 否则 {
        返回 1;  // 失败
    }
    
    // 测试3：switch语句中使用枚举
    选择 (类型) {
        情况 词元类型枚举.标识符:
            // 正确：识别标识符类型
            中断;
        情况 词元类型枚举.整数字面量:
            返回 2;  // 不应该到达这里
        默认:
            返回 3;  // 不应该到达这里
    }
    
    // 测试4：另一个枚举类型
    二元运算符 运算符 = 二元运算符.加法;
    
    选择 (运算符) {
        情况 二元运算符.加法:
            // 正确：识别加法运算符
            中断;
        情况 二元运算符.减法:
            返回 4;  // 不应该到达这里
        默认:
            返回 5;  // 不应该到达这里
    }
    
    // 测试5：枚举值赋值和比较
    词元类型枚举 另一个类型 = 词元类型枚举.关键字;
    
    如果 (另一个类型 == 词元类型枚举.关键字) {
        // 正确
    } 否则 {
        返回 6;
    }
    
    // 测试6：枚举值作为整数使用
    如果 (类型 == 0) {  // 标识符 = 0
        // 正确
    } 否则 {
        返回 7;
    }
    
    // 所有测试通过
    返回 0;
}
