// ============================================================================
// 运行时接口单元测试
// ============================================================================
// 功能：测试运行时接口各模块的功能
// 作者：CN语言自托管编译器项目
// ============================================================================

// 导入运行时模块
导入 运行时;

// ============================================================================
// 第一部分：测试计数器和辅助函数
// ============================================================================

/// 全局测试计数器
整数 通过计数 = 0;
整数 失败计数 = 0;

/// 断言相等（整数）
/// @param 期望 期望值
/// @param 实际 实际值
/// @param 消息 测试描述
函数 断言相等整数(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

/// 断言为真
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为真(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言为假
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为假(整数 条件, 字符串 消息) -> 空类型 {
    断言为真(条件 == 0, 消息);
}

/// 断言不为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言不为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 != 无, 消息);
}

/// 断言为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 == 无, 消息);
}

/// 断言字符串相等
/// @param 期望 期望字符串
/// @param 实际 实际字符串
/// @param 消息 测试描述
函数 断言字符串相等(字符串 期望, 字符串 实际, 字符串 消息) -> 空类型 {
    如果 (比较字符串(期望, 实际) == 0) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: '" + 期望 + "', 实际: '" + 实际 + "')");
    }
}

// ============================================================================
// 第二部分：内存管理接口测试
// ============================================================================

/// 测试内存管理接口
函数 测试内存管理() -> 空类型 {
    打印行("");
    打印行("[1] 内存管理接口测试");
    打印行("----------------------------------------");

    // 测试1：分配内存
    空类型* ptr = 分配内存(100);
    断言不为空(ptr, "分配内存(100)应返回非空指针");

    // 测试2：释放内存
    释放内存(ptr);
    通过计数 = 通过计数 + 1;
    打印行("✓ 释放内存成功");

    // 测试3：分配清零内存
    空类型* zero_ptr = 分配清零内存(10, 10);
    断言不为空(zero_ptr, "分配清零内存(10, 10)应返回非空指针");

    // 测试4：验证内存已清零
    整数* int_ptr = (整数*)zero_ptr;
    断言相等整数(0, int_ptr[0], "分配清零内存应初始化为0");

    释放内存(zero_ptr);

    // 测试5：重新分配内存
    空类型* realloc_ptr = 分配内存(50);
    断言不为空(realloc_ptr, "分配内存(50)应返回非空指针");

    空类型* new_ptr = 重新分配内存(realloc_ptr, 200);
    断言不为空(new_ptr, "重新分配内存(50->200)应返回非空指针");

    释放内存(new_ptr);

    // 测试6：分配大块内存
    空类型* large_ptr = 分配内存(1024 * 1024);
    断言不为空(large_ptr, "分配内存(1MB)应返回非空指针");
    释放内存(large_ptr);
}

// ============================================================================
// 第三部分：字符串操作接口测试
// ============================================================================

/// 测试字符串操作接口
函数 测试字符串操作() -> 空类型 {
    打印行("");
    打印行("[2] 字符串操作接口测试");
    打印行("----------------------------------------");

    // 测试1：获取字符串长度
    整数 len = 获取字符串长度("你好世界");
    断言相等整数(4, len, "获取字符串长度('你好世界')应返回4");

    // 测试2：获取空字符串长度
    整数 empty_len = 获取字符串长度("");
    断言相等整数(0, empty_len, "获取字符串长度('')应返回0");

    // 测试3：比较字符串（相等）
    整数 cmp_equal = 比较字符串("abc", "abc");
    断言相等整数(0, cmp_equal, "比较字符串('abc', 'abc')应返回0（相等）");

    // 测试4：比较字符串（小于）
    整数 cmp_less = 比较字符串("abc", "abd");
    断言为真(cmp_less < 0, "比较字符串('abc', 'abd')应返回负数（小于）");

    // 测试5：比较字符串（大于）
    整数 cmp_greater = 比较字符串("abd", "abc");
    断言为真(cmp_greater > 0, "比较字符串('abd', 'abc')应返回正数（大于）");

    // 测试6：限长比较字符串
    整数 cmp_n = 限长比较字符串("abcdef", "abcxyz", 3);
    断言相等整数(0, cmp_n, "限长比较字符串(前3字符)应返回0（相等）");

    // 测试7：查找字符
    字符串 found = 查找字符("hello", 'l');
    断言不为空(found, "查找字符('hello', 'l')应找到");

    // 测试8：查找不存在的字符
    字符串 not_found = 查找字符("hello", 'z');
    断言为空(not_found, "查找字符('hello', 'z')应返回无");

    // 测试9：查找子串
    字符串 substr = 查找子串("hello world", "world");
    断言不为空(substr, "查找子串('hello world', 'world')应找到");

    // 测试10：反向查找字符
    字符串 last_found = 反向查找字符("hello", 'l');
    断言不为空(last_found, "反向查找字符('hello', 'l')应找到");
}

// ============================================================================
// 第四部分：辅助函数接口测试
// ============================================================================

/// 测试辅助函数接口
函数 测试辅助函数() -> 空类型 {
    打印行("");
    打印行("[3] 辅助函数接口测试");
    打印行("----------------------------------------");

    // 测试1：获取绝对值（负数）
    整数 abs_neg = 获取绝对值(-10);
    断言相等整数(10, abs_neg, "获取绝对值(-10)应返回10");

    // 测试2：获取绝对值（正数）
    整数 abs_pos = 获取绝对值(10);
    断言相等整数(10, abs_pos, "获取绝对值(10)应返回10");

    // 测试3：获取绝对值（零）
    整数 abs_zero = 获取绝对值(0);
    断言相等整数(0, abs_zero, "获取绝对值(0)应返回0");

    // 测试4：求最大值
    整数 max_val = 求最大值(5, 10);
    断言相等整数(10, max_val, "求最大值(5, 10)应返回10");

    // 测试5：求最大值（相等）
    整数 max_same = 求最大值(7, 7);
    断言相等整数(7, max_same, "求最大值(7, 7)应返回7");

    // 测试6：求最小值
    整数 min_val = 求最小值(5, 10);
    断言相等整数(5, min_val, "求最小值(5, 10)应返回5");

    // 测试7：求最小值（相等）
    整数 min_same = 求最小值(7, 7);
    断言相等整数(7, min_same, "求最小值(7, 7)应返回7");

    // 测试8：转整数
    整数 int_val = 转整数("12345");
    断言相等整数(12345, int_val, "转整数('12345')应返回12345");

    // 测试9：转整数（负数）
    整数 int_neg = 转整数("-42");
    断言相等整数(-42, int_neg, "转整数('-42')应返回-42");

    // 测试10：是数字文本
    整数 is_num = 是数字文本("123.45");
    断言为真(is_num, "是数字文本('123.45')应返回真");

    // 测试11：是整数文本
    整数 is_int = 是整数文本("12345");
    断言为真(is_int, "是整数文本('12345')应返回真");

    // 测试12：是整数文本（非整数）
    整数 is_not_int = 是整数文本("12.34");
    断言为假(is_not_int, "是整数文本('12.34')应返回假");
}

// ============================================================================
// 第五部分：标准输入输出接口测试
// ============================================================================

/// 测试标准输入输出接口
函数 测试标准输入输出() -> 空类型 {
    打印行("");
    打印行("[4] 标准输入输出接口测试");
    打印行("----------------------------------------");

    // 测试1：打印字符串
    整数 print_result = 打印字符串("测试输出");
    断言为真(print_result >= 0, "打印字符串应返回非负数");

    // 测试2：打印行
    整数 println_result = 打印行("测试行输出");
    断言为真(println_result >= 0, "打印行应返回非负数");

    // 测试3：刷新输出
    整数 flush_result = 刷新输出();
    断言相等整数(0, flush_result, "刷新输出应返回0");
}

// ============================================================================
// 第六部分：命令行参数接口测试
// ============================================================================

/// 测试命令行参数接口
函数 测试命令行参数() -> 空类型 {
    打印行("");
    打印行("[5] 命令行参数接口测试");
    打印行("----------------------------------------");

    // 测试1：获取参数个数
    整数 argc = 获取参数个数();
    断言为真(argc >= 1, "获取参数个数应至少返回1（程序名）");

    // 测试2：获取程序名称
    字符串 prog_name = 获取程序名称();
    断言不为空(prog_name, "获取程序名称应返回非空字符串");

    // 测试3：获取参数（索引0）
    字符串 arg0 = 获取参数(0);
    断言不为空(arg0, "获取参数(0)应返回程序名");

    // 测试4：获取参数（越界索引）
    字符串 arg_invalid = 获取参数(9999);
    断言为空(arg_invalid, "获取参数(9999)应返回无（越界）");

    // 测试5：获取位置参数个数
    整数 pos_count = 获取位置参数个数();
    断言为真(pos_count >= 0, "获取位置参数个数应返回非负数");
}

// ============================================================================
// 第七部分：动态数组接口测试
// ============================================================================

/// 测试动态数组接口
函数 测试动态数组() -> 空类型 {
    打印行("");
    打印行("[6] 动态数组接口测试");
    打印行("----------------------------------------");

    // 测试1：创建数组
    空类型* arr = 创建数组(10);
    断言不为空(arr, "创建数组(10)应返回非空指针");

    // 测试2：初始长度为零
    整数 init_len = 数组长度(arr);
    断言相等整数(0, init_len, "新创建数组长度应为0");

    // 测试3：添加元素
    整数 val1 = 100;
    整数 add_result = 数组添加(arr, &val1);
    断言为真(add_result, "数组添加元素应成功");

    // 测试4：添加后长度增加
    整数 after_add_len = 数组长度(arr);
    断言相等整数(1, after_add_len, "添加元素后长度应为1");

    // 测试5：获取元素
    整数* elem = (整数*)数组获取(arr, 0);
    断言不为空(elem, "数组获取(0)应返回非空指针");
    断言相等整数(100, elem[0], "获取的元素值应为100");

    // 测试6：清空数组
    清空数组(arr);
    整数 after_clear_len = 数组长度(arr);
    断言相等整数(0, after_clear_len, "清空数组后长度应为0");

    // 测试7：销毁数组
    销毁数组(arr);
    通过计数 = 通过计数 + 1;
    打印行("✓ 销毁数组成功");
}

// ============================================================================
// 第八部分：哈希表接口测试
// ============================================================================

/// 测试哈希表接口
函数 测试哈希表() -> 空类型 {
    打印行("");
    打印行("[7] 哈希表接口测试");
    打印行("----------------------------------------");

    // 测试1：创建哈希表
    空类型* table = 创建哈希表(16);
    断言不为空(table, "创建哈希表(16)应返回非空指针");

    // 测试2：初始大小为零
    整数 init_size = 哈希表大小(table);
    断言相等整数(0, init_size, "新创建哈希表大小应为0");

    // 测试3：插入键值对
    整数 val1 = 100;
    整数 insert_result = 哈希表插入(table, "key1", &val1);
    断言为真(insert_result, "哈希表插入应成功");

    // 测试4：插入后大小增加
    整数 after_insert_size = 哈希表大小(table);
    断言相等整数(1, after_insert_size, "插入后大小应为1");

    // 测试5：获取值
    整数* found_val = (整数*)哈希表获取(table, "key1");
    断言不为空(found_val, "哈希表获取('key1')应找到");
    断言相等整数(100, found_val[0], "获取的值应为100");

    // 测试6：检查键存在
    整数 contains = 哈希表包含(table, "key1");
    断言为真(contains, "哈希表包含('key1')应返回真");

    // 测试7：检查键不存在
    整数 not_contains = 哈希表包含(table, "nonexistent");
    断言为假(not_contains, "哈希表包含('nonexistent')应返回假");

    // 测试8：清空哈希表
    清空哈希表(table);
    整数 after_clear_size = 哈希表大小(table);
    断言相等整数(0, after_clear_size, "清空哈希表后大小应为0");

    // 测试9：销毁哈希表
    销毁哈希表(table);
    通过计数 = 通过计数 + 1;
    打印行("✓ 销毁哈希表成功");
}

// ============================================================================
// 第九部分：主测试函数
// ============================================================================

/// 主测试函数
函数 主程序() -> 整数 {
    打印行("========================================");
    打印行("运行时接口单元测试");
    打印行("========================================");

    // 执行所有测试
    测试内存管理();
    测试字符串操作();
    测试辅助函数();
    测试标准输入输出();
    测试命令行参数();
    测试动态数组();
    测试哈希表();

    // 输出测试结果
    打印行("");
    打印行("========================================");
    打印行("测试结果: " + 整数转字符串(通过计数) + " 通过, " + 整数转字符串(失败计数) + " 失败");
    打印行("========================================");

    // 返回退出码
    如果 (失败计数 > 0) {
        返回 1;
    }
    返回 0;
}
