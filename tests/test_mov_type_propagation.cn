// 测试MOV指令的类型传播
// 问题：MOV指令从指针变量赋值时，类型传播失败

结构体 函数声明 {
    字符串 名称;
    整数 参数个数;
};

结构体 声明节点 {
    函数声明* 作为函数声明;
};

函数 测试MOV类型传播() -> 整数 {
    声明节点 声明;
    函数声明* 函数声明指针;
    
    // 这里的MOV指令应该正确传播指针类型
    函数声明指针 = 声明.作为函数声明;
    
    // 验证类型是否正确（通过返回值验证）
    如果 (函数声明指针 != 无) {
        返回 1;
    } 否则 {
        返回 0;
    }
}

函数 主程序() -> 整数 {
    返回 测试MOV类型传播();
}
