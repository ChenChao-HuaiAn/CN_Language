// 测试各种比较运算符
函数 测试比较运算符() -> 整数 {
    整数 a = 10;
    整数 b = 20;
    
    // 测试小于比较
    如果 (a < b) {
        返回 1;
    }
    
    // 测试小于等于比较
    如果 (a <= b) {
        返回 2;
    }
    
    // 测试大于比较
    如果 (a > b) {
        返回 3;
    }
    
    // 测试大于等于比较
    如果 (a >= b) {
        返回 4;
    }
    
    // 测试等于比较
    如果 (a == b) {
        返回 5;
    }
    
    // 测试不等于比较
    如果 (a != b) {
        返回 6;
    }
    
    返回 0;
}

// 测试复杂表达式
函数 测试复杂表达式() -> 整数 {
    整数 x = 5;
    整数 y = 10;
    整数 z = 15;
    
    // 测试多个比较表达式
    如果 (x < y && y < z) {
        返回 1;
    }
    
    如果 (x < y || x > z) {
        返回 2;
    }
    
    返回 0;
}
