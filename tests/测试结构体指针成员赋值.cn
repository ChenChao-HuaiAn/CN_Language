// 测试结构体指针成员赋值

结构体 扫描器 {
    整数 位置;
    整数 行号;
    整数 列号;
};

函数 主() -> 整数 {
    扫描器* 实例 = 分配内存(12);
    
    实例->位置 = 0;
    实例->行号 = 1;
    实例->列号 = 1;
    
    整数 c = 10;
    
    如果 (c == 10) {
        实例->行号 = 实例->行号 + 1;
        实例->列号 = 1;
    } 否则 {
        实例->列号 = 实例->列号 + 1;
    }
    
    返回 实例->列号;
}
