// 测试指针类型成员字段的类型传播
// 问题：MEMBER_ACCESS指令在处理指针类型的成员字段时，结果类型没有被正确传播

// 定义简单的结构体
结构体 函数声明 {
    整数 标识;
}

结构体 声明节点 {
    函数声明* 作为函数声明;  // 指针类型的成员字段
}

// 测试函数
函数 测试指针成员类型() -> 整数 {
    // 创建声明节点实例
    声明节点 节点;
    函数声明 声明;
    
    // 初始化
    声明.标识 = 100;
    节点.作为函数声明 = &声明;
    
    // 访问指针类型的成员字段
    // 这里 节点.作为函数声明 的类型应该是 函数声明*（指针类型）
    函数声明* 指针 = 节点.作为函数声明;
    
    // 通过指针访问成员
    返回 指针.标识;
}
