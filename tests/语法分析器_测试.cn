// =============================================================================
// CN语言语法分析器 - 单元测试主入口
// =============================================================================
//
// 本文件是语法分析器单元测试的主入口，负责：
// - 导入所有测试子模块
// - 运行所有测试用例
// - 统计测试结果
//
// 测试覆盖：
// - AST节点定义（节点类型、运算符、源位置）
// - 类型解析（基础类型、指针、数组、函数类型）
// - 表达式解析（字面量、二元、一元、函数调用等）
// - 语句解析（控制流、块语句、返回等）
// - 声明解析（函数、变量、结构体、枚举、类等）
// - 错误恢复（同步点、级联抑制、错误计数）
//
// =============================================================================

// 导入语法分析器模块
导入 语法分析器/解析器;
导入 语法分析器/AST节点;
导入 语法分析器/错误恢复;

// 导入词法分析器模块（测试依赖）
导入 词法分析器/词元;
导入 词法分析器/扫描器;

// 导入运行时模块
导入 运行时/运行时;

// =============================================================================
// 测试计数器和辅助函数
// =============================================================================

/// 全局测试计数器
变量 整数 通过计数 = 0;;
变量 整数 失败计数 = 0;;

/// 断言相等（整数）
函数 断言相等整数(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

/// 断言为真
函数 断言为真(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言为假
函数 断言为假(整数 条件, 字符串 消息) -> 空类型 {
    断言为真(条件 == 0, 消息);
}

/// 断言字符串相等
函数 断言字符串相等(字符串 期望, 字符串 实际, 字符串 消息) -> 空类型 {
    如果 (比较字符串(期望, 实际) == 0) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: '" + 期望 + "', 实际: '" + 实际 + "')");
    }
}

/// 断言不为空
函数 断言不为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 != 无, 消息);
}

/// 断言为空
函数 断言为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 == 无, 消息);
}

// =============================================================================
// 第一部分：AST节点类型测试
// =============================================================================

/// 测试AST节点类型枚举
函数 测试节点类型() -> 空类型 {
    打印行("");
    打印行("[1] AST节点类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：程序节点枚举值
    // -------------------------------------------------------------------------
    断言相等整数(0, 节点类型.程序节点 作为 整数, "节点类型.程序节点 枚举值应为0");

    // -------------------------------------------------------------------------
    // 测试2：声明节点枚举值
    // -------------------------------------------------------------------------
    断言相等整数(1, 节点类型.函数声明 作为 整数, "节点类型.函数声明 枚举值应为1");
    断言相等整数(2, 节点类型.变量声明 作为 整数, "节点类型.变量声明 枚举值应为2");
    断言相等整数(3, 节点类型.结构体声明 作为 整数, "节点类型.结构体声明 枚举值应为3");
    断言相等整数(4, 节点类型.枚举声明 作为 整数, "节点类型.枚举声明 枚举值应为4");

    // -------------------------------------------------------------------------
    // 测试3：语句节点枚举值
    // -------------------------------------------------------------------------
    断言相等整数(10, 节点类型.表达式语句 作为 整数, "节点类型.表达式语句 枚举值应为10");
    断言相等整数(11, 节点类型.块语句 作为 整数, "节点类型.块语句 枚举值应为11");
    断言相等整数(12, 节点类型.如果语句 作为 整数, "节点类型.如果语句 枚举值应为12");
    断言相等整数(13, 节点类型.当语句 作为 整数, "节点类型.当语句 枚举值应为13");
    断言相等整数(14, 节点类型.循环语句 作为 整数, "节点类型.循环语句 枚举值应为14");
    断言相等整数(15, 节点类型.返回语句 作为 整数, "节点类型.返回语句 枚举值应为15");

    // -------------------------------------------------------------------------
    // 测试4：表达式节点枚举值
    // -------------------------------------------------------------------------
    断言相等整数(20, 节点类型.二元表达式 作为 整数, "节点类型.二元表达式 枚举值应为20");
    断言相等整数(21, 节点类型.一元表达式 作为 整数, "节点类型.一元表达式 枚举值应为21");
    断言相等整数(22, 节点类型.字面量表达式 作为 整数, "节点类型.字面量表达式 枚举值应为22");
    断言相等整数(23, 节点类型.标识符表达式 作为 整数, "节点类型.标识符表达式 枚举值应为23");
    断言相等整数(24, 节点类型.函数调用表达式 作为 整数, "节点类型.函数调用表达式 枚举值应为24");
    断言相等整数(25, 节点类型.成员访问表达式 作为 整数, "节点类型.成员访问表达式 枚举值应为25");
    断言相等整数(26, 节点类型.数组访问表达式 作为 整数, "节点类型.数组访问表达式 枚举值应为26");
    断言相等整数(27, 节点类型.赋值表达式 作为 整数, "节点类型.赋值表达式 枚举值应为27");
    断言相等整数(28, 节点类型.三元表达式 作为 整数, "节点类型.三元表达式 枚举值应为28");

    // -------------------------------------------------------------------------
    // 测试5：类型节点枚举值
    // -------------------------------------------------------------------------
    断言相等整数(30, 节点类型.基础类型 作为 整数, "节点类型.基础类型 枚举值应为30");
    断言相等整数(31, 节点类型.指针类型 作为 整数, "节点类型.指针类型 枚举值应为31");
    断言相等整数(32, 节点类型.数组类型 作为 整数, "节点类型.数组类型 枚举值应为32");
    断言相等整数(33, 节点类型.函数类型 作为 整数, "节点类型.函数类型 枚举值应为33");
}

// =============================================================================
// 第二部分：运算符枚举测试
// =============================================================================

/// 测试运算符枚举
函数 测试运算符() -> 空类型 {
    打印行("");
    打印行("[2] 运算符枚举测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：二元运算符枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 二元运算符.加 作为 整数, "二元运算符.加 枚举值应为0");
    断言相等整数(1, 二元运算符.减 作为 整数, "二元运算符.减 枚举值应为1");
    断言相等整数(2, 二元运算符.乘 作为 整数, "二元运算符.乘 枚举值应为2");
    断言相等整数(3, 二元运算符.除 作为 整数, "二元运算符.除 枚举值应为3");
    断言相等整数(4, 二元运算符.取模 作为 整数, "二元运算符.取模 枚举值应为4");

    // 比较运算符
    断言相等整数(5, 二元运算符.等于 作为 整数, "二元运算符.等于 枚举值应为5");
    断言相等整数(6, 二元运算符.不等于 作为 整数, "二元运算符.不等于 枚举值应为6");
    断言相等整数(7, 二元运算符.小于 作为 整数, "二元运算符.小于 枚举值应为7");
    断言相等整数(8, 二元运算符.大于 作为 整数, "二元运算符.大于 枚举值应为8");

    // -------------------------------------------------------------------------
    // 测试2：一元运算符枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 一元运算符.逻辑非 作为 整数, "一元运算符.逻辑非 枚举值应为0");
    断言相等整数(1, 一元运算符.取负 作为 整数, "一元运算符.取负 枚举值应为1");
    断言相等整数(2, 一元运算符.取地址 作为 整数, "一元运算符.取地址 枚举值应为2");
    断言相等整数(3, 一元运算符.解引用 作为 整数, "一元运算符.解引用 枚举值应为3");
    断言相等整数(4, 一元运算符.位取反 作为 整数, "一元运算符.位取反 枚举值应为4");
    断言相等整数(5, 一元运算符.前置自增 作为 整数, "一元运算符.前置自增 枚举值应为5");
    断言相等整数(6, 一元运算符.前置自减 作为 整数, "一元运算符.前置自减 枚举值应为6");
    断言相等整数(7, 一元运算符.后置自增 作为 整数, "一元运算符.后置自增 枚举值应为7");
    断言相等整数(8, 一元运算符.后置自减 作为 整数, "一元运算符.后置自减 枚举值应为8");

    // -------------------------------------------------------------------------
    // 测试3：逻辑运算符枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 逻辑运算符.逻辑与 作为 整数, "逻辑运算符.逻辑与 枚举值应为0");
    断言相等整数(1, 逻辑运算符.逻辑或 作为 整数, "逻辑运算符.逻辑或 枚举值应为1");

    // -------------------------------------------------------------------------
    // 测试4：赋值运算符枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 赋值运算符.简单赋值 作为 整数, "赋值运算符.简单赋值 枚举值应为0");
    断言相等整数(1, 赋值运算符.加法赋值 作为 整数, "赋值运算符.加法赋值 枚举值应为1");
    断言相等整数(2, 赋值运算符.减法赋值 作为 整数, "赋值运算符.减法赋值 枚举值应为2");
    断言相等整数(3, 赋值运算符.乘法赋值 作为 整数, "赋值运算符.乘法赋值 枚举值应为3");

    // -------------------------------------------------------------------------
    // 测试5：字面量类型枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 字面量类型.整数字面量 作为 整数, "字面量类型.整数字面量 枚举值应为0");
    断言相等整数(1, 字面量类型.浮点字面量 作为 整数, "字面量类型.浮点字面量 枚举值应为1");
    断言相等整数(2, 字面量类型.字符串字面量 作为 整数, "字面量类型.字符串字面量 枚举值应为2");
    断言相等整数(3, 字面量类型.布尔字面量 作为 整数, "字面量类型.布尔字面量 枚举值应为3");
    断言相等整数(4, 字面量类型.空字面量 作为 整数, "字面量类型.空字面量 枚举值应为4");
}

// =============================================================================
// 第三部分：源位置和基础结构测试
// =============================================================================

/// 测试源位置结构
函数 测试源位置() -> 空类型 {
    打印行("");
    打印行("[3] 源位置结构测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：创建源位置
    // -------------------------------------------------------------------------
    变量 源位置 位置;
    位置.文件名 = "测试.cn";
    位置.行号 = 10;
    位置.列号 = 5;

    断言字符串相等("测试.cn", 位置.文件名, "源位置.文件名 应正确设置");
    断言相等整数(10, 位置.行号, "源位置.行号 应正确设置");
    断言相等整数(5, 位置.列号, "源位置.列号 应正确设置");

    // -------------------------------------------------------------------------
    // 测试2：AST节点基类
    // -------------------------------------------------------------------------
    变量 AST节点 节点;
    节点.类型 = 节点类型.二元表达式;
    节点.位置 = 位置;

    断言相等整数(节点类型.二元表达式 作为 整数, 节点.类型 作为 整数, "AST节点.类型 应正确设置");
    断言字符串相等("测试.cn", 节点.位置.文件名, "AST节点.位置 应正确继承");
}

// =============================================================================
// 第四部分：类型节点测试
// =============================================================================

/// 测试类型节点
函数 测试类型节点() -> 空类型 {
    打印行("");
    打印行("[4] 类型节点测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：基础类型节点
    // -------------------------------------------------------------------------
    变量 类型节点 整数类型;
    整数类型.类型 = 节点类型.基础类型;
    整数类型.名称 = "整数";
    整数类型.指针层级 = 0;
    整数类型.数组维度 = 0;

    断言相等整数(节点类型.基础类型 作为 整数, 整数类型.类型 作为 整数, "基础类型节点类型应正确");
    断言字符串相等("整数", 整数类型.名称, "基础类型名称应正确");
    断言相等整数(0, 整数类型.指针层级, "基础类型指针层级应为0");

    // -------------------------------------------------------------------------
    // 测试2：指针类型节点
    // -------------------------------------------------------------------------
    变量 类型节点 指针类型;
    指针类型.类型 = 节点类型.指针类型;
    指针类型.名称 = "整数*";
    指针类型.指针层级 = 1;

    断言相等整数(节点类型.指针类型 作为 整数, 指针类型.类型 作为 整数, "指针类型节点类型应正确");
    断言相等整数(1, 指针类型.指针层级, "指针层级应为1");

    // -------------------------------------------------------------------------
    // 测试3：数组类型节点
    // -------------------------------------------------------------------------
    变量 类型节点 数组类型;
    数组类型.类型 = 节点类型.数组类型;
    数组类型.名称 = "整数[]";
    数组类型.数组维度 = 1;
    数组类型.数组大小 = 10;

    断言相等整数(节点类型.数组类型 作为 整数, 数组类型.类型 作为 整数, "数组类型节点类型应正确");
    断言相等整数(1, 数组类型.数组维度, "数组维度应为1");
    断言相等整数(10, 数组类型.数组大小, "数组大小应为10");
}

// =============================================================================
// 第五部分：错误恢复测试
// =============================================================================

/// 测试错误恢复机制
函数 测试错误恢复() -> 空类型 {
    打印行("");
    打印行("[5] 错误恢复测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：同步点类型枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 同步点类型.同步点_分号 作为 整数, "同步点类型.同步点_分号 枚举值应为0");
    断言相等整数(1, 同步点类型.同步点_右大括号 作为 整数, "同步点类型.同步点_右大括号 枚举值应为1");
    断言相等整数(2, 同步点类型.同步点_右小括号 作为 整数, "同步点类型.同步点_右小括号 枚举值应为2");
    断言相等整数(3, 同步点类型.同步点_右中括号 作为 整数, "同步点类型.同步点_右中括号 枚举值应为3");

    // -------------------------------------------------------------------------
    // 测试2：恢复策略枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 语法恢复策略.不恢复 作为 整数, "语法恢复策略.不恢复 枚举值应为0");
    断言相等整数(1, 语法恢复策略.跳过词元 作为 整数, "语法恢复策略.跳过词元 枚举值应为1");
    断言相等整数(2, 语法恢复策略.同步到分号 作为 整数, "语法恢复策略.同步到分号 枚举值应为2");
    断言相等整数(3, 语法恢复策略.同步到大括号 作为 整数, "语法恢复策略.同步到大括号 枚举值应为3");

    // -------------------------------------------------------------------------
    // 测试3：错误恢复上下文初始化
    // -------------------------------------------------------------------------
    变量 语法错误恢复上下文 上下文;
    变量 布尔 初始化结果 = 初始化错误恢复(&上下文);

    断言为真(初始化结果, "初始化错误恢复 应成功");
    断言相等整数(0, 上下文.连续错误计数, "初始化后连续错误计数应为0");
    断言相等整数(3, 上下文.最大连续错误, "默认最大连续错误应为3");
    断言为假(上下文.抑制级联错误, "初始化后不应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试4：错误记录和计数
    // -------------------------------------------------------------------------
    记录错误(&上下文, 10);
    断言相等整数(1, 上下文.连续错误计数, "记录一次错误后计数应为1");
    断言相等整数(10, 上下文.最后错误行号, "最后错误行号应为10");

    记录错误(&上下文, 20);
    记录错误(&上下文, 30);
    断言相等整数(3, 上下文.连续错误计数, "记录三次错误后计数应为3");

    // -------------------------------------------------------------------------
    // 测试5：级联错误抑制
    // -------------------------------------------------------------------------
    变量 布尔 应该抑制 = 应该抑制错误(&上下文);
    断言为真(应该抑制, "连续错误达到阈值后应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试6：重置错误计数
    // -------------------------------------------------------------------------
    重置错误计数(&上下文);
    断言相等整数(0, 上下文.连续错误计数, "重置后连续错误计数应为0");
    断言为假(上下文.抑制级联错误, "重置后不应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试7：同步点检测
    // -------------------------------------------------------------------------
    变量 布尔 是分号同步点 = 是同步点(词元类型.分号 作为 整数, 同步点类型.同步点_分号);
    断言为真(是分号同步点, "分号 应该是分号同步点");

    变量 布尔 是大括号同步点 = 是同步点(词元类型.右大括号 作为 整数, 同步点类型.同步点_右大括号);
    断言为真(是大括号同步点, "右大括号 应该是右大括号同步点");

    // -------------------------------------------------------------------------
    // 测试8：任意同步点检测
    // -------------------------------------------------------------------------
    变量 布尔 是任意分号 = 是任意同步点(词元类型.分号 作为 整数);
    断言为真(是任意分号, "分号 应该是任意同步点");

    变量 布尔 是任意大括号 = 是任意同步点(词元类型.右大括号 作为 整数);
    断言为真(是任意大括号, "右大括号 应该是任意同步点");

    // -------------------------------------------------------------------------
    // 测试9：恢复策略选择
    // -------------------------------------------------------------------------
    变量 语法恢复策略 策略 = 选择恢复策略(诊断错误码.语法_期望标记 作为 整数);
    断言为真(策略 != 语法恢复策略.不恢复, "语法错误应选择恢复策略");

    // -------------------------------------------------------------------------
    // 测试10：销毁错误恢复上下文
    // -------------------------------------------------------------------------
    销毁错误恢复上下文(&上下文);
}

// =============================================================================
// 第六部分：可见性和导入类型测试
// =============================================================================

/// 测试可见性和导入类型枚举
函数 测试可见性和导入() -> 空类型 {
    打印行("");
    打印行("[6] 可见性和导入类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：可见性枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 可见性.默认可见 作为 整数, "可见性.默认可见 枚举值应为0");
    断言相等整数(1, 可见性.公开可见 作为 整数, "可见性.公开可见 枚举值应为1");
    断言相等整数(2, 可见性.私有可见 作为 整数, "可见性.私有可见 枚举值应为2");

    // -------------------------------------------------------------------------
    // 测试2：导入类型枚举
    // -------------------------------------------------------------------------
    断言相等整数(0, 导入类型.全量导入 作为 整数, "导入类型.全量导入 枚举值应为0");
    断言相等整数(1, 导入类型.选择性导入 作为 整数, "导入类型.选择性导入 枚举值应为1");
    断言相等整数(2, 导入类型.别名导入 作为 整数, "导入类型.别名导入 枚举值应为2");
    断言相等整数(3, 导入类型.从模块选择性导入 作为 整数, "导入类型.从模块选择性导入 枚举值应为3");
    断言相等整数(4, 导入类型.从模块通配符导入 作为 整数, "导入类型.从模块通配符导入 枚举值应为4");
}

// =============================================================================
// 主测试入口
// =============================================================================

/// 主测试函数
函数 主程序() -> 整数 {
    打印行("========================================");
    打印行("CN语言语法分析器单元测试");
    打印行("========================================");

    // 运行所有测试
    测试节点类型();
    测试运算符();
    测试源位置();
    测试类型节点();
    测试错误恢复();
    测试可见性和导入();

    // 输出测试结果
    打印行("");
    打印行("========================================");
    打印行("测试结果: " + 整数转字符串(通过计数) + " 通过, " + 整数转字符串(失败计数) + " 失败");
    打印行("========================================");

    如果 (失败计数 == 0) {
        返回 0;
    } 否则 {
        返回 1;
    }
}
