// 测试枚举模块 - 定义同名结构体和枚举
// 用于验证同名不同类型符号可以共存

// 定义一个枚举类型（与结构体同名前缀）
枚举 词元类型枚举 {
    标识符,     // 0
    整数字面量, // 1
    字符串字面量, // 2
    运算符,     // 3
    分隔符,     // 4
    关键字,     // 5
    错误        // 6
}

// 定义一个结构体类型（与枚举同名前缀）
结构体 词元 {
    词元类型枚举 类型;  // 使用枚举类型作为字段
    字符串 内容;
    整数 行号;
    整数 列号;
}

// 定义二元运算符枚举
枚举 二元运算符 {
    加法,   // 0
    减法,   // 1
    乘法,   // 2
    除法,   // 3
    取模    // 4
}

// 公开函数：创建词元
公开:
函数 创建词元(词元类型枚举 类型, 字符串 内容, 整数 行号, 整数 列号) -> 词元 {
    词元 结果;
    结果.类型 = 类型;
    结果.内容 = 内容;
    结果.行号 = 行号;
    结果.列号 = 列号;
    返回 结果;
}

// 公开函数：获取词元类型名称
函数 获取类型名称(词元类型枚举 类型) -> 字符串 {
    选择 (类型) {
        情况 词元类型枚举.标识符:
            返回 "标识符";
        情况 词元类型枚举.整数字面量:
            返回 "整数字面量";
        情况 词元类型枚举.字符串字面量:
            返回 "字符串字面量";
        情况 词元类型枚举.运算符:
            返回 "运算符";
        情况 词元类型枚举.分隔符:
            返回 "分隔符";
        情况 词元类型枚举.关键字:
            返回 "关键字";
        情况 词元类型枚举.错误:
            返回 "错误";
        默认:
            返回 "未知";
    }
}
