// =============================================================================
// CN语言词法分析器 - 单元测试
// =============================================================================
//
// 本文件测试词法分析器各模块的功能：
// - 词元类型定义（83种词元类型）
// - 关键字查找表（41个关键字）
// - 字符工具函数（21个函数）
// - 扫描器核心功能
// - 错误恢复机制
//
// 测试覆盖率目标：
// - 词元类型：100%
// - 关键字表：100%
// - 字符工具：100%
// - 扫描器核心：90%+
// - 错误恢复：80%+
//
// =============================================================================

// 导入词法分析器模块
导入 词法分析器.词元;
导入 词法分析器.关键字;
导入 词法分析器.字符工具;
导入 词法分析器.扫描器;
导入 词法分析器.错误恢复;

// 导入运行时模块
导入 运行时;

// =============================================================================
// 第一部分：测试计数器和辅助函数
// =============================================================================

/// 全局测试计数器
整数 通过计数 = 0;
整数 失败计数 = 0;

/// 断言相等（整数）
/// @param 期望 期望值
/// @param 实际 实际值
/// @param 消息 测试描述
函数 断言相等整数(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

/// 断言为真
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为真(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言为假
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为假(整数 条件, 字符串 消息) -> 空类型 {
    断言为真(条件 == 0, 消息);
}

/// 断言字符串相等
/// @param 期望 期望字符串
/// @param 实际 实际字符串
/// @param 消息 测试描述
函数 断言字符串相等(字符串 期望, 字符串 实际, 字符串 消息) -> 空类型 {
    如果 (比较字符串(期望, 实际) == 0) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: '" + 期望 + "', 实际: '" + 实际 + "')");
    }
}

/// 断言不为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言不为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 != 无, 消息);
}

/// 断言为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言为空(空类型* 指针, 字符串 消息) -> 空类型 {
    断言为真(指针 == 无, 消息);
}

// =============================================================================
// 第二部分：词元类型测试
// =============================================================================

/// 测试词元类型定义
/// 测试所有83种词元类型的枚举值和名称获取函数
函数 测试词元类型() -> 空类型 {
    打印行("");
    打印行("[1] 词元类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：关键字枚举值连续性
    // -------------------------------------------------------------------------
    // 控制流关键字（10个）
    断言相等整数(0, 关键字_如果 作为 整数, "关键字_如果 枚举值应为0");
    断言相等整数(1, 关键字_否则 作为 整数, "关键字_否则 枚举值应为1");
    断言相等整数(2, 关键字_当 作为 整数, "关键字_当 枚举值应为2");
    断言相等整数(3, 关键字_循环 作为 整数, "关键字_循环 枚举值应为3");
    断言相等整数(9, 关键字_默认 作为 整数, "关键字_默认 枚举值应为9");

    // 类型关键字（7个）
    断言相等整数(10, 关键字_整数 作为 整数, "关键字_整数 枚举值应为10");
    断言相等整数(16, 关键字_枚举 作为 整数, "关键字_枚举 枚举值应为16");

    // 声明关键字（8个）
    断言相等整数(17, 关键字_函数 作为 整数, "关键字_函数 枚举值应为17");
    断言相等整数(24, 关键字_静态 作为 整数, "关键字_静态 枚举值应为24");

    // 常量关键字（3个）
    断言相等整数(25, 关键字_真 作为 整数, "关键字_真 枚举值应为25");
    断言相等整数(27, 关键字_无 作为 整数, "关键字_无 枚举值应为27");

    // -------------------------------------------------------------------------
    // 测试2：词元类型名称获取
    // -------------------------------------------------------------------------
    断言字符串相等("关键字_如果", 词元类型名称(关键字_如果), "词元类型名称(关键字_如果)应返回正确名称");
    断言字符串相等("关键字_函数", 词元类型名称(关键字_函数), "词元类型名称(关键字_函数)应返回正确名称");
    断言字符串相等("标识符", 词元类型名称(标识符), "词元类型名称(标识符)应返回正确名称");
    断言字符串相等("整数字面量", 词元类型名称(整数字面量), "词元类型名称(整数字面量)应返回正确名称");
    断言字符串相等("加号", 词元类型名称(加号), "词元类型名称(加号)应返回正确名称");
    断言字符串相等("左括号", 词元类型名称(左括号), "词元类型名称(左括号)应返回正确名称");
    断言字符串相等("结束", 词元类型名称(结束), "词元类型名称(结束)应返回正确名称");
    断言字符串相等("错误", 词元类型名称(错误), "词元类型名称(错误)应返回正确名称");

    // -------------------------------------------------------------------------
    // 测试3：创建词元
    // -------------------------------------------------------------------------
    变量 词元 测试词元 = 创建词元(标识符, "测试", 1, 5);
    断言相等整数(标识符 作为 整数, 测试词元.类型 作为 整数, "创建词元类型应正确");
    断言字符串相等("测试", 测试词元.值, "创建词元值应正确");
    断言相等整数(1, 测试词元.行号, "创建词元行号应正确");
    断言相等整数(5, 测试词元.列号, "创建词元列号应正确");
    断言相等整数(2, 测试词元.长度, "创建词元长度应正确");

    // -------------------------------------------------------------------------
    // 测试4：词元类型分类判断
    // -------------------------------------------------------------------------
    // 是关键字测试
    断言为真(是关键字(关键字_如果), "关键字_如果 应该是关键字");
    断言为真(是关键字(关键字_函数), "关键字_函数 应该是关键字");
    断言为真(是关键字(关键字_真), "关键字_真 应该是关键字");
    断言为假(是关键字(标识符), "标识符 不应该是关键字");
    断言为假(是关键字(加号), "加号 不应该是关键字");

    // 是字面量测试
    断言为真(是字面量(标识符), "标识符 应该是字面量");
    断言为真(是字面量(整数字面量), "整数字面量 应该是字面量");
    断言为真(是字面量(字符串字面量), "字符串字面量 应该是字面量");
    断言为假(是字面量(关键字_如果), "关键字_如果 不应该是字面量");
    断言为假(是字面量(加号), "加号 不应该是字面量");

    // 是运算符测试
    断言为真(是运算符(加号), "加号 应该是运算符");
    断言为真(是运算符(等于), "等于 应该是运算符");
    断言为真(是运算符(逻辑与), "逻辑与 应该是运算符");
    断言为真(是运算符(自增), "自增 应该是运算符");
    断言为假(是运算符(标识符), "标识符 不应该是运算符");
    断言为假(是运算符(左括号), "左括号 不应该是运算符");

    // 是分隔符测试
    断言为真(是分隔符(左括号), "左括号 应该是分隔符");
    断言为真(是分隔符(右大括号), "右大括号 应该是分隔符");
    断言为真(是分隔符(分号), "分号 应该是分隔符");
    断言为假(是分隔符(加号), "加号 不应该是分隔符");
    断言为假(是分隔符(标识符), "标识符 不应该是分隔符");
}

// =============================================================================
// 第三部分：关键字表测试
// =============================================================================

/// 测试关键字查找表
/// 测试所有41个关键字的查找功能
函数 测试关键字表() -> 空类型 {
    打印行("");
    打印行("[2] 关键字表测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：关键字总数
    // -------------------------------------------------------------------------
    断言相等整数(41, 关键字总数(), "关键字总数应为41");

    // -------------------------------------------------------------------------
    // 测试2：控制流关键字查找（10个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_如果 作为 整数, 查找关键字("如果") 作为 整数, "查找关键字('如果')应返回关键字_如果");
    断言相等整数(关键字_否则 作为 整数, 查找关键字("否则") 作为 整数, "查找关键字('否则')应返回关键字_否则");
    断言相等整数(关键字_当 作为 整数, 查找关键字("当") 作为 整数, "查找关键字('当')应返回关键字_当");
    断言相等整数(关键字_循环 作为 整数, 查找关键字("循环") 作为 整数, "查找关键字('循环')应返回关键字_循环");
    断言相等整数(关键字_返回 作为 整数, 查找关键字("返回") 作为 整数, "查找关键字('返回')应返回关键字_返回");
    断言相等整数(关键字_中断 作为 整数, 查找关键字("中断") 作为 整数, "查找关键字('中断')应返回关键字_中断");
    断言相等整数(关键字_继续 作为 整数, 查找关键字("继续") 作为 整数, "查找关键字('继续')应返回关键字_继续");
    断言相等整数(关键字_选择 作为 整数, 查找关键字("选择") 作为 整数, "查找关键字('选择')应返回关键字_选择");
    断言相等整数(关键字_情况 作为 整数, 查找关键字("情况") 作为 整数, "查找关键字('情况')应返回关键字_情况");
    断言相等整数(关键字_默认 作为 整数, 查找关键字("默认") 作为 整数, "查找关键字('默认')应返回关键字_默认");

    // -------------------------------------------------------------------------
    // 测试3：类型关键字查找（7个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_整数 作为 整数, 查找关键字("整数") 作为 整数, "查找关键字('整数')应返回关键字_整数");
    断言相等整数(关键字_小数 作为 整数, 查找关键字("小数") 作为 整数, "查找关键字('小数')应返回关键字_小数");
    断言相等整数(关键字_字符串 作为 整数, 查找关键字("字符串") 作为 整数, "查找关键字('字符串')应返回关键字_字符串");
    断言相等整数(关键字_布尔 作为 整数, 查找关键字("布尔") 作为 整数, "查找关键字('布尔')应返回关键字_布尔");
    断言相等整数(关键字_空类型 作为 整数, 查找关键字("空类型") 作为 整数, "查找关键字('空类型')应返回关键字_空类型");
    断言相等整数(关键字_结构体 作为 整数, 查找关键字("结构体") 作为 整数, "查找关键字('结构体')应返回关键字_结构体");
    断言相等整数(关键字_枚举 作为 整数, 查找关键字("枚举") 作为 整数, "查找关键字('枚举')应返回关键字_枚举");

    // -------------------------------------------------------------------------
    // 测试4：声明关键字查找（8个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_函数 作为 整数, 查找关键字("函数") 作为 整数, "查找关键字('函数')应返回关键字_函数");
    断言相等整数(关键字_变量 作为 整数, 查找关键字("变量") 作为 整数, "查找关键字('变量')应返回关键字_变量");
    断言相等整数(关键字_模块 作为 整数, 查找关键字("模块") 作为 整数, "查找关键字('模块')应返回关键字_模块");
    断言相等整数(关键字_导入 作为 整数, 查找关键字("导入") 作为 整数, "查找关键字('导入')应返回关键字_导入");
    断言相等整数(关键字_从 作为 整数, 查找关键字("从") 作为 整数, "查找关键字('从')应返回关键字_从");
    断言相等整数(关键字_公开 作为 整数, 查找关键字("公开") 作为 整数, "查找关键字('公开')应返回关键字_公开");
    断言相等整数(关键字_私有 作为 整数, 查找关键字("私有") 作为 整数, "查找关键字('私有')应返回关键字_私有");
    断言相等整数(关键字_静态 作为 整数, 查找关键字("静态") 作为 整数, "查找关键字('静态')应返回关键字_静态");

    // -------------------------------------------------------------------------
    // 测试5：常量关键字查找（3个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_真 作为 整数, 查找关键字("真") 作为 整数, "查找关键字('真')应返回关键字_真");
    断言相等整数(关键字_假 作为 整数, 查找关键字("假") 作为 整数, "查找关键字('假')应返回关键字_假");
    断言相等整数(关键字_无 作为 整数, 查找关键字("无") 作为 整数, "查找关键字('无')应返回关键字_无");

    // -------------------------------------------------------------------------
    // 测试6：OOP关键字查找（9个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_类 作为 整数, 查找关键字("类") 作为 整数, "查找关键字('类')应返回关键字_类");
    断言相等整数(关键字_接口 作为 整数, 查找关键字("接口") 作为 整数, "查找关键字('接口')应返回关键字_接口");
    断言相等整数(关键字_保护 作为 整数, 查找关键字("保护") 作为 整数, "查找关键字('保护')应返回关键字_保护");
    断言相等整数(关键字_虚拟 作为 整数, 查找关键字("虚拟") 作为 整数, "查找关键字('虚拟')应返回关键字_虚拟");
    断言相等整数(关键字_重写 作为 整数, 查找关键字("重写") 作为 整数, "查找关键字('重写')应返回关键字_重写");
    断言相等整数(关键字_抽象 作为 整数, 查找关键字("抽象") 作为 整数, "查找关键字('抽象')应返回关键字_抽象");
    断言相等整数(关键字_实现 作为 整数, 查找关键字("实现") 作为 整数, "查找关键字('实现')应返回关键字_实现");
    断言相等整数(关键字_自身 作为 整数, 查找关键字("自身") 作为 整数, "查找关键字('自身')应返回关键字_自身");
    断言相等整数(关键字_基类 作为 整数, 查找关键字("基类") 作为 整数, "查找关键字('基类')应返回关键字_基类");

    // -------------------------------------------------------------------------
    // 测试7：异常处理关键字查找（4个）
    // -------------------------------------------------------------------------
    断言相等整数(关键字_尝试 作为 整数, 查找关键字("尝试") 作为 整数, "查找关键字('尝试')应返回关键字_尝试");
    断言相等整数(关键字_捕获 作为 整数, 查找关键字("捕获") 作为 整数, "查找关键字('捕获')应返回关键字_捕获");
    断言相等整数(关键字_抛出 作为 整数, 查找关键字("抛出") 作为 整数, "查找关键字('抛出')应返回关键字_抛出");
    断言相等整数(关键字_最终 作为 整数, 查找关键字("最终") 作为 整数, "查找关键字('最终')应返回关键字_最终");

    // -------------------------------------------------------------------------
    // 测试8：非关键字字符串返回标识符类型
    // -------------------------------------------------------------------------
    断言相等整数(标识符 作为 整数, 查找关键字("变量名") 作为 整数, "查找关键字('变量名')应返回标识符");
    断言相等整数(标识符 作为 整数, 查找关键字("myVar") 作为 整数, "查找关键字('myVar')应返回标识符");
    断言相等整数(标识符 作为 整数, 查找关键字("test123") 作为 整数, "查找关键字('test123')应返回标识符");
    断言相等整数(标识符 作为 整数, 查找关键字("") 作为 整数, "查找关键字('')应返回标识符");

    // -------------------------------------------------------------------------
    // 测试9：是关键字字符串判断
    // -------------------------------------------------------------------------
    断言为真(是关键字字符串("函数"), "'函数' 应该是关键字字符串");
    断言为真(是关键字字符串("如果"), "'如果' 应该是关键字字符串");
    断言为假(是关键字字符串("变量名"), "'变量名' 不应该是关键字字符串");
    断言为假(是关键字字符串("myVar"), "'myVar' 不应该是关键字字符串");
}

// =============================================================================
// 第四部分：字符工具测试
// =============================================================================

/// 测试字符工具函数
/// 测试所有21个字符判断函数
函数 测试字符工具() -> 空类型 {
    打印行("");
    打印行("[3] 字符工具测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：空白字符判断
    // -------------------------------------------------------------------------
    断言为真(是空白字符(' '), "空格应该是空白字符");
    断言为真(是空白字符('\t'), "制表符应该是空白字符");
    断言为真(是空白字符('\n'), "换行符应该是空白字符");
    断言为真(是空白字符('\r'), "回车符应该是空白字符");
    断言为假(是空白字符('a'), "'a' 不应该是空白字符");
    断言为假(是空白字符('0'), "'0' 不应该是空白字符");

    // -------------------------------------------------------------------------
    // 测试2：换行符判断
    // -------------------------------------------------------------------------
    断言为真(是换行符('\n'), "'\\n' 应该是换行符");
    断言为真(是换行符('\r'), "'\\r' 应该是换行符");
    断言为假(是换行符(' '), "空格不应该是换行符");
    断言为假(是换行符('a'), "'a' 不应该是换行符");

    // -------------------------------------------------------------------------
    // 测试3：数字判断
    // -------------------------------------------------------------------------
    // 十进制数字
    断言为真(是数字('0'), "'0' 应该是数字");
    断言为真(是数字('5'), "'5' 应该是数字");
    断言为真(是数字('9'), "'9' 应该是数字");
    断言为假(是数字('a'), "'a' 不应该是数字");
    断言为假(是数字('A'), "'A' 不应该是数字");

    // 十六进制数字
    断言为真(是十六进制数字('0'), "'0' 应该是十六进制数字");
    断言为真(是十六进制数字('9'), "'9' 应该是十六进制数字");
    断言为真(是十六进制数字('a'), "'a' 应该是十六进制数字");
    断言为真(是十六进制数字('f'), "'f' 应该是十六进制数字");
    断言为真(是十六进制数字('A'), "'A' 应该是十六进制数字");
    断言为真(是十六进制数字('F'), "'F' 应该是十六进制数字");
    断言为假(是十六进制数字('g'), "'g' 不应该是十六进制数字");
    断言为假(是十六进制数字('G'), "'G' 不应该是十六进制数字");

    // 二进制数字
    断言为真(是二进制数字('0'), "'0' 应该是二进制数字");
    断言为真(是二进制数字('1'), "'1' 应该是二进制数字");
    断言为假(是二进制数字('2'), "'2' 不应该是二进制数字");
    断言为假(是二进制数字('a'), "'a' 不应该是二进制数字");

    // 八进制数字
    断言为真(是八进制数字('0'), "'0' 应该是八进制数字");
    断言为真(是八进制数字('7'), "'7' 应该是八进制数字");
    断言为假(是八进制数字('8'), "'8' 不应该是八进制数字");
    断言为假(是八进制数字('9'), "'9' 不应该是八进制数字");

    // -------------------------------------------------------------------------
    // 测试4：字母判断
    // -------------------------------------------------------------------------
    断言为真(是字母('a'), "'a' 应该是字母");
    断言为真(是字母('z'), "'z' 应该是字母");
    断言为真(是字母('A'), "'A' 应该是字母");
    断言为真(是字母('Z'), "'Z' 应该是字母");
    断言为假(是字母('0'), "'0' 不应该是字母");
    断言为假(是字母('_'), "'_' 不应该是字母");

    // 字母或数字
    断言为真(是字母或数字('a'), "'a' 应该是字母或数字");
    断言为真(是字母或数字('Z'), "'Z' 应该是字母或数字");
    断言为真(是字母或数字('0'), "'0' 应该是字母或数字");
    断言为真(是字母或数字('9'), "'9' 应该是字母或数字");
    断言为假(是字母或数字('_'), "'_' 不应该是字母或数字");
    断言为假(是字母或数字(' '), "' ' 不应该是字母或数字");

    // -------------------------------------------------------------------------
    // 测试5：标识符字符判断
    // -------------------------------------------------------------------------
    // 标识符开头
    断言为真(是标识符开头('a'), "'a' 应该可以作为标识符开头");
    断言为真(是标识符开头('Z'), "'Z' 应该可以作为标识符开头");
    断言为真(是标识符开头('_'), "'_' 应该可以作为标识符开头");
    断言为假(是标识符开头('0'), "'0' 不应该可以作为标识符开头");
    断言为假(是标识符开头('1'), "'1' 不应该可以作为标识符开头");

    // 标识符字符
    断言为真(是标识符字符('a'), "'a' 应该可以作为标识符字符");
    断言为真(是标识符字符('Z'), "'Z' 应该可以作为标识符字符");
    断言为真(是标识符字符('_'), "'_' 应该可以作为标识符字符");
    断言为真(是标识符字符('0'), "'0' 应该可以作为标识符字符");
    断言为真(是标识符字符('9'), "'9' 应该可以作为标识符字符");
    断言为假(是标识符字符(' '), "' ' 不应该可以作为标识符字符");
    断言为假(是标识符字符('+'), "'+' 不应该可以作为标识符字符");

    // -------------------------------------------------------------------------
    // 测试6：运算符字符判断
    // -------------------------------------------------------------------------
    断言为真(是运算符字符('+'), "'+' 应该是运算符字符");
    断言为真(是运算符字符('-'), "'-' 应该是运算符字符");
    断言为真(是运算符字符('*'), "'*' 应该是运算符字符");
    断言为真(是运算符字符('/'), "'/' 应该是运算符字符");
    断言为真(是运算符字符('%'), "'%' 应该是运算符字符");
    断言为真(是运算符字符('='), "'=' 应该是运算符字符");
    断言为真(是运算符字符('!'), "'!' 应该是运算符字符");
    断言为真(是运算符字符('<'), "'<' 应该是运算符字符");
    断言为真(是运算符字符('>'), "'>' 应该是运算符字符");
    断言为真(是运算符字符('&'), "'&' 应该是运算符字符");
    断言为真(是运算符字符('|'), "'|' 应该是运算符字符");
    断言为真(是运算符字符('^'), "'^' 应该是运算符字符");
    断言为真(是运算符字符('~'), "'~' 应该是运算符字符");
    断言为假(是运算符字符('a'), "'a' 不应该是运算符字符");
    断言为假(是运算符字符('('), "'(' 不应该是运算符字符");

    // -------------------------------------------------------------------------
    // 测试7：分隔符字符判断
    // -------------------------------------------------------------------------
    断言为真(是分隔符字符('('), "'(' 应该是分隔符字符");
    断言为真(是分隔符字符(')'), "')' 应该是分隔符字符");
    断言为真(是分隔符字符('{'), "'{' 应该是分隔符字符");
    断言为真(是分隔符字符(''), "'}' 应该是分隔符字符");
    断言为真(是分隔符字符('['), "'[' 应该是分隔符字符");
    断言为真(是分隔符字符(']'), "']' 应该是分隔符字符");
    断言为真(是分隔符字符(';'), "';' 应该是分隔符字符");
    断言为真(是分隔符字符(','), "',' 应该是分隔符字符");
    断言为真(是分隔符字符('.'), "'.' 应该是分隔符字符");
    断言为真(是分隔符字符(':'), "':' 应该是分隔符字符");
    断言为真(是分隔符字符('?'), "'?' 应该是分隔符字符");
    断言为假(是分隔符字符('a'), "'a' 不应该是分隔符字符");
    断言为假(是分隔符字符('+'), "'+' 不应该是分隔符字符");

    // -------------------------------------------------------------------------
    // 测试8：字符转换函数
    // -------------------------------------------------------------------------
    断言相等整数('a' 作为 整数, 转小写('A') 作为 整数, "转小写('A')应返回'a'");
    断言相等整数('a' 作为 整数, 转小写('a') 作为 整数, "转小写('a')应返回'a'");
    断言相等整数('A' 作为 整数, 转大写('a') 作为 整数, "转大写('a')应返回'A'");
    断言相等整数('A' 作为 整数, 转大写('A') 作为 整数, "转大写('A')应返回'A'");

    // -------------------------------------------------------------------------
    // 测试9：可打印字符判断
    // -------------------------------------------------------------------------
    断言为真(是可打印字符(' '), "' ' 应该是可打印字符");
    断言为真(是可打印字符('a'), "'a' 应该是可打印字符");
    断言为真(是可打印字符('~'), "'~' 应该是可打印字符");
    断言为假(是可打印字符('\n'), "'\\n' 不应该是可打印字符");
    断言为假(是可打印字符('\t'), "'\\t' 不应该是可打印字符");

    // -------------------------------------------------------------------------
    // 测试10：前缀判断函数
    // -------------------------------------------------------------------------
    断言为真(是十六进制前缀('0', 'x'), "'0x' 应该是十六进制前缀");
    断言为真(是十六进制前缀('0', 'X'), "'0X' 应该是十六进制前缀");
    断言为假(是十六进制前缀('0', 'b'), "'0b' 不应该是十六进制前缀");

    断言为真(是二进制前缀('0', 'b'), "'0b' 应该是二进制前缀");
    断言为真(是二进制前缀('0', 'B'), "'0B' 应该是二进制前缀");
    断言为假(是二进制前缀('0', 'x'), "'0x' 不应该是二进制前缀");

    断言为真(是八进制前缀('0', 'o'), "'0o' 应该是八进制前缀");
    断言为真(是八进制前缀('0', 'O'), "'0O' 应该是八进制前缀");
    断言为假(是八进制前缀('0', 'x'), "'0x' 不应该是八进制前缀");

    // -------------------------------------------------------------------------
    // 测试11：注释开始判断
    // -------------------------------------------------------------------------
    断言为真(是单行注释开始('/', '/'), "'//' 应该是单行注释开始");
    断言为假(是单行注释开始('/', '*'), "'/*' 不应该是单行注释开始");

    断言为真(是块注释开始('/', '*'), "'/*' 应该是块注释开始");
    断言为假(是块注释开始('/', '/'), "'//' 不应该是块注释开始");
}

// =============================================================================
// 第五部分：扫描器测试
// =============================================================================

/// 测试扫描器核心功能
函数 测试扫描器() -> 空类型 {
    打印行("");
    打印行("[4] 扫描器测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：创建和销毁扫描器
    // -------------------------------------------------------------------------
    字符串 空源码 = "";
    扫描器* 空扫描器 = 创建扫描器(空源码, 0);
    断言不为空(空扫描器, "创建扫描器(空源码)应返回非空指针");
    销毁扫描器(空扫描器);
    通过计数 = 通过计数 + 1;
    打印行("✓ 销毁扫描器成功");

    // 测试空指针参数
    扫描器* 无效扫描器 = 创建扫描器(无, 0);
    断言为空(无效扫描器, "创建扫描器(无)应返回空指针");

    // -------------------------------------------------------------------------
    // 测试2：扫描标识符
    // -------------------------------------------------------------------------
    字符串 标识符源码 = "变量名";
    扫描器* 标识符扫描器 = 创建扫描器(标识符源码, 获取字符串长度(标识符源码));
    断言不为空(标识符扫描器, "创建标识符扫描器应成功");

    变量 词元 标识符词元 = 下一个词元(标识符扫描器);
    断言相等整数(标识符 作为 整数, 标识符词元.类型 作为 整数, "扫描'变量名'应返回标识符类型");
    断言字符串相等("变量名", 标识符词元.值, "标识符值应为'变量名'");
    断言相等整数(1, 标识符词元.行号, "标识符行号应为1");
    断言相等整数(1, 标识符词元.列号, "标识符列号应为1");

    销毁扫描器(标识符扫描器);

    // -------------------------------------------------------------------------
    // 测试3：扫描关键字
    // -------------------------------------------------------------------------
    字符串 关键字源码 = "函数";
    扫描器* 关键字扫描器 = 创建扫描器(关键字源码, 获取字符串长度(关键字源码));
    断言不为空(关键字扫描器, "创建关键字扫描器应成功");

    变量 词元 关键字词元 = 下一个词元(关键字扫描器);
    断言相等整数(关键字_函数 作为 整数, 关键字词元.类型 作为 整数, "扫描'函数'应返回关键字_函数类型");
    断言字符串相等("函数", 关键字词元.值, "关键字值应为'函数'");

    销毁扫描器(关键字扫描器);

    // -------------------------------------------------------------------------
    // 测试4：扫描整数字面量
    // -------------------------------------------------------------------------
    字符串 整数源码 = "12345";
    扫描器* 整数扫描器 = 创建扫描器(整数源码, 获取字符串长度(整数源码));
    断言不为空(整数扫描器, "创建整数扫描器应成功");

    变量 词元 整数词元 = 下一个词元(整数扫描器);
    断言相等整数(整数字面量 作为 整数, 整数词元.类型 作为 整数, "扫描'12345'应返回整数字面量类型");
    断言字符串相等("12345", 整数词元.值, "整数值应为'12345'");

    销毁扫描器(整数扫描器);

    // -------------------------------------------------------------------------
    // 测试5：扫描十六进制字面量
    // -------------------------------------------------------------------------
    字符串 十六进制源码 = "0xFF";
    扫描器* 十六进制扫描器 = 创建扫描器(十六进制源码, 获取字符串长度(十六进制源码));
    断言不为空(十六进制扫描器, "创建十六进制扫描器应成功");

    变量 词元 十六进制词元 = 下一个词元(十六进制扫描器);
    断言相等整数(整数字面量 作为 整数, 十六进制词元.类型 作为 整数, "扫描'0xFF'应返回整数字面量类型");
    断言字符串相等("0xFF", 十六进制词元.值, "十六进制值应为'0xFF'");

    销毁扫描器(十六进制扫描器);

    // -------------------------------------------------------------------------
    // 测试6：扫描二进制字面量
    // -------------------------------------------------------------------------
    字符串 二进制源码 = "0b1010";
    扫描器* 二进制扫描器 = 创建扫描器(二进制源码, 获取字符串长度(二进制源码));
    断言不为空(二进制扫描器, "创建二进制扫描器应成功");

    变量 词元 二进制词元 = 下一个词元(二进制扫描器);
    断言相等整数(整数字面量 作为 整数, 二进制词元.类型 作为 整数, "扫描'0b1010'应返回整数字面量类型");
    断言字符串相等("0b1010", 二进制词元.值, "二进制值应为'0b1010'");

    销毁扫描器(二进制扫描器);

    // -------------------------------------------------------------------------
    // 测试7：扫描浮点数字面量
    // -------------------------------------------------------------------------
    字符串 浮点源码 = "3.14";
    扫描器* 浮点扫描器 = 创建扫描器(浮点源码, 获取字符串长度(浮点源码));
    断言不为空(浮点扫描器, "创建浮点数扫描器应成功");

    变量 词元 浮点词元 = 下一个词元(浮点扫描器);
    断言相等整数(浮点字面量 作为 整数, 浮点词元.类型 作为 整数, "扫描'3.14'应返回浮点字面量类型");
    断言字符串相等("3.14", 浮点词元.值, "浮点数值应为'3.14'");

    销毁扫描器(浮点扫描器);

    // -------------------------------------------------------------------------
    // 测试8：扫描字符串字面量
    // -------------------------------------------------------------------------
    字符串 字符串源码 = "\"你好世界\"";
    扫描器* 字符串扫描器 = 创建扫描器(字符串源码, 获取字符串长度(字符串源码));
    断言不为空(字符串扫描器, "创建字符串扫描器应成功");

    变量 词元 字符串词元 = 下一个词元(字符串扫描器);
    断言相等整数(字符串字面量 作为 整数, 字符串词元.类型 作为 整数, "扫描'\"你好世界\"'应返回字符串字面量类型");
    断言字符串相等("你好世界", 字符串词元.值, "字符串值应为'你好世界'");

    销毁扫描器(字符串扫描器);

    // -------------------------------------------------------------------------
    // 测试9：扫描字符字面量
    // -------------------------------------------------------------------------
    字符串 字符源码 = "'a'";
    扫描器* 字符扫描器 = 创建扫描器(字符源码, 获取字符串长度(字符源码));
    断言不为空(字符扫描器, "创建字符扫描器应成功");

    变量 词元 字符词元 = 下一个词元(字符扫描器);
    断言相等整数(字符字面量 作为 整数, 字符词元.类型 作为 整数, "扫描''a''应返回字符字面量类型");
    断言字符串相等("a", 字符词元.值, "字符值应为'a'");

    销毁扫描器(字符扫描器);

    // -------------------------------------------------------------------------
    // 测试10：扫描运算符
    // -------------------------------------------------------------------------
    字符串 运算符源码 = "+ - * / % == != < <= > >=";
    扫描器* 运算符扫描器 = 创建扫描器(运算符源码, 获取字符串长度(运算符源码));
    断言不为空(运算符扫描器, "创建运算符扫描器应成功");

    // 扫描加号
    变量 词元 加号词元 = 下一个词元(运算符扫描器);
    断言相等整数(加号 作为 整数, 加号词元.类型 作为 整数, "扫描'+'应返回加号类型");

    // 扫描减号
    变量 词元 减号词元 = 下一个词元(运算符扫描器);
    断言相等整数(减号 作为 整数, 减号词元.类型 作为 整数, "扫描'-'应返回减号类型");

    // 扫描星号
    变量 词元 星号词元 = 下一个词元(运算符扫描器);
    断言相等整数(星号 作为 整数, 星号词元.类型 作为 整数, "扫描'*'应返回星号类型");

    // 扫描斜杠
    变量 词元 斜杠词元 = 下一个词元(运算符扫描器);
    断言相等整数(斜杠 作为 整数, 斜杠词元.类型 作为 整数, "扫描'/'应返回斜杠类型");

    // 扫描百分号
    变量 词元 百分号词元 = 下一个词元(运算符扫描器);
    断言相等整数(百分号 作为 整数, 百分号词元.类型 作为 整数, "扫描'%'应返回百分号类型");

    // 扫描等于
    变量 词元 等于词元 = 下一个词元(运算符扫描器);
    断言相等整数(等于 作为 整数, 等于词元.类型 作为 整数, "扫描'=='应返回等于类型");

    // 扫描不等于
    变量 词元 不等于词元 = 下一个词元(运算符扫描器);
    断言相等整数(不等于 作为 整数, 不等于词元.类型 作为 整数, "扫描'!='应返回不等于类型");

    销毁扫描器(运算符扫描器);

    // -------------------------------------------------------------------------
    // 测试11：扫描分隔符
    // -------------------------------------------------------------------------
    字符串 分隔符源码 = "( ) { } [ ] ; , . : ?";
    扫描器* 分隔符扫描器 = 创建扫描器(分隔符源码, 获取字符串长度(分隔符源码));
    断言不为空(分隔符扫描器, "创建分隔符扫描器应成功");

    // 扫描左括号
    变量 词元 左括号词元 = 下一个词元(分隔符扫描器);
    断言相等整数(左括号 作为 整数, 左括号词元.类型 作为 整数, "扫描'('应返回左括号类型");

    // 扫描右括号
    变量 词元 右括号词元 = 下一个词元(分隔符扫描器);
    断言相等整数(右括号 作为 整数, 右括号词元.类型 作为 整数, "扫描')'应返回右括号类型");

    // 扫描左大括号
    变量 词元 左大括号词元 = 下一个词元(分隔符扫描器);
    断言相等整数(左大括号 作为 整数, 左大括号词元.类型 作为 整数, "扫描'{'应返回左大括号类型");

    // 扫描右大括号
    变量 词元 右大括号词元 = 下一个词元(分隔符扫描器);
    断言相等整数(右大括号 作为 整数, 右大括号词元.类型 作为 整数, "扫描'}'应返回右大括号类型");

    销毁扫描器(分隔符扫描器);

    // -------------------------------------------------------------------------
    // 测试12：扫描结束标记
    // -------------------------------------------------------------------------
    字符串 结束源码 = "";
    扫描器* 结束扫描器 = 创建扫描器(结束源码, 0);
    断言不为空(结束扫描器, "创建结束扫描器应成功");

    变量 词元 结束词元 = 下一个词元(结束扫描器);
    断言相等整数(结束 作为 整数, 结束词元.类型 作为 整数, "扫描空源码应返回结束类型");

    销毁扫描器(结束扫描器);

    // -------------------------------------------------------------------------
    // 测试13：跳过空白字符
    // -------------------------------------------------------------------------
    字符串 空白源码 = "   \t\n  变量";
    扫描器* 空白扫描器 = 创建扫描器(空白源码, 获取字符串长度(空白源码));
    断言不为空(空白扫描器, "创建空白扫描器应成功");

    变量 词元 空白后词元 = 下一个词元(空白扫描器);
    断言相等整数(标识符 作为 整数, 空白后词元.类型 作为 整数, "跳过空白后应返回标识符类型");
    断言字符串相等("变量", 空白后词元.值, "空白后值应为'变量'");
    断言相等整数(2, 空白后词元.行号, "空白后行号应为2");

    销毁扫描器(空白扫描器);

    // -------------------------------------------------------------------------
    // 测试14：跳过单行注释
    // -------------------------------------------------------------------------
    字符串 注释源码 = "// 这是注释\n变量";
    扫描器* 注释扫描器 = 创建扫描器(注释源码, 获取字符串长度(注释源码));
    断言不为空(注释扫描器, "创建注释扫描器应成功");

    变量 词元 注释后词元 = 下一个词元(注释扫描器);
    断言相等整数(标识符 作为 整数, 注释后词元.类型 作为 整数, "跳过注释后应返回标识符类型");
    断言字符串相等("变量", 注释后词元.值, "注释后值应为'变量'");

    销毁扫描器(注释扫描器);

    // -------------------------------------------------------------------------
    // 测试15：预览词元
    // -------------------------------------------------------------------------
    字符串 预览源码 = "函数";
    扫描器* 预览扫描器 = 创建扫描器(预览源码, 获取字符串长度(预览源码));
    断言不为空(预览扫描器, "创建预览扫描器应成功");

    // 预览词元不应改变扫描器状态
    变量 词元 预览词元1 = 预览词元(预览扫描器);
    变量 词元 预览词元2 = 预览词元(预览扫描器);
    断言相等整数(预览词元1.类型 作为 整数, 预览词元2.类型 作为 整数, "两次预览应返回相同类型");
    断言字符串相等(预览词元1.值, 预览词元2.值, "两次预览应返回相同值");

    // 下一个词元应返回预览的词元
    变量 词元 实际词元 = 下一个词元(预览扫描器);
    断言相等整数(预览词元1.类型 作为 整数, 实际词元.类型 作为 整数, "下一个词元应与预览词元类型相同");

    销毁扫描器(预览扫描器);
}

// =============================================================================
// 第六部分：错误恢复测试
// =============================================================================

/// 测试错误恢复机制
函数 测试错误恢复() -> 空类型 {
    打印行("");
    打印行("[5] 错误恢复测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：初始化错误恢复上下文
    // -------------------------------------------------------------------------
    变量 错误恢复上下文 上下文;
    初始化错误恢复(&上下文);
    断言相等整数(0, 上下文.连续错误计数, "初始化后连续错误计数应为0");
    断言相等整数(默认最大连续错误, 上下文.最大连续错误, "初始化后最大连续错误应为默认值");
    断言为假(上下文.抑制级联错误 作为 整数, "初始化后不应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试2：同步点判断
    // -------------------------------------------------------------------------
    断言为真(是否同步点(分号), "分号应该是同步点");
    断言为真(是否同步点(右大括号), "右大括号应该是同步点");
    断言为真(是否同步点(右括号), "右括号应该是同步点");
    断言为假(是否同步点(标识符), "标识符不应该是同步点");
    断言为假(是否同步点(加号), "加号不应该是同步点");

    // -------------------------------------------------------------------------
    // 测试3：恢复策略选择
    // -------------------------------------------------------------------------
    断言相等整数(跳过字符 作为 整数, 选择恢复策略(无, 非法字符) 作为 整数, "非法字符应选择跳过字符策略");
    断言相等整数(跳过到行尾 作为 整数, 选择恢复策略(无, 未闭合字符串) 作为 整数, "未闭合字符串应选择跳过到行尾策略");
    断言相等整数(跳过到同步点 作为 整数, 选择恢复策略(无, 未闭合块注释) 作为 整数, "未闭合块注释应选择跳过到同步点策略");

    // -------------------------------------------------------------------------
    // 测试4：级联错误抑制
    // -------------------------------------------------------------------------
    变量 错误恢复上下文 抑制上下文;
    初始化错误恢复(&抑制上下文);

    // 第一次错误不应抑制
    断言为假(应该抑制错误(&抑制上下文), "第一次错误不应被抑制");

    // 增加错误计数
    抑制上下文.连续错误计数 = 级联错误阈值;
    断言为真(应该抑制错误(&抑制上下文), "达到阈值后应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试5：重置错误计数
    // -------------------------------------------------------------------------
    变量 错误恢复上下文 重置上下文;
    初始化错误恢复(&重置上下文);
    重置上下文.连续错误计数 = 5;
    重置上下文.抑制级联错误 = 真;

    重置错误计数(&重置上下文);
    断言相等整数(0, 重置上下文.连续错误计数, "重置后连续错误计数应为0");
    断言为假(重置上下文.抑制级联错误 作为 整数, "重置后不应抑制级联错误");

    // -------------------------------------------------------------------------
    // 测试6：词法错误类型名称
    // -------------------------------------------------------------------------
    断言字符串相等("非法字符", 词法错误类型名称(非法字符), "词法错误类型名称(非法字符)应正确");
    断言字符串相等("未闭合字符串", 词法错误类型名称(未闭合字符串), "词法错误类型名称(未闭合字符串)应正确");
    断言字符串相等("未闭合块注释", 词法错误类型名称(未闭合块注释), "词法错误类型名称(未闭合块注释)应正确");
    断言字符串相等("数字格式错误", 词法错误类型名称(数字格式错误), "词法错误类型名称(数字格式错误)应正确");

    // -------------------------------------------------------------------------
    // 测试7：恢复策略名称
    // -------------------------------------------------------------------------
    断言字符串相等("无恢复", 恢复策略名称(无恢复), "恢复策略名称(无恢复)应正确");
    断言字符串相等("跳过字符", 恢复策略名称(跳过字符), "恢复策略名称(跳过字符)应正确");
    断言字符串相等("跳过到行尾", 恢复策略名称(跳过到行尾), "恢复策略名称(跳过到行尾)应正确");
    断言字符串相等("跳过到同步点", 恢复策略名称(跳过到同步点), "恢复策略名称(跳过到同步点)应正确");

    // -------------------------------------------------------------------------
    // 测试8：扫描非法字符
    // -------------------------------------------------------------------------
    字符串 非法源码 = "@#$";
    扫描器* 非法扫描器 = 创建扫描器(非法源码, 获取字符串长度(非法源码));
    断言不为空(非法扫描器, "创建非法字符扫描器应成功");

    变量 词元 非法词元 = 下一个词元(非法扫描器);
    断言相等整数(错误 作为 整数, 非法词元.类型 作为 整数, "扫描非法字符应返回错误类型");

    销毁扫描器(非法扫描器);

    // -------------------------------------------------------------------------
    // 测试9：扫描未闭合字符串
    // -------------------------------------------------------------------------
    字符串 未闭合字符串源码 = "\"未闭合";
    扫描器* 未闭合扫描器 = 创建扫描器(未闭合字符串源码, 获取字符串长度(未闭合字符串源码));
    断言不为空(未闭合扫描器, "创建未闭合字符串扫描器应成功");

    变量 词元 未闭合词元 = 下一个词元(未闭合扫描器);
    断言相等整数(错误 作为 整数, 未闭合词元.类型 作为 整数, "扫描未闭合字符串应返回错误类型");

    销毁扫描器(未闭合扫描器);
}

// =============================================================================
// 第七部分：综合测试
// =============================================================================

/// 测试复杂源码的扫描
函数 测试综合扫描() -> 空类型 {
    打印行("");
    打印行("[6] 综合扫描测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：函数声明扫描
    // -------------------------------------------------------------------------
    字符串 函数源码 = "函数 加法(整数 a, 整数 b) -> 整数 { 返回 a + b }";
    扫描器* 函数扫描器 = 创建扫描器(函数源码, 获取字符串长度(函数源码));
    断言不为空(函数扫描器, "创建函数扫描器应成功");

    // 扫描关键字 函数
    变量 词元 词元1 = 下一个词元(函数扫描器);
    断言相等整数(关键字_函数 作为 整数, 词元1.类型 作为 整数, "第1个词元应为关键字_函数");

    // 扫描标识符 加法
    变量 词元 词元2 = 下一个词元(函数扫描器);
    断言相等整数(标识符 作为 整数, 词元2.类型 作为 整数, "第2个词元应为标识符");
    断言字符串相等("加法", 词元2.值, "第2个词元值应为'加法'");

    // 扫描左括号
    变量 词元 词元3 = 下一个词元(函数扫描器);
    断言相等整数(左括号 作为 整数, 词元3.类型 作为 整数, "第3个词元应为左括号");

    // 扫描关键字 整数
    变量 词元 词元4 = 下一个词元(函数扫描器);
    断言相等整数(关键字_整数 作为 整数, 词元4.类型 作为 整数, "第4个词元应为关键字_整数");

    销毁扫描器(函数扫描器);

    // -------------------------------------------------------------------------
    // 测试2：表达式扫描
    // -------------------------------------------------------------------------
    字符串 表达式源码 = "结果 = (a + b) * 2";
    扫描器* 表达式扫描器 = 创建扫描器(表达式源码, 获取字符串长度(表达式源码));
    断言不为空(表达式扫描器, "创建表达式扫描器应成功");

    // 扫描标识符 结果
    变量 词元 表达式词元1 = 下一个词元(表达式扫描器);
    断言相等整数(标识符 作为 整数, 表达式词元1.类型 作为 整数, "表达式第1个词元应为标识符");
    断言字符串相等("结果", 表达式词元1.值, "表达式第1个词元值应为'结果'");

    // 扫描赋值
    变量 词元 表达式词元2 = 下一个词元(表达式扫描器);
    断言相等整数(赋值 作为 整数, 表达式词元2.类型 作为 整数, "表达式第2个词元应为赋值");

    销毁扫描器(表达式扫描器);

    // -------------------------------------------------------------------------
    // 测试3：带注释的代码扫描
    // -------------------------------------------------------------------------
    字符串 注释代码源码 = "// 计算两数之和\n变量 结果 = a + b  // 加法运算";
    扫描器* 注释代码扫描器 = 创建扫描器(注释代码源码, 获取字符串长度(注释代码源码));
    断言不为空(注释代码扫描器, "创建注释代码扫描器应成功");

    // 跳过注释后应扫描到关键字 变量
    变量 词元 注释代码词元 = 下一个词元(注释代码扫描器);
    断言相等整数(关键字_变量 作为 整数, 注释代码词元.类型 作为 整数, "跳过注释后应为关键字_变量");
    断言相等整数(2, 注释代码词元.行号, "注释代码词元行号应为2");

    销毁扫描器(注释代码扫描器);
}

// =============================================================================
// 第八部分：主测试函数
// =============================================================================

/// 运行所有测试
/// 返回：测试失败数（0表示全部通过）
函数 运行所有测试() -> 整数 {
    打印行("========================================");
    打印行("CN语言词法分析器单元测试");
    打印行("========================================");
    打印行("");

    // 运行各模块测试
    测试词元类型();
    测试关键字表();
    测试字符工具();
    测试扫描器();
    测试错误恢复();
    测试综合扫描();

    // 输出测试结果
    打印行("");
    打印行("========================================");
    打印行("测试结果统计");
    打印行("========================================");
    打印行("通过: " + 整数转字符串(通过计数));
    打印行("失败: " + 整数转字符串(失败计数));

    变量 整数 总数 = 通过计数 + 失败计数;
    变量 整数 通过率 = (通过计数 * 100) / 总数;
    打印行("通过率: " + 整数转字符串(通过率) + "%");
    打印行("========================================");

    返回 失败计数;
}

/// 程序入口
函数 主函数() -> 整数 {
    变量 整数 失败数 = 运行所有测试();

    如果 (失败数 > 0) {
        返回 1;
    }
    返回 0;
}
