// 测试更多函数调用返回值场景
// 验证编译器正确处理各种情况

// 返回整数的函数
函数 获取值() -> 整数 {
    返回 42;
}

// 返回布尔值的函数
函数 是偶数(整数 n) -> 布尔 {
    返回 n % 2 == 0;
}

// 无返回值的函数
函数 打印消息(整数 消息) {
    打印整数(消息);
}

// 主函数
函数 主函数() -> 整数 {
    // 测试1：函数调用作为if条件
    如果 (是偶数(10)) {
        打印整数(1);  // 应该打印1
    }
    
    // 测试2：函数调用作为while条件
    整数 计数 = 0;
    当 (计数 < 获取值()) {
        计数 = 计数 + 10;
    }
    打印整数(计数);  // 应该打印50
    
    // 测试3：函数调用在表达式中
    整数 结果 = 获取值() + 8;
    打印整数(结果);  // 应该打印50
    
    // 测试4：嵌套函数调用
    如果 (是偶数(获取值())) {
        打印整数(1);  // 42是偶数，应该打印1
    }
    
    返回 0;
}
