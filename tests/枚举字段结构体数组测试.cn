// 测试枚举类型字段的结构体数组

枚举 测试枚举 {
    值一,
    值二,
    值三
};

结构体 测试结构 {
    字符* 名称;
    测试枚举 类型;
};

测试结构 测试数组[3];
布尔 已初始化 = 假;

函数 初始化() -> 空类型 {
    如果 (已初始化) { 返回; }
    测试数组[0].名称 = "测试1";
    测试数组[0].类型 = 值一;
    测试数组[1].名称 = "测试2";
    测试数组[1].类型 = 值二;
    测试数组[2].名称 = "测试3";
    测试数组[2].类型 = 值三;
    已初始化 = 真;
}

函数 主程序() -> 整数 {
    初始化();
    返回 0;
}
