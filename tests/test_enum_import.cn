// 测试枚举导入 - 验证模块导入后枚举类型和成员访问
// 测试目标：
// 1. 验证同名不同类型的符号可以共存（词元结构体 vs 词元类型枚举）
// 2. 验证枚举类型在模块导入后类型信息正确
// 3. 验证枚举成员访问正常工作

// 导入测试模块（不带.cn扩展名）
从 ./test_enum_module 导入 { 词元类型枚举, 词元, 二元运算符, 创建词元, 获取类型名称 };

函数 主程序() -> 整数 {
    // 测试1：同名不同类型符号共存
    // 词元 是结构体，词元类型枚举 是枚举，两者应该可以共存
    
    // 测试2：枚举类型导入后类型信息正确
    词元类型枚举 类型 = 词元类型枚举.标识符;
    
    // 测试3：枚举成员访问
    如果 (类型 == 词元类型枚举.标识符) {
        // 正确识别枚举成员
    } 否则 {
        返回 1;  // 失败：枚举成员访问失败
    }
    
    // 测试4：使用导入的结构体（包含枚举字段）
    词元 词元实例;
    词元实例.类型 = 词元类型枚举.关键字;
    词元实例.内容 = "函数";
    词元实例.行号 = 1;
    词元实例.列号 = 1;
    
    // 测试5：验证结构体中枚举字段的比较
    如果 (词元实例.类型 == 词元类型枚举.关键字) {
        // 正确：枚举字段比较成功
    } 否则 {
        返回 2;  // 失败：枚举字段比较失败
    }
    
    // 测试6：使用导入的函数
    词元 另一个词元 = 创建词元(词元类型枚举.整数字面量, "123", 2, 5);
    
    如果 (另一个词元.类型 != 词元类型枚举.整数字面量) {
        返回 3;  // 失败：函数返回值中枚举类型不正确
    }
    
    // 测试7：switch语句中使用枚举
    字符串 类型名称 = 获取类型名称(另一个词元.类型);
    
    // 测试8：另一个枚举类型
    二元运算符 运算符 = 二元运算符.加法;
    
    选择 (运算符) {
        情况 二元运算符.加法:
            // 正确：识别加法运算符
            中断;
        情况 二元运算符.减法:
            返回 4;  // 不应该到达这里
        默认:
            返回 5;  // 不应该到达这里
    }
    
    // 测试9：枚举值赋值
    词元类型枚举 类型数组[3];
    类型数组[0] = 词元类型枚举.标识符;
    类型数组[1] = 词元类型枚举.整数字面量;
    类型数组[2] = 词元类型枚举.字符串字面量;
    
    // 验证数组中的枚举值
    如果 (类型数组[0] != 词元类型枚举.标识符) {
        返回 6;
    }
    如果 (类型数组[1] != 词元类型枚举.整数字面量) {
        返回 7;
    }
    如果 (类型数组[2] != 词元类型枚举.字符串字面量) {
        返回 8;
    }
    
    // 所有测试通过
    返回 0;
}
