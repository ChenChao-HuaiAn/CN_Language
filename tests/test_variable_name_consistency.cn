// =============================================================================
// 测试变量名一致性
// =============================================================================
// 问题：变量声明为 cn_var_模块_0，但使用时错误地使用了 cn_var_模块
// =============================================================================

// 定义结构体
结构体 目标信息 {
    整数 平台;
};

结构体 模块 {
    目标信息 目标信息;
};

// 测试函数
函数 测试变量名一致性() -> 整数 {
    模块 模块;  // 变量名应该生成 cn_var_模块_0
    模块.目标信息.平台 = 1;  // 使用时应该使用 cn_var_模块_0
    返回 模块.目标信息.平台;
}

// 主函数
函数 主函数() -> 整数 {
    整数 结果 = 测试变量名一致性();
    返回 结果;
}
