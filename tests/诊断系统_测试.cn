// ============================================================================
// 诊断系统单元测试
// ============================================================================
// 功能：测试诊断系统各模块的功能
// 作者：CN语言自托管编译器项目
// ============================================================================

// 导入诊断系统各模块
导入 诊断.诊断核心;
导入 诊断.诊断消息表;
导入 诊断.诊断恢复;
导入 诊断.诊断修复;

// ============================================================================
// 第一部分：测试计数器和辅助函数
// ============================================================================

/// 全局测试计数器
整数 通过计数 = 0;
整数 失败计数 = 0;

/// 断言相等（整数）
/// @param 期望 期望值
/// @param 实际 实际值
/// @param 消息 测试描述
函数 断言相等整数(整数 期望, 整数 实际, 常量字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

/// 断言为真
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为真(布尔 条件, 常量字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印("✗ " + 消息);
    }
}

/// 断言为假
/// @param 条件 条件表达式
/// @param 消息 测试描述
函数 断言为假(布尔 条件, 常量字符串 消息) -> 空类型 {
    断言为真(条件 == 假, 消息);
}

/// 断言不为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言不为空(空类型* 指针, 常量字符串 消息) -> 空类型 {
    断言为真(指针 != 无, 消息);
}

/// 断言为空
/// @param 指针 指针值
/// @param 消息 测试描述
函数 断言为空(空类型* 指针, 常量字符串 消息) -> 空类型 {
    断言为真(指针 == 无, 消息);
}

/// 断言字符串相等
/// @param 期望 期望字符串
/// @param 实际 实际字符串
/// @param 消息 测试描述
函数 断言字符串相等(常量字符串 期望, 常量字符串 实际, 常量字符串 消息) -> 空类型 {
    如果 (字符串比较(期望, 实际) == 0) {
        通过计数 = 通过计数 + 1;
        打印("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印("✗ " + 消息 + " (期望: '" + 期望 + "', 实际: '" + 实际 + "')");
    }
}

// ============================================================================
// 第二部分：诊断核心模块测试
// ============================================================================

/// 测试诊断核心模块
函数 测试诊断核心() -> 空类型 {
    打印("");
    打印("[1] 诊断核心模块测试");
    打印("----------------------------------------");

    // 测试1：创建诊断集合
    诊断集合* 集合 = 创建诊断集合(4);
    断言不为空(集合, "创建诊断集合成功");

    // 测试2：初始计数为零
    断言相等整数(0, 获取错误计数(集合), "初始错误计数为零");
    断言相等整数(0, 获取警告计数(集合), "初始警告计数为零");
    断言相等整数(0, 集合.长度, "初始诊断总数为零");

    // 测试3：报告错误
    源位置 位置1 = 创建源位置("测试.cn", 10, 5);
    报告错误(集合, 诊断错误码.语义_未定义标识符, 位置1, "未定义的标识符: x");
    断言相等整数(1, 获取错误计数(集合), "报告错误后错误计数为1");
    断言相等整数(1, 集合.长度, "报告错误后诊断总数为1");

    // 测试4：报告警告
    源位置 位置2 = 创建源位置("测试.cn", 20, 10);
    报告警告(集合, 诊断错误码.语义_类型不匹配, 位置2, "类型不匹配");
    断言相等整数(1, 获取警告计数(集合), "报告警告后警告计数为1");
    断言相等整数(2, 集合.长度, "报告警告后诊断总数为2");

    // 测试5：应该继续编译
    断言为真(应该继续(集合), "错误数未达上限，应该继续编译");

    // 测试6：设置最大错误限制
    集合.最大错误数 = 2;
    报告错误(集合, 诊断错误码.语义_重复符号, 位置1, "重复定义");
    断言为假(应该继续(集合), "错误数达上限，不应继续编译");

    // 测试7：清空诊断集合
    清空诊断集合(集合);
    断言相等整数(0, 获取错误计数(集合), "清空后错误计数为零");
    断言相等整数(0, 获取警告计数(集合), "清空后警告计数为零");
    断言相等整数(0, 集合.长度, "清空后诊断总数为零");

    // 测试8：释放诊断集合
    释放诊断集合(集合);
    打印("✓ 释放诊断集合成功");
}

// ============================================================================
// 第三部分：消息表模块测试
// ============================================================================

/// 测试消息表模块
函数 测试消息表() -> 空类型 {
    打印("");
    打印("[2] 消息表模块测试");
    打印("----------------------------------------");

    // 测试1：默认语言为中文
    诊断语言 当前语言 = 获取诊断语言();
    断言相等整数(诊断语言.中文, 当前语言, "默认语言为中文");

    // 测试2：设置语言为英文
    设置诊断语言(诊断语言.英文);
    断言相等整数(诊断语言.英文, 获取诊断语言(), "设置语言为英文成功");

    // 测试3：设置回中文
    设置诊断语言(诊断语言.中文);
    断言相等整数(诊断语言.中文, 获取诊断语言(), "设置语言为中文成功");

    // 测试4：查找消息模板
    消息模板* 模板 = 获取消息模板(诊断错误码.词法_未终止字符串);
    断言不为空(模板, "查找词法错误消息模板成功");

    // 测试5：验证中文消息
    断言字符串相等("未终止的字符串字面量", 模板.中文消息, "词法错误中文消息正确");

    // 测试6：验证英文消息
    断言字符串相等("Unterminated string literal", 模板.英文消息, "词法错误英文消息正确");

    // 测试7：查找语义错误模板
    模板 = 获取消息模板(诊断错误码.语义_未定义标识符);
    断言不为空(模板, "查找语义错误消息模板成功");
    断言字符串相等("未定义的标识符: '{0}'", 模板.中文消息, "语义错误中文消息正确");

    // 测试8：查找不存在的错误码
    模板 = 获取消息模板(诊断错误码.未知错误);
    断言不为空(模板, "未知错误码返回表结束标记");

    // 测试9：消息格式化（带参数）
    字符 缓冲区[256]
    诊断参数 参数数组[1]
    参数数组[0].类型 = 参数类型.字符串参数;
    参数数组[0].值.字符串值 = "测试标识符";

    诊断参数数组 参数 = { 参数数组, 1 }
    模板 = 获取消息模板(诊断错误码.语义_未定义标识符);
    整数 长度 = 格式化消息(模板, &参数, 诊断语言.中文, 缓冲区, 256);
    断言为真(长度 > 0, "消息格式化成功");
    断言字符串相等("未定义的标识符: '测试标识符'", 缓冲区, "参数化消息正确");

    // 测试10：获取提示信息
    常量字符串 提示 = 获取诊断提示(诊断错误码.词法_未终止字符串, 诊断语言.中文);
    断言为真(提示 != 无 && 字符串长度(提示) > 0, "获取中文提示成功");

    提示 = 获取诊断提示(诊断错误码.词法_未终止字符串, 诊断语言.英文);
    断言为真(提示 != 无 && 字符串长度(提示) > 0, "获取英文提示成功");
}

// ============================================================================
// 第四部分：恢复模块测试
// ============================================================================

/// 测试恢复模块
函数 测试恢复模块() -> 空类型 {
    打印("");
    打印("[3] 恢复模块测试");
    打印("----------------------------------------");

    // 测试1：初始化恢复上下文
    恢复上下文 上下文;
    初始化恢复上下文(&上下文, 100);
    断言相等整数(0, 上下文.错误计数, "初始错误计数为零");
    断言相等整数(100, 上下文.最大错误数, "最大错误数设置正确");
    断言相等整数(0, 上下文.级联抑制计数, "初始级联抑制计数为零");

    // 测试2：获取恢复策略 - 期望标记错误
    恢复策略 策略 = 获取恢复策略(诊断错误码.语法_期望标记);
    断言相等整数(恢复策略.插入, 策略, "期望标记错误返回插入策略");

    // 测试3：获取恢复策略 - 词法错误
    策略 = 获取恢复策略(诊断错误码.词法_无效字符);
    断言相等整数(恢复策略.跳过标记, 策略, "词法错误返回跳过标记策略");

    // 测试4：获取恢复策略 - 语义错误
    策略 = 获取恢复策略(诊断错误码.语义_未定义标识符);
    断言相等整数(恢复策略.同步, 策略, "语义错误返回同步策略");

    // 测试5：记录错误并选择策略
    策略 = 记录错误并选择策略(&上下文, 诊断错误码.语法_期望标记, "测试.cn", 10);
    断言相等整数(1, 上下文.错误计数, "记录错误后计数增加");
    断言相等整数(恢复策略.插入, 策略, "返回正确的恢复策略");

    // 测试6：同步标记检测
    断言为真(是同步标记(';'), "分号是同步标记");
    断言为真(是同步标记('}'), "右花括号是同步标记");
    断言为真(是同步标记(')'), "右圆括号是同步标记");
    断言为假(是同步标记('a'), "普通字符不是同步标记");

    // 测试7：级联错误抑制
    // 同一位置连续报告错误
    整数 索引 = 0;
    当 (索引 < 级联错误阈值) {
        记录错误并选择策略(&上下文, 诊断错误码.语义_类型不匹配, "测试.cn", 20);
        索引 = 索引 + 1;
    }
    断言为真(应该抑制级联(&上下文, "测试.cn", 20), "级联错误应被抑制");

    // 测试8：不同位置不抑制
    断言为假(应该抑制级联(&上下文, "测试.cn", 30), "不同位置不应抑制");
    断言为假(应该抑制级联(&上下文, "其他.cn", 20), "不同文件不应抑制");

    // 测试9：达到最大错误数
    上下文.错误计数 = 99;
    策略 = 记录错误并选择策略(&上下文, 诊断错误码.语法_期望标记, "测试.cn", 50);
    断言相等整数(恢复策略.不恢复, 策略, "达到最大错误数返回不恢复");

    // 测试10：重置恢复上下文
    重置恢复上下文(&上下文);
    断言相等整数(0, 上下文.错误计数, "重置后错误计数为零");
    断言相等整数(0, 上下文.级联抑制计数, "重置后级联抑制计数为零");
}

// ============================================================================
// 第五部分：修复建议模块测试
// ============================================================================

/// 测试修复建议模块
函数 测试修复建议() -> 空类型 {
    打印("");
    打印("[4] 修复建议模块测试");
    打印("----------------------------------------");

    源位置 位置 = 创建源位置("测试.cn", 10, 5);
    修复建议 建议;
    布尔 结果;

    // 测试1：生成缺少分号的修复建议
    结果 = 生成修复建议(诊断错误码.语法_期望标记, 位置, 无, &建议);
    断言为真(结果, "生成缺少分号建议成功");
    断言相等整数(修复类型.插入, 建议.类型, "修复类型为插入");
    断言字符串相等(";", 建议.新文本, "建议插入分号");

    // 测试2：获取修复描述（中文）
    常量字符串 描述 = 获取修复描述(&建议, 诊断语言.中文);
    断言为真(描述 != 无, "获取中文描述成功");

    // 测试3：获取修复描述（英文）
    描述 = 获取修复描述(&建议, 诊断语言.英文);
    断言为真(描述 != 无, "获取英文描述成功");

    // 测试4：生成未定义标识符的修复建议
    诊断参数 参数数组[1]
    参数数组[0].类型 = 参数类型.字符串参数;
    参数数组[0].值.字符串值 = "未知变量";
    诊断参数数组 参数 = { 参数数组, 1 }

    结果 = 生成修复建议(诊断错误码.语义_未定义标识符, 位置, &参数, &建议);
    断言为真(结果, "生成未定义标识符建议成功");
    断言字符串相等("未知变量", 建议.原文本, "原文本正确");

    // 测试5：生成类型不匹配的修复建议
    诊断参数 类型参数[2]
    类型参数[0].类型 = 参数类型.字符串参数;
    类型参数[0].值.字符串值 = "整数";
    类型参数[1].类型 = 参数类型.字符串参数;
    类型参数[1].值.字符串值 = "字符串";
    诊断参数数组 类型参数数组 = { 类型参数, 2 }

    结果 = 生成修复建议(诊断错误码.语义_类型不匹配, 位置, &类型参数数组, &建议);
    断言为真(结果, "生成类型不匹配建议成功");

    // 测试6：生成重复符号的修复建议
    诊断参数 重复参数[2]
    重复参数[0].类型 = 参数类型.字符串参数;
    重复参数[0].值.字符串值 = "重复名";
    重复参数[1].类型 = 参数类型.整数参数;
    重复参数[1].值.整数值 = 5;
    诊断参数数组 重复参数数组 = { 重复参数, 2 }

    结果 = 生成修复建议(诊断错误码.语义_重复符号, 位置, &重复参数数组, &建议);
    断言为真(结果, "生成重复符号建议成功");

    // 测试7：生成缺少返回语句的修复建议
    诊断参数 返回参数[1]
    返回参数[0].类型 = 参数类型.字符串参数;
    返回参数[0].值.字符串值 = "整数";
    诊断参数数组 返回参数数组 = { 返回参数, 1 }

    结果 = 生成修复建议(诊断错误码.语义_缺少返回语句, 位置, &返回参数数组, &建议);
    断言为真(结果, "生成缺少返回语句建议成功");

    // 测试8：生成参数数量不匹配的修复建议
    诊断参数 参数数量[2]
    参数数量[0].类型 = 参数类型.整数参数;
    参数数量[0].值.整数值 = 3;
    参数数量[1].类型 = 参数类型.整数参数;
    参数数量[1].值.整数值 = 2;
    诊断参数数组 参数数量数组 = { 参数数量, 2 }

    结果 = 生成修复建议(诊断错误码.语义_参数数量不匹配, 位置, &参数数量数组, &建议);
    断言为真(结果, "生成参数数量不匹配建议成功");

    // 测试9：生成常量缺少初始化的修复建议
    诊断参数 常量参数[1]
    常量参数[0].类型 = 参数类型.字符串参数;
    常量参数[0].值.字符串值 = "PI";
    诊断参数数组 常量参数数组 = { 常量参数, 1 }

    结果 = 生成修复建议(诊断错误码.语义_常量缺少初始化, 位置, &常量参数数组, &建议);
    断言为真(结果, "生成常量缺少初始化建议成功");

    // 测试10：格式化修复建议
    字符 缓冲区[256]
    整数 长度 = 格式化修复建议(&建议, 诊断语言.中文, 缓冲区, 256);
    断言为真(长度 > 0, "格式化修复建议成功");

    // 测试11：不支持的错误码
    结果 = 生成修复建议(诊断错误码.未知错误, 位置, 无, &建议);
    断言为假(结果, "未知错误码无修复建议");
}

// ============================================================================
// 第六部分：主测试函数
// ============================================================================

/// 运行所有测试
/// @return 失败数量（0表示全部通过）
函数 运行所有测试() -> 整数 {
    打印("========================================");
    打印("诊断系统单元测试");
    打印("========================================");

    // 运行各模块测试
    测试诊断核心();
    测试消息表();
    测试恢复模块();
    测试修复建议();

    // 输出测试结果
    打印("");
    打印("========================================");
    打印("测试结果: " + 整数转字符串(通过计数) + " 通过, " + 整数转字符串(失败计数) + " 失败");
    打印("========================================");

    返回 失败计数;
}

/// 程序入口
函数 主程序() -> 整数 {
    整数 失败数 = 运行所有测试();

    如果 (失败数 > 0) {
        返回 1  // 测试失败;
    }
    返回 0  // 测试通过;
}
