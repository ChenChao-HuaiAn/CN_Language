// =============================================================================
// CN语言语法分析器 - 类型解析测试
// =============================================================================
//
// 本文件测试类型解析功能：
// - 基础类型解析（整数、浮点、字符串、布尔、空类型）
// - 指针类型解析（单级、多级指针）
// - 数组类型解析（一维、多维数组）
// - 函数类型解析
// - 结构体类型解析
// - 枚举类型解析
// - 类类型解析
// - 接口类型解析
//
// =============================================================================

// 导入依赖模块
导入 语法分析器/解析器;
导入 语法分析器/AST节点;
导入 词法分析器/词元;
导入 词法分析器/扫描器;
导入 运行时/运行时;

// =============================================================================
// 测试计数器（静态变量）
// =============================================================================

变量 整数 通过计数 = 0;;
变量 整数 失败计数 = 0;;

/// 断言为真
函数 断言为真类型(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言相等整数
函数 断言相等整数类型(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

// =============================================================================
// 第一部分：基础类型测试
// =============================================================================

/// 测试基础类型
函数 测试基础类型() -> 空类型 {
    打印行("");
    打印行("[类型-1] 基础类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：整数类型
    // -------------------------------------------------------------------------
    变量 类型节点 整数类型;
    整数类型.类型 = 节点类型.基础类型;
    整数类型.名称 = "整数";
    整数类型.指针层级 = 0;
    整数类型.数组维度 = 0;
    整数类型.是常量 = 假;

    断言相等整数类型(节点类型.基础类型 作为 整数, 整数类型.类型 作为 整数, "整数类型节点类型应正确");
    断言相等整数类型(0, 整数类型.指针层级, "基础类型指针层级应为0");
    断言相等整数类型(0, 整数类型.数组维度, "基础类型数组维度应为0");

    // -------------------------------------------------------------------------
    // 测试2：小数类型
    // -------------------------------------------------------------------------
    变量 类型节点 小数类型;
    小数类型.类型 = 节点类型.基础类型;
    小数类型.名称 = "小数";

    断言相等整数类型(节点类型.基础类型 作为 整数, 小数类型.类型 作为 整数, "小数类型节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试3：字符串类型
    // -------------------------------------------------------------------------
    变量 类型节点 字符串类型;
    字符串类型.类型 = 节点类型.基础类型;
    字符串类型.名称 = "字符串";

    断言相等整数类型(节点类型.基础类型 作为 整数, 字符串类型.类型 作为 整数, "字符串类型节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试4：布尔类型
    // -------------------------------------------------------------------------
    变量 类型节点 布尔类型;
    布尔类型.类型 = 节点类型.基础类型;
    布尔类型.名称 = "布尔";

    断言相等整数类型(节点类型.基础类型 作为 整数, 布尔类型.类型 作为 整数, "布尔类型节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试5：空类型
    // -------------------------------------------------------------------------
    变量 类型节点 空类型节点;
    空类型节点.类型 = 节点类型.基础类型;
    空类型节点.名称 = "空类型";

    断言相等整数类型(节点类型.基础类型 作为 整数, 空类型节点.类型 作为 整数, "空类型节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试6：常量类型
    // -------------------------------------------------------------------------
    变量 类型节点 常量整数类型;
    常量整数类型.类型 = 节点类型.基础类型;
    常量整数类型.名称 = "整数";
    常量整数类型.是常量 = 真;

    断言为真类型(常量整数类型.是常量, "常量类型应标记为常量");
}

// =============================================================================
// 第二部分：指针类型测试
// =============================================================================

/// 测试指针类型
函数 测试指针类型() -> 空类型 {
    打印行("");
    打印行("[类型-2] 指针类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：单级指针
    // -------------------------------------------------------------------------
    变量 类型节点 单级指针;
    单级指针.类型 = 节点类型.指针类型;
    单级指针.名称 = "整数*";
    单级指针.指针层级 = 1;

    断言相等整数类型(节点类型.指针类型 作为 整数, 单级指针.类型 作为 整数, "指针类型节点类型应正确");
    断言相等整数类型(1, 单级指针.指针层级, "单级指针层级应为1");

    // -------------------------------------------------------------------------
    // 测试2：多级指针
    // -------------------------------------------------------------------------
    变量 类型节点 二级指针;
    二级指针.类型 = 节点类型.指针类型;
    二级指针.名称 = "整数**";
    二级指针.指针层级 = 2;

    断言相等整数类型(2, 二级指针.指针层级, "二级指针层级应为2");

    // -------------------------------------------------------------------------
    // 测试3：三级指针
    // -------------------------------------------------------------------------
    变量 类型节点 三级指针;
    三级指针.类型 = 节点类型.指针类型;
    三级指针.名称 = "整数***";
    三级指针.指针层级 = 3;

    断言相等整数类型(3, 三级指针.指针层级, "三级指针层级应为3");

    // -------------------------------------------------------------------------
    // 测试4：结构体指针
    // -------------------------------------------------------------------------
    变量 类型节点 结构体指针;
    结构体指针.类型 = 节点类型.指针类型;
    结构体指针.名称 = "点*";
    结构体指针.指针层级 = 1;

    断言相等整数类型(1, 结构体指针.指针层级, "结构体指针层级应为1");
}

// =============================================================================
// 第三部分：数组类型测试
// =============================================================================

/// 测试数组类型
函数 测试数组类型() -> 空类型 {
    打印行("");
    打印行("[类型-3] 数组类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：一维数组
    // -------------------------------------------------------------------------
    变量 类型节点 一维数组;
    一维数组.类型 = 节点类型.数组类型;
    一维数组.名称 = "整数[]";
    一维数组.数组维度 = 1;
    一维数组.数组大小 = 10;

    断言相等整数类型(节点类型.数组类型 作为 整数, 一维数组.类型 作为 整数, "数组类型节点类型应正确");
    断言相等整数类型(1, 一维数组.数组维度, "一维数组维度应为1");
    断言相等整数类型(10, 一维数组.数组大小, "数组大小应为10");

    // -------------------------------------------------------------------------
    // 测试2：二维数组
    // -------------------------------------------------------------------------
    变量 类型节点 二维数组;
    二维数组.类型 = 节点类型.数组类型;
    二维数组.名称 = "整数[][]";
    二维数组.数组维度 = 2;

    断言相等整数类型(2, 二维数组.数组维度, "二维数组维度应为2");

    // -------------------------------------------------------------------------
    // 测试3：三维数组
    // -------------------------------------------------------------------------
    变量 类型节点 三维数组;
    三维数组.类型 = 节点类型.数组类型;
    三维数组.名称 = "整数[][][]";
    三维数组.数组维度 = 3;

    断言相等整数类型(3, 三维数组.数组维度, "三维数组维度应为3");

    // -------------------------------------------------------------------------
    // 测试4：动态数组（无大小）
    // -------------------------------------------------------------------------
    变量 类型节点 动态数组;
    动态数组.类型 = 节点类型.数组类型;
    动态数组.名称 = "整数[]";
    动态数组.数组维度 = 1;
    动态数组.数组大小 = 0;  // 0表示动态数组;

    断言相等整数类型(0, 动态数组.数组大小, "动态数组大小应为0");
}

// =============================================================================
// 第四部分：函数类型测试
// =============================================================================

/// 测试函数类型
函数 测试函数类型() -> 空类型 {
    打印行("");
    打印行("[类型-4] 函数类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：函数类型节点
    // -------------------------------------------------------------------------
    变量 类型节点 函数类型节点;
    函数类型节点.类型 = 节点类型.函数类型;
    函数类型节点.名称 = "函数";

    断言相等整数类型(节点类型.函数类型 作为 整数, 函数类型节点.类型 作为 整数, "函数类型节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：函数指针类型
    // -------------------------------------------------------------------------
    // 函数指针使用 函数类型 节点表示
    断言为真类型(真, "函数指针使用函数类型节点表示");
}

