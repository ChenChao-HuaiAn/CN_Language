函数 测试接口类型() -> 空类型 {
    打印行("");
    打印行("[类型-8] 接口类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：接口类型节点
    // -------------------------------------------------------------------------
    变量 类型节点 接口类型节点;
    接口类型节点.类型 = 节点类型.接口类型;
    接口类型节点.名称 = "可序列化";

    断言相等整数类型(节点类型.接口类型 作为 整数, 接口类型节点.类型 作为 整数, "接口类型节点类型应正确");
}

// =============================================================================
// 第九部分：复合类型测试
// =============================================================================

/// 测试复合类型
函数 测试复合类型() -> 空类型 {
    打印行("");
    打印行("[类型-9] 复合类型测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：指针数组
    // -------------------------------------------------------------------------
    // 整数*[] - 指针数组
    变量 类型节点 指针数组;
    指针数组.类型 = 节点类型.数组类型;
    指针数组.名称 = "整数*[]";
    指针数组.数组维度 = 1;
    // 元素类型是指针
    指针数组.元素类型 = 分配内存(类型节点大小);
    指针数组.元素类型.类型 = 节点类型.指针类型;
    指针数组.元素类型.指针层级 = 1;

    断言为真类型(指针数组.元素类型 != 无, "指针数组元素类型应不为空");

    // -------------------------------------------------------------------------
    // 测试2：数组指针
    // -------------------------------------------------------------------------
    // 整数(*)[10] - 数组指针
    变量 类型节点 数组指针;
    数组指针.类型 = 节点类型.指针类型;
    数组指针.名称 = "整数(*)[10]";
    数组指针.指针层级 = 1;
    // 元素类型是数组
    数组指针.元素类型 = 分配内存(类型节点大小);
    数组指针.元素类型.类型 = 节点类型.数组类型;
    数组指针.元素类型.数组维度 = 1;
    数组指针.元素类型.数组大小 = 10;

    断言为真类型(数组指针.元素类型 != 无, "数组指针元素类型应不为空");
}

// =============================================================================
// 类型测试入口
// =============================================================================

/// 运行所有类型测试
函数 运行类型测试() -> 空类型 {
    测试基础类型();
    测试指针类型();
    测试数组类型();
    测试函数类型();
    测试结构体类型();
    测试枚举类型();
    测试类类型();
    测试接口类型();
    测试复合类型();
}
