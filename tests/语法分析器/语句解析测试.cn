// =============================================================================
// 语句测试入口
// =============================================================================

/// 运行所有语句测试
函数 运行语句测试() -> 空类型 {
    测试表达式语句();
    测试块语句();
    测试如果语句();
    测试当语句();
    测试循环语句();
    测试返回语句();
    测试中断语句();
    测试继续语句();
    测试选择语句();
    测试尝试语句();
    测试抛出语句();
    测试最终语句();
}
