// =============================================================================
// CN语言语法分析器 - 语句解析测试
// =============================================================================
//
// 本文件测试语句解析功能：
// - 表达式语句
// - 块语句
// - 如果语句（含否则如果、否则）
// - 当语句（while循环）
// - 循环语句（for循环）
// - 返回语句
// - 中断语句
// - 继续语句
// - 选择语句（switch-case）
// - 尝试语句（try-catch-finally）
// - 抛出语句
//
// =============================================================================

// 导入依赖模块
导入 语法分析器/解析器;
导入 语法分析器/AST节点;
导入 词法分析器/词元;
导入 词法分析器/扫描器;
导入 运行时/运行时;

// =============================================================================
// 测试计数器（静态变量）
// =============================================================================

变量 整数 通过计数 = 0;;
变量 整数 失败计数 = 0;;

/// 断言为真
函数 断言为真语句(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言相等整数
函数 断言相等整数语句(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

// =============================================================================
// 第一部分：表达式语句测试
// =============================================================================

/// 测试表达式语句
函数 测试表达式语句() -> 空类型 {
    打印行("");
    打印行("[语句-1] 表达式语句测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：表达式语句节点类型
    // -------------------------------------------------------------------------
    断言相等整数语句(节点类型.表达式语句 作为 整数, 节点类型.表达式语句 作为 整数, "表达式语句节点类型应正确");
}

// =============================================================================
// 第二部分：块语句测试
// =============================================================================

/// 测试块语句
函数 测试块语句() -> 空类型 {
    打印行("");
    打印行("[语句-2] 块语句测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：块语句节点类型
    // -------------------------------------------------------------------------
    变量 块语句节点 块节点;
    块节点.基类.类型 = 节点类型.块语句;

    断言相等整数语句(节点类型.块语句 作为 整数, 块节点.基类.类型 作为 整数, "块语句节点类型应正确");
}

// =============================================================================
// 第三部分：如果语句测试
// =============================================================================

/// 测试如果语句
函数 测试如果语句() -> 空类型 {
    打印行("");
    打印行("[语句-3] 如果语句测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：如果语句节点类型
    // -------------------------------------------------------------------------
    变量 如果语句节点 如果节点;
    如果节点.基类.类型 = 节点类型.如果语句;

    断言相等整数语句(节点类型.如果语句 作为 整数, 如果节点.基类.类型 作为 整数, "如果语句节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：如果-否则结构
    // -------------------------------------------------------------------------
    // 如果语句包含条件、真分支、假分支
    // 假分支可以是块语句或另一个如果语句（否则如果）
    断言为真语句(真, "如果语句支持否则如果链");
}

