/// 测试结构体声明
函数 测试结构体声明() -> 空类型 {
    打印行("");
    打印行("[声明-3] 结构体声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：结构体声明节点类型
    // -------------------------------------------------------------------------
    变量 结构体声明节点 结构体节点;
    结构体节点.基类.类型 = 节点类型.结构体声明;
    结构体节点.名称 = "点";

    断言相等整数声明(节点类型.结构体声明 作为 整数, 结构体节点.基类.类型 作为 整数, "结构体声明节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：结构体成员
    // -------------------------------------------------------------------------
    // 结构体包含成员列表
    断言为真声明(真, "结构体包含成员列表");
}

// =============================================================================
// 第四部分：枚举声明测试
// =============================================================================

/// 测试枚举声明
函数 测试枚举声明() -> 空类型 {
    打印行("");
    打印行("[声明-4] 枚举声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：枚举声明节点类型
    // -------------------------------------------------------------------------
    变量 枚举声明节点 枚举节点;
    枚举节点.基类.类型 = 节点类型.枚举声明;
    枚举节点.名称 = "颜色";

    断言相等整数声明(节点类型.枚举声明 作为 整数, 枚举节点.基类.类型 作为 整数, "枚举声明节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：枚举成员
    // -------------------------------------------------------------------------
    变量 枚举成员 成员;
    成员.名称 = "红";
    成员.值 = 0;
    成员.有显式值 = 假;

    断言相等整数声明(0, 成员.值, "枚举成员默认值应为0");
    断言为真声明(成员.有显式值 == 假, "枚举成员默认无显式值");

    // -------------------------------------------------------------------------
    // 测试3：枚举成员显式值
    // -------------------------------------------------------------------------
    变量 枚举成员 显式成员;
    显式成员.名称 = "蓝";
    显式成员.值 = 10;
    显式成员.有显式值 = 真;

    断言相等整数声明(10, 显式成员.值, "枚举成员显式值应为10");
    断言为真声明(显式成员.有显式值, "枚举成员应标记有显式值");
}

// =============================================================================
// 第五部分：类声明测试
// =============================================================================

/// 测试类声明
函数 测试类声明() -> 空类型 {
    打印行("");
    打印行("[声明-5] 类声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：类声明节点类型
    // -------------------------------------------------------------------------
    变量 类声明节点 类节点;
    类节点.基类.类型 = 节点类型.类声明;
    类节点.名称 = "动物";
    类节点.是抽象 = 假;

    断言相等整数声明(节点类型.类声明 作为 整数, 类节点.基类.类型 作为 整数, "类声明节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：抽象类
    // -------------------------------------------------------------------------
    变量 类声明节点 抽象类节点;
    抽象类节点.基类.类型 = 节点类型.类声明;
    抽象类节点.名称 = "形状";
    抽象类节点.是抽象 = 真;

    断言为真声明(抽象类节点.是抽象, "抽象类应标记为抽象");

    // -------------------------------------------------------------------------
    // 测试3：类继承
    // -------------------------------------------------------------------------
    变量 类声明节点 子类节点;
    子类节点.基类.类型 = 节点类型.类声明;
    子类节点.名称 = "狗";
    子类节点.基类名称 = "动物";

    断言为真声明(真, "类支持继承基类");

    // -------------------------------------------------------------------------
    // 测试4：类实现接口
    // -------------------------------------------------------------------------
    变量 类声明节点 实现类节点;
    实现类节点.基类.类型 = 节点类型.类声明;
    实现类节点.名称 = "学生";

    断言为真声明(真, "类支持实现接口");
}

