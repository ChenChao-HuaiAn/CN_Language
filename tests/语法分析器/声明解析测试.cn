}

// =============================================================================
// 第九部分：参数节点测试
// =============================================================================

/// 测试参数节点
函数 测试参数节点() -> 空类型 {
    打印行("");
    打印行("[声明-9] 参数节点测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：参数节点
    // -------------------------------------------------------------------------
    变量 参数节点 参数;
    参数.名称 = "值";
    参数.是数组 = 假;
    参数.数组维度 = 0;

    断言为真声明(真, "参数节点包含名称和类型");

    // -------------------------------------------------------------------------
    // 测试2：数组参数
    // -------------------------------------------------------------------------
    变量 参数节点 数组参数;
    数组参数.名称 = "数组";
    数组参数.是数组 = 真;
    数组参数.数组维度 = 1;

    断言为真声明(数组参数.是数组, "数组参数应标记为数组");
    断言相等整数声明(1, 数组参数.数组维度, "一维数组参数维度应为1");
}

// =============================================================================
// 声明测试入口
// =============================================================================

/// 运行所有声明测试
函数 运行声明测试() -> 空类型 {
    测试函数声明();
    测试变量声明();
    测试结构体声明();
    测试枚举声明();
    测试类声明();
    测试接口声明();
    测试导入声明();
    测试模块声明();
    测试参数节点();
}
