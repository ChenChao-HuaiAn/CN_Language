}

// =============================================================================
// 第七部分：导入声明测试
// =============================================================================

/// 测试导入声明
函数 测试导入声明() -> 空类型 {
    打印行("");
    打印行("[声明-7] 导入声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：导入声明节点类型
    // -------------------------------------------------------------------------
    变量 导入声明节点 导入节点;
    导入节点.基类.类型 = 节点类型.导入声明;
    导入节点.模块名 = "标准库";
    导入节点.导入类型 = 导入类型.全量导入;

    断言相等整数声明(节点类型.导入声明 作为 整数, 导入节点.基类.类型 作为 整数, "导入声明节点类型应正确");
    断言相等整数声明(导入类型.全量导入 作为 整数, 导入节点.导入类型 作为 整数, "导入类型应为全量导入");

    // -------------------------------------------------------------------------
    // 测试2：选择性导入
    // -------------------------------------------------------------------------
    变量 导入声明节点 选择导入节点;
    选择导入节点.基类.类型 = 节点类型.导入声明;
    选择导入节点.模块名 = "数学工具";
    选择导入节点.导入类型 = 导入类型.选择性导入;

    断言相等整数声明(导入类型.选择性导入 作为 整数, 选择导入节点.导入类型 作为 整数, "导入类型应为选择性导入");

    // -------------------------------------------------------------------------
    // 测试3：别名导入
    // -------------------------------------------------------------------------
    变量 导入声明节点 别名导入节点;
    别名导入节点.基类.类型 = 节点类型.导入声明;
    别名导入节点.模块名 = "数学工具";
    别名导入节点.别名 = "数学";
    别名导入节点.导入类型 = 导入类型.别名导入;

    断言相等整数声明(导入类型.别名导入 作为 整数, 别名导入节点.导入类型 作为 整数, "导入类型应为别名导入");
}

