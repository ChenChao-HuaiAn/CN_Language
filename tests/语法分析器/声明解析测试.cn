// =============================================================================
// CN语言语法分析器 - 声明解析测试
// =============================================================================
//
// 本文件测试声明解析功能：
// - 函数声明
// - 变量声明（含常量、静态）
// - 结构体声明
// - 枚举声明
// - 类声明
// - 接口声明
// - 导入声明
// - 模块声明
//
// =============================================================================

// 导入依赖模块
导入 语法分析器/解析器;
导入 语法分析器/AST节点;
导入 词法分析器/词元;
导入 词法分析器/扫描器;
导入 运行时/运行时;

// =============================================================================
// 测试计数器（静态变量）
// =============================================================================

变量 整数 通过计数 = 0;;
变量 整数 失败计数 = 0;;

/// 断言为真
函数 断言为真声明(整数 条件, 字符串 消息) -> 空类型 {
    如果 (条件) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息);
    }
}

/// 断言相等整数
函数 断言相等整数声明(整数 期望, 整数 实际, 字符串 消息) -> 空类型 {
    如果 (期望 == 实际) {
        通过计数 = 通过计数 + 1;
        打印行("✓ " + 消息);
    } 否则 {
        失败计数 = 失败计数 + 1;
        打印行("✗ " + 消息 + " (期望: " + 整数转字符串(期望) + ", 实际: " + 整数转字符串(实际) + ")");
    }
}

// =============================================================================
// 第一部分：函数声明测试
// =============================================================================

/// 测试函数声明
函数 测试函数声明() -> 空类型 {
    打印行("");
    打印行("[声明-1] 函数声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：函数声明节点类型
    // -------------------------------------------------------------------------
    变量 函数声明节点 函数节点;
    函数节点.基类.类型 = 节点类型.函数声明;
    函数节点.名称 = "测试函数";
    函数节点.是静态 = 假;
    函数节点.是重写 = 假;
    函数节点.是虚拟 = 假;
    函数节点.是抽象 = 假;

    断言相等整数声明(节点类型.函数声明 作为 整数, 函数节点.基类.类型 作为 整数, "函数声明节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：静态函数
    // -------------------------------------------------------------------------
    变量 函数声明节点 静态函数;
    静态函数.基类.类型 = 节点类型.函数声明;
    静态函数.名称 = "静态方法";
    静态函数.是静态 = 真;

    断言为真声明(静态函数.是静态, "静态函数应标记为静态");

    // -------------------------------------------------------------------------
    // 测试3：虚拟函数
    // -------------------------------------------------------------------------
    变量 函数声明节点 虚拟函数;
    虚拟函数.基类.类型 = 节点类型.函数声明;
    虚拟函数.名称 = "虚拟方法";
    虚拟函数.是虚拟 = 真;

    断言为真声明(虚拟函数.是虚拟, "虚拟函数应标记为虚拟");

    // -------------------------------------------------------------------------
    // 测试4：重写函数
    // -------------------------------------------------------------------------
    变量 函数声明节点 重写函数;
    重写函数.基类.类型 = 节点类型.函数声明;
    重写函数.名称 = "重写方法";
    重写函数.是重写 = 真;

    断言为真声明(重写函数.是重写, "重写函数应标记为重写");

    // -------------------------------------------------------------------------
    // 测试5：抽象函数
    // -------------------------------------------------------------------------
    变量 函数声明节点 抽象函数;
    抽象函数.基类.类型 = 节点类型.函数声明;
    抽象函数.名称 = "抽象方法";
    抽象函数.是抽象 = 真;

    断言为真声明(抽象函数.是抽象, "抽象函数应标记为抽象");
}

// =============================================================================
// 第二部分：变量声明测试
// =============================================================================

/// 测试变量声明
函数 测试变量声明() -> 空类型 {
    打印行("");
    打印行("[声明-2] 变量声明测试");
    打印行("----------------------------------------");

    // -------------------------------------------------------------------------
    // 测试1：变量声明节点类型
    // -------------------------------------------------------------------------
    变量 变量声明节点 变量节点;
    变量节点.基类.类型 = 节点类型.变量声明;
    变量节点.名称 = "测试变量";
    变量节点.是常量 = 假;
    变量节点.是静态 = 假;
    变量节点.是数组 = 假;

    断言相等整数声明(节点类型.变量声明 作为 整数, 变量节点.基类.类型 作为 整数, "变量声明节点类型应正确");

    // -------------------------------------------------------------------------
    // 测试2：常量声明
    // -------------------------------------------------------------------------
    变量 变量声明节点 常量节点;
    常量节点.基类.类型 = 节点类型.变量声明;
    常量节点.名称 = "PI";
    常量节点.是常量 = 真;

    断言为真声明(常量节点.是常量, "常量声明应标记为常量");

    // -------------------------------------------------------------------------
    // 测试3：静态变量声明
    // -------------------------------------------------------------------------
    变量 变量声明节点 静态变量节点;
    静态变量节点.基类.类型 = 节点类型.变量声明;
    静态变量节点.名称 = "计数器";
    静态变量节点.是静态 = 真;

    断言为真声明(静态变量节点.是静态, "静态变量声明应标记为静态");

    // -------------------------------------------------------------------------
    // 测试4：数组变量声明
    // -------------------------------------------------------------------------
    变量 变量声明节点 数组变量节点;
    数组变量节点.基类.类型 = 节点类型.变量声明;
    数组变量节点.名称 = "数组";
    数组变量节点.是数组 = 真;
    数组变量节点.数组维度 = 1;

    断言为真声明(数组变量节点.是数组, "数组变量声明应标记为数组");
    断言相等整数声明(1, 数组变量节点.数组维度, "一维数组维度应为1");

    // -------------------------------------------------------------------------
    // 测试5：多维数组变量声明
    // -------------------------------------------------------------------------
    变量 变量声明节点 多维数组节点;
    多维数组节点.基类.类型 = 节点类型.变量声明;
    多维数组节点.名称 = "矩阵";
    多维数组节点.是数组 = 真;
    多维数组节点.数组维度 = 2;

    断言相等整数声明(2, 多维数组节点.数组维度, "二维数组维度应为2");
}

