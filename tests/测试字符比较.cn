// 测试字符比较表达式类型检查
// 注意：CN语言没有字符类型，字符字面量是整数类型

函数 测试字符字面量比较() -> 整数 {
    // 字符字面量 'A' 的 ASCII 码是 65
    变量 c = 65;
    
    // 比较表达式应该返回布尔类型
    如果 (c == 65) {
        返回 1;
    }
    返回 0;
}

函数 测试字符范围检查(整数 c) -> 布尔 {
    // 测试范围比较
    如果 (c >= 65 && c <= 90) {
        返回 真;  // 大写字母 A-Z
    }
    返回 假;
}

函数 测试多个比较() -> 整数 {
    变量 a = 10;
    变量 b = 20;
    变量 c = 30;
    
    // 测试多种比较运算符
    如果 (a < b) {
        如果 (b <= c) {
            如果 (c > a) {
                如果 (a != c) {
                    返回 1;
                }
            }
        }
    }
    返回 0;
}

函数 主函数() -> 整数 {
    变量 结果1 = 测试字符字面量比较();
    变量 结果2 = 测试字符范围检查(70);  // 'F'
    变量 结果3 = 测试多个比较();
    
    如果 (结果2 == 真) {
        返回 结果1 + 结果3;
    }
    返回 0;
}
