// 测试字符字面量和函数原型声明
// 编译时间: 2026-04-04

// 测试函数原型声明（前向声明）
函数 计算阶乘(整数 n) -> 整数;

// 测试字符字面量
函数 测试字符() -> 整数 {
    变量 ch = 'A';
    变量 换行 = '\n';
    变量 制表 = '\t';
    变量 反斜杠 = '\\';
    变量 单引号 = '\'';
    变量 空字符 = '\0';
    返回 ch;
}

// 主程序
函数 主程序() -> 整数 {
    变量 结果 = 测试字符();
    变量 阶乘结果 = 计算阶乘(5);
    返回 0;
}

// 函数定义（实现前面的原型声明）
函数 计算阶乘(整数 n) -> 整数 {
    如果 (n <= 1) {
        返回 1;
    }
    返回 n * 计算阶乘(n - 1);
}
