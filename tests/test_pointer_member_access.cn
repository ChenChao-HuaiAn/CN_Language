// 测试指针成员访问操作符生成
// 验证：指针类型成员访问应该生成 -> 而不是 .

结构体 数据 {
    整数 值;
    整数 编号;
};

函数 测试指针成员访问(数据* 指针) -> 整数 {
    // 这些应该生成 -> 操作符
    整数 值1 = 指针.值;
    整数 值2 = 指针.编号;
    
    返回 值1 + 值2;
}

函数 主程序() -> 整数 {
    数据 实例;
    
    实例.值 = 42;
    实例.编号 = 10;
    
    整数 结果 = 测试指针成员访问(&实例);
    返回 结果;
}
