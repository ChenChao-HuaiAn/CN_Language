// 测试比较表达式类型检查

函数 测试比较() -> 整数 {
    变量 a = 10;
    变量 b = 20;
    如果 (a < b) {
        返回 1;
    }
    返回 0;
}

函数 测试字符比较() -> 整数 {
    变量 c = 65;  // 'A' 的 ASCII 码
    如果 (c == 65) {
        返回 1;
    }
    返回 0;
}

函数 主函数() -> 整数 {
    变量 结果1 = 测试比较();
    变量 结果2 = 测试字符比较();
    返回 结果1 + 结果2;
}
