// 测试字符指针成员访问

结构体 扫描器 {
    字符* 源码;
    整数 位置;
    整数 行号;
    整数 列号;
    整数 源码长度;
};

函数 当前字符(扫描器* 实例) -> 整数 {
    如果 (实例 == 无 || 实例->位置 >= 实例->源码长度) {
        返回 0;
    }
    返回 实例->源码[实例->位置];
}

函数 主() -> 整数 {
    扫描器* 实例 = 分配内存(24);
    
    实例->位置 = 0;
    实例->行号 = 1;
    实例->列号 = 1;
    
    整数 c = 当前字符(实例);
    
    如果 (c == '\n') {
        实例->行号 = 实例->行号 + 1;
        实例->列号 = 1;
    } 否则 {
        实例->列号 = 实例->列号 + 1;
    }
    
    返回 实例->列号;
}
