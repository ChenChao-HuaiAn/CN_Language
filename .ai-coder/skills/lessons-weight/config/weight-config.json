{
  "version": "1.0.0",
  "description": "lessons.md 权重计算配置",
  "baseWeights": {
    "设计缺陷": 10,
    "任务未完成": 9,
    "逻辑错误": 8,
    "集成问题": 7,
    "配置错误": 6,
    "工具执行错误": 2,
    "其他": 3
  },
  "typeCoefficients": {
    "hasDetailedAnalysis": 2.0,
    "hasSolution": 1.5,
    "hasPrevention": 1.3,
    "isTemplate": 0.3,
    "noAnalysis": 0.5
  },
  "resolutionMultipliers": {
    "unresolved": 2.0,
    "partial": 1.2,
    "resolved": 1.0
  },
  "thresholds": {
    "mustRead": 15,
    "recommendedRead": 10,
    "optionalRead": 5,
    "skipThreshold": 3
  },
  "cleanupRules": {
    "compressAfterDays": 30,
    "archiveAfterDays": 90,
    "maxTemplateEntries": 10
  },
  "taskTypeMapping": {
    "代码编写": ["逻辑错误", "设计缺陷", "任务未完成"],
    "配置修改": ["配置错误", "集成问题"],
    "功能开发": ["设计缺陷", "逻辑错误"],
    "Bug修复": ["逻辑错误", "工具执行错误"],
    "集成开发": ["集成问题", "设计缺陷"],
    "任务执行": ["任务未完成", "工具执行错误"]
  }
}