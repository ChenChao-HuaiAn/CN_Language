# 首先：忽略所有文件和文件夹
*
# 然后：取消忽略必要的目录结构
!*/

# 取消忽略 .git 目录
!/.git/

# 取消忽略 .ai-coder/ 目录及其内容
!.ai-coder/
# 确保 .ai-coder/ 文件夹里的所有文件不被忽略
!.ai-coder/**

# 取消忽略 include/ 目录及其内容
!include/
# 确保 include/ 文件夹里的所有文件不被忽略
!include/**

# 取消忽略 examples/ 目录及其内容
!examples/
# 确保 examples/ 文件夹里的所有文件不被忽略
!examples/**

# 取消忽略 plans/ 目录及其内容
!plans/
# 确保 plans/ 文件夹里的所有文件不被忽略
!plans/**

# 取消忽略 TODO/ 目录及其内容
!TODO/
# 确保 TODO/ 文件夹里的所有文件不被忽略
!TODO/**

# 取消忽略 src/ 目录及其内容
!/src/
# 确保 src/ 文件夹里的所有文件不被忽略
!/src/**

# 取消忽略 tests/ 目录及其内容
!/tests/
# 确保 tests/ 文件夹里的所有文件不被忽略
!/tests/**

# 取消忽略 tools/ 目录及其内容
!/tools/
# 确保 tools/ 文件夹里的所有文件不被忽略
!/tools/**

# 取消忽略 src_cn/ 目录及其内容
!/src_cn/
# 确保 src_cn/ 文件夹里的所有文件不被忽略
!/src_cn/**

#############################################################################################################
# 取消忽略 .gitignore 文件本身
!/.gitignore
# 取消忽略 .dockerignore 文件本身
!/.dockerignore
# 取消忽略"CHANGELOG.md"文件本身
!/CHANGELOG.md
# 取消忽略"README.md"文件本身
!/README.md
# 取消忽略"CMakeLists.txt"文件本身
!/CMakeLists.txt
# 取消忽略".dockerignore"文件本身
!/dockerignore
# 取消忽略"docker_run.ps1"文件本身
!/docker_run.ps1
# 取消忽略"docker-compose.yml"文件本身
!/docker-compose.yml
# 取消忽略"Dockerfile"文件本身
!/Dockerfile
# 取消忽略"lessons.md"文件本身
!/lessons.md

#############################################################################################################
# 构建产物和中间文件（CMake构建目录及编译产物）
/build/
/build_*/
*.o
*.obj
*.exe
*.out
*.a
*.so
*.dll
*.lib
*.dylib

# 测试报告目录
test_reports/

# 临时测试文件
*.c.tmp
*.cn.tmp
test_*.c
!tests/**/*.c

# IDE和编辑器配置
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

.codeartsdoer