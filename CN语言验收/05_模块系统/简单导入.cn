// 测试目的：验证简单导入语法
// 包括全量导入、使用导入的函数

// 全量导入模块
导入 被导入模块;

函数 主程序() -> 整数 {
    // 使用导入模块的函数
    整数 和 = 加法(10, 20);
    整数 差 = 减法(30, 15);
    整数 积 = 乘法(5, 6);
    整数 商 = 除法(20, 4);
    
    // 使用导入模块的常量
    整数 上限 = 最大值;
    字符串 版本 = 模块版本;
    
    // 使用工具函数
    整数 平方值 = 平方(9);
    整数 绝对值结果 = 绝对值(-15);
    
    返回 0;
}
