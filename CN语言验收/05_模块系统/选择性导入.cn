// 测试目的：验证选择性导入语法
// 包括选择性导入、从...导入、别名导入

// 选择性导入：只导入指定的函数
导入 被导入模块 { 加法, 减法 };

// 从模块导入指定成员
从 被导入模块 导入 { 乘法, 除法, 最大值 };

// 别名导入（如果支持）
导入 被导入模块(数学);

函数 主程序() -> 整数 {
    // 使用选择性导入的函数
    整数 和 = 加法(100, 200);
    整数 差 = 减法(500, 300);
    
    // 使用从...导入的函数
    整数 积 = 乘法(7, 8);
    整数 商 = 除法(100, 5);
    
    // 使用导入的常量
    整数 上限 = 最大值;
    
    // 使用别名调用（如果支持）
    整数 结果 = 数学.平方(5);
    
    返回 0;
}
