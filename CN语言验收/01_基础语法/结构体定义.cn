// 测试目的：验证结构体定义语法
// 包括结构体声明、成员访问、嵌套结构体

// 基本结构体
结构体 点 {
    整数 x;
    整数 y;
};

// 带数组的结构体
结构体 学生 {
    字符串 姓名;
    整数 年龄;
    小数 成绩[4];
};

// 嵌套结构体
结构体 线段 {
    结构体 点 起点;
    结构体 点 终点;
};

函数 主程序() -> 整数 {
    // 声明结构体变量
    结构体 点 坐标;
    坐标.x = 10;
    坐标.y = 20;
    
    // 结构体指针
    结构体 点* 点指针 = &坐标;
    点指针->x = 30;
    
    // 嵌套结构体使用
    结构体 线段 线;
    线.起点.x = 0;
    线.起点.y = 0;
    线.终点.x = 100;
    线.终点.y = 100;
    
    返回 0;
}
