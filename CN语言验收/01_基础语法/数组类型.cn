// 测试目的：验证数组类型语法
// 包括一维数组、多维数组、数组初始化

函数 主程序() -> 整数 {
    // 一维数组声明
    整数 一维数组[5];
    一维数组[0] = 10;
    一维数组[1] = 20;
    一维数组[2] = 30;
    一维数组[3] = 40;
    一维数组[4] = 50;
    
    // 多维数组
    整数 二维数组[3][4];
    二维数组[0][0] = 1;
    二维数组[1][2] = 5;
    
    // 字符串数组
    字符串 名称列表[3];
    名称列表[0] = "张三";
    名称列表[1] = "李四";
    名称列表[2] = "王五";
    
    // 小数数组
    小数 温度记录[7];
    温度记录[0] = 25.5;
    温度记录[1] = 26.3;
    
    返回 0;
}
