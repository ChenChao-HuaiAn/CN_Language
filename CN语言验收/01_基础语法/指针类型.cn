// 测试目的：验证指针类型语法
// 包括指针声明、指针操作、多级指针

函数 主程序() -> 整数 {
    // 基本指针
    整数 值 = 42;
    整数* 指针 = &值;
    
    // 通过指针访问值
    整数 取值 = *指针;
    
    // 多级指针
    整数** 二级指针 = &指针;
    
    // 空指针
    整数* 空指针 = 无;
    
    // 指针运算
    整数 数组[5];
    整数* 数组指针 = 数组;
    数组指针 = 数组指针 + 1;
    
    // 空类型指针
    空类型* 通用指针 = &值;
    
    返回 0;
}
