// 测试目的：验证变量声明语法
// 包括类型推断、显式类型声明、数组声明等

函数 主程序() -> 整数 {
    // 类型推断声明
    变量 x = 10;
    
    // 显式类型声明
    整数 y = 20;
    小数 pi = 3.14159;
    字符串 消息 = "你好，CN语言！";
    布尔 flag = 真;
    
    // 数组声明
    整数 arr[5];
    arr[0] = 1;
    arr[1] = 2;
    arr[2] = 3;
    
    // 多维数组
    整数 matrix[2][3];
    matrix[0][0] = 1;
    matrix[0][1] = 2;
    
    返回 0;
}
