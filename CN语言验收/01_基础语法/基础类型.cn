// 测试目的：验证基础数据类型
// 包括整数、小数、字符串、布尔、空类型

函数 主程序() -> 整数 {
    // 整数类型
    整数 整数值 = 42;
    
    // 小数类型
    小数 小数值 = 3.14159;
    
    // 字符串类型
    字符串 文本 = "你好，世界！";
    
    // 布尔类型
    布尔 是真 = 真;
    布尔 是假 = 假;
    
    // 空类型指针
    空类型* 通用指针 = 无;
    
    // 数字字面量格式
    整数 十进制 = 123;
    整数 十六进制 = 0xFF;
    整数 二进制 = 0b1010;
    整数 八进制 = 0o755;
    
    小数 科学计数法 = 1.5e-3;
    
    返回 0;
}
