// 测试目的：验证当循环语法
// 包括基本当循环、中断、继续语句

函数 主程序() -> 整数 {
    整数 计数 = 0;
    
    // 基本当循环
    当 (计数 < 10) {
        计数 = 计数 + 1;
    }
    
    // 带中断的循环
    整数 i = 0;
    当 (真) {
        i = i + 1;
        如果 (i >= 5) {
            中断;
        }
    }
    
    // 带继续的循环
    整数 j = 0;
    当 (j < 10) {
        j = j + 1;
        如果 (j % 2 == 0) {
            继续;  // 跳过偶数
        }
        // 处理奇数
    }
    
    返回 0;
}
