// 测试目的：验证如果语句语法
// 包括如果、否则如果、否则分支

函数 主程序() -> 整数 {
    整数 分数 = 85;
    
    // 基本如果语句
    如果 (分数 >= 90) {
        // 优秀
    } 否则 如果 (分数 >= 80) {
        // 良好
    } 否则 如果 (分数 >= 60) {
        // 及格
    } 否则 {
        // 不及格
    }
    
    // 嵌套如果语句
    布尔 是会员 = 真;
    整数 购买金额 = 500;
    
    如果 (是会员) {
        如果 (购买金额 >= 1000) {
            // VIP会员享受8折
        } 否则 {
            // 普通会员享受9折
        }
    } 否则 {
        // 非会员无折扣
    }
    
    返回 0;
}
