// 测试目的：验证基本函数定义语法
// 包括无参函数、有参函数、无返回值函数

// 无参无返回值函数
函数 打印问候() {
    // 无返回值函数
}

// 有参无返回值函数
函数 打印整数(整数 值) {
    // 打印整数值
}

// 有参有返回值函数
函数 加法(整数 a, 整数 b) -> 整数 {
    返回 a + b;
}

// 多参数函数
函数 计算平均值(整数 a, 整数 b, 整数 c) -> 小数 {
    返回 (a + b + c) / 3.0;
}

// 字符串参数函数
函数 拼接字符串(字符串 前缀, 字符串 后缀) -> 字符串 {
    返回 前缀 + 后缀;
}

函数 主程序() -> 整数 {
    // 调用无参函数
    打印问候();
    
    // 调用有参函数
    整数 结果 = 加法(10, 20);
    
    // 调用多参数函数
    小数 平均值 = 计算平均值(80, 90, 85);
    
    返回 0;
}
