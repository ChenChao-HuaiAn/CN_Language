// ============================================================================
// 第六部分：核心接口函数实现
// ============================================================================

/// 设置诊断消息语言
/// @param 语言 语言类型（中文 或 英文）
函数 设置诊断语言(诊断语言 语言) -> 空类型 {
    当前语言 = 语言
}

/// 获取当前诊断消息语言
/// @return 当前语言类型
函数 获取诊断语言() -> 诊断语言 {
    返回 当前语言
}

/// 根据错误码获取消息模板
/// 在消息表中线性查找指定错误码对应的消息模板
/// @param 代码 错误码
/// @return 消息模板指针，未找到返回空
函数 获取消息模板(诊断错误码 代码) -> 消息模板* {
    整数 索引 = 0
    
    // 遍历消息表查找匹配的错误码
    当 (消息表[索引].代码 != 诊断错误码.未知错误) {
        如果 (消息表[索引].代码 == 代码) {
            返回 &消息表[索引]
        }
        索引 = 索引 + 1
    }
    
    // 未找到，返回空
    返回 空
}

/// 格式化消息
/// 根据消息模板和参数生成完整的错误消息字符串
/// 模板中的 {0}, {1}, {2} 等占位符会被对应参数替换
/// @param 模板 消息模板指针
/// @param 参数 参数数组（可为空，表示无参数消息）
/// @param 语言 语言类型
/// @param 缓冲区 输出缓冲区
/// @param 缓冲区大小 缓冲区大小（字节）
/// @return 格式化后的字符串长度（不含终止符），失败返回负值
函数 格式化消息(消息模板* 模板, 诊断参数数组* 参数, 诊断语言 语言, 字符串 缓冲区, 整数 缓冲区大小) -> 整数 {
    常量字符串 消息文本        // 消息模板
    常量字符串 源指针          // 源字符串遍历指针
    字符串 目标指针            // 目标缓冲区指针
    整数 剩余空间              // 剩余缓冲区空间
    整数 已写入                // 已写入字符数
    整数 参数索引              // 参数索引
    诊断参数* 当前参数         // 当前参数
    字符串 参数字符串          // 参数字符串值
    整数 消息表索引 = 0        // 消息表遍历索引
    
    // 参数检查
    如果 (模板 == 空 或 缓冲区 == 空 或 缓冲区大小 <= 0) {
        返回 -1
    }
    
    // 选择语言
    如果 (语言 == 诊断语言.中文) {
        消息文本 = 模板.中文消息
    } 否则 {
        消息文本 = 模板.英文消息
    }
    
    // 如果选定语言的消息为空，尝试使用另一种语言
    如果 (消息文本 == 空) {
        如果 (语言 == 诊断语言.中文) {
            消息文本 = 模板.英文消息
        } 否则 {
            消息文本 = 模板.中文消息
        }
    }
    
    // 如果仍然为空，使用默认消息
    如果 (消息文本 == 空) {
        消息文本 = "（无消息）"
    }
    
    源指针 = 消息文本
    目标指针 = 缓冲区
    剩余空间 = 缓冲区大小 - 1  // 保留终止符空间
    
    // 遍历模板字符串
    当 (*源指针 != '\0' 且 剩余空间 > 0) {
        // 检测占位符 {n}
        如果 (*源指针 == '{' 且 *(源指针 + 1) >= '0' 且 *(源指针 + 1) <= '9' 且 *(源指针 + 2) == '}') {
            // 解析参数索引
            参数索引 = *(源指针 + 1) - '0'
            
            // 获取参数值
            参数字符串 = 空
            如果 (参数 != 空 且 参数索引 < 参数.长度) {
                当前参数 = &参数.参数[参数索引]
                
                // 根据参数类型获取字符串值
                选择 (当前参数.类型) {
                    情况 参数类型.字符串参数:
                        参数字符串 = 当前参数.值.字符串值
                        中断
                    情况 参数类型.整数参数:
                        // 整数转字符串（简化实现）
                        参数字符串 = 整数转字符串(当前参数.值.整数值)
                        中断
                    情况 参数类型.标记参数:
                        // Token类型暂时显示为数字
                        参数字符串 = 整数转字符串(当前参数.值.标记值)
                        中断
                    默认:
                        参数字符串 = "?"
                        中断
                }
            }
            
            // 写入参数值
            如果 (参数字符串 != 空) {
                已写入 = 字符串复制(目标指针, 参数字符串, 剩余空间)
                如果 (已写入 > 0) {
                    目标指针 = 目标指针 + 已写入
                    剩余空间 = 剩余空间 - 已写入
                }
            } 否则 {
                // 参数缺失，保留占位符
                如果 (剩余空间 >= 3) {
                    *目标指针 = '{'
                    目标指针 = 目标指针 + 1
                    *目标指针 = *(源指针 + 1)
                    目标指针 = 目标指针 + 1
                    *目标指针 = '}'
                    目标指针 = 目标指针 + 1
                    剩余空间 = 剩余空间 - 3
                }
            }
            
            源指针 = 源指针 + 3  // 跳过 {n}
        } 否则 {
            // 普通字符，直接复制
            *目标指针 = *源指针
            目标指针 = 目标指针 + 1
            源指针 = 源指针 + 1
            剩余空间 = 剩余空间 - 1
        }
    }
    
    // 添加终止符
    *目标指针 = '\0'
    
    // 返回写入的字符数（不含终止符）
    返回 目标指针 - 缓冲区
}

/// 获取诊断消息
/// 根据错误码和参数获取格式化的消息字符串
/// @param 代码 错误码
/// @param 语言 语言类型
/// @param 参数 参数数组（可为空）
/// @param 缓冲区 输出缓冲区
/// @param 缓冲区大小 缓冲区大小
/// @return 格式化后的字符串长度，失败返回负值
函数 获取诊断消息(诊断错误码 代码, 诊断语言 语言, 诊断参数数组* 参数, 字符串 缓冲区, 整数 缓冲区大小) -> 整数 {
    消息模板* 模板 = 获取消息模板(代码)
    
    如果 (模板 == 空) {
        // 未找到模板，返回默认消息
        如果 (缓冲区大小 > 0) {
            缓冲区[0] = '\0'
        }
        返回 -1
    }
    
    返回 格式化消息(模板, 参数, 语言, 缓冲区, 缓冲区大小)
}

/// 获取诊断提示
/// 根据错误码获取提示信息字符串
/// @param 代码 错误码
/// @param 语言 语言类型
/// @return 提示信息字符串，无提示返回空
函数 获取诊断提示(诊断错误码 代码, 诊断语言 语言) -> 常量字符串 {
    消息模板* 模板 = 获取消息模板(代码)
    
    如果 (模板 == 空) {
        返回 空
    }
    
    如果 (语言 == 诊断语言.中文) {
        返回 模板.中文提示
    } 否则 {
        返回 模板.英文提示
    }
}

// ============================================================================
// 第七部分：便利函数实现
// ============================================================================

/// 创建字符串参数
/// 便利函数，用于快速创建字符串类型的诊断参数
/// @param 值 字符串值（指针，不拥有所有权）
/// @return 初始化完成的诊断参数结构
函数 创建字符串参数(常量字符串 值) -> 诊断参数 {
    诊断参数 参数
    参数.类型 = 参数类型.字符串参数
    参数.值.字符串值 = 值
    返回 参数
}

/// 创建整数参数
/// 便利函数，用于快速创建整数类型的诊断参数
/// @param 值 整数值
/// @return 初始化完成的诊断参数结构
函数 创建整数参数(整数 值) -> 诊断参数 {
    诊断参数 参数
    参数.类型 = 参数类型.整数参数
    参数.值.整数值 = 值
    返回 参数
}

/// 创建标记参数
/// 便利函数，用于快速创建Token类型的诊断参数
/// @param 标记类型 Token类型值
/// @return 初始化完成的诊断参数结构
函数 创建标记参数(整数 标记类型) -> 诊断参数 {
    诊断参数 参数
    参数.类型 = 参数类型.标记参数
    参数.值.标记值 = 标记类型
    返回 参数
}

// ============================================================================
// 第八部分：辅助函数实现
// ============================================================================

/// 整数转字符串（内部辅助函数）
/// 将整数值转换为字符串表示
/// @param 值 整数值
/// @return 字符串表示（静态缓冲区，非线程安全）
函数 整数转字符串(整数 值) -> 字符串 {
    静态 字符 缓冲区[32]    // 静态缓冲区，足够容纳64位整数
    整数 索引 = 30          // 从缓冲区末尾开始
    布尔 负数 = 假          // 是否为负数
    整数 绝对值 = 值        // 绝对值
    
    // 处理负数
    如果 (值 < 0) {
        负数 = 真
        绝对值 = -值
    }
    
    // 特殊情况：零
    如果 (值 == 0) {
        缓冲区[0] = '0'
        缓冲区[1] = '\0'
        返回 缓冲区
    }
    
    // 从后向前填充数字
    缓冲区[31] = '\0'  // 终止符
    
    当 (绝对值 > 0 且 索引 >= 0) {
        缓冲区[索引] = '0' + (绝对值 % 10)
        绝对值 = 绝对值 / 10
        索引 = 索引 - 1
    }
    
    // 添加负号
    如果 (负数) {
        缓冲区[索引] = '-'
        索引 = 索引 - 1
    }
    
    返回 &缓冲区[索引 + 1]
}

/// 字符串复制（带长度限制）
/// 将源字符串复制到目标缓冲区，最多复制指定长度
/// @param 目标 目标缓冲区
/// @param 源 源字符串
/// @param 最大长度 最大复制长度（不含终止符）
/// @return 实际复制的字符数
函数 字符串复制(字符串 目标, 常量字符串 源, 整数 最大长度) -> 整数 {
    整数 计数 = 0
    
    当 (*源 != '\0' 且 计数 < 最大长度) {
        *目标 = *源
        目标 = 目标 + 1
        源 = 源 + 1
        计数 = 计数 + 1
    }
    
    返回 计数
}
