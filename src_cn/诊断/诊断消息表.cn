// ============================================================================
// 诊断消息表模块
// ============================================================================
// 功能：提供中英文双语错误消息支持，包含参数化消息模板和格式化功能
// 作者：CN语言自托管编译器项目
// ============================================================================

// 导入诊断核心模块（依赖诊断错误码枚举）
导入 诊断.诊断核心

// ============================================================================
// 第一部分：语言类型枚举
// ============================================================================

/// 诊断消息语言类型枚举
/// 用于选择错误消息的显示语言
枚举 诊断语言 {
    中文 = 0,    // 中文（默认）
    英文 = 1     // 英文
}

// ============================================================================
// 第二部分：参数类型定义
// ============================================================================

/// 参数类型枚举
/// 定义消息模板中可使用的参数类型
枚举 参数类型 {
    字符串参数,    // 字符串参数（如标识符名称）
    整数参数,      // 整数参数（如行号、数量）
    标记参数       // Token类型参数（如关键字）
}

/// 参数值联合体
/// 存储不同类型参数的实际值
联合体 参数值 {
    常量字符串 字符串值    // 字符串值
    整数 整数值            // 整数值
    整数 标记值            // Token类型值（用整数表示）
}

/// 单个参数结构体
/// 包含参数类型和参数值的完整参数描述
结构体 诊断参数 {
    参数类型 类型    // 参数类型
    参数值 值        // 参数值
}

/// 参数数组结构体
/// 用于传递多个参数给消息格式化函数
结构体 诊断参数数组 {
    诊断参数* 参数    // 参数数组指针
    整数 长度         // 参数数量
}

// ============================================================================
// 第三部分：消息模板结构体
// ============================================================================

/// 消息模板结构体
/// 存储单个错误码对应的中英文消息模板和提示信息
/// 消息模板使用 {0}, {1}, {2} 等占位符表示参数位置
结构体 消息模板 {
    诊断错误码 代码        // 错误码
    常量字符串 中文消息    // 中文消息模板，使用 {0}, {1} 等占位符
    常量字符串 英文消息    // 英文消息模板
    常量字符串 中文提示    // 中文提示（可选，可为空）
    常量字符串 英文提示    // 英文提示（可选，可为空）
}

// ============================================================================
// 第四部分：全局变量
// ============================================================================

/// 当前诊断消息语言设置
/// 默认为中文
静态 诊断语言 当前语言 = 诊断语言.中文

// ============================================================================
// 第五部分：消息模板表
// ============================================================================

/// 消息模板表
/// 包含所有错误码对应的中英文消息模板和提示信息
/// 使用 未知错误 作为表结束标记
/// 消息模板使用 {0}, {1}, {2} 等占位符表示参数位置
常量 消息模板 消息表[] = {
    // ==================== 词法错误 ====================
    
