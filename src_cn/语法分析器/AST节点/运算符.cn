// =============================================================================
// CN语言语法分析器 - 运算符枚举定义
// =============================================================================
// 
// 本模块定义AST节点所需的各类运算符枚举
// 包括二元运算符、逻辑运算符、一元运算符、赋值运算符等
//
// 语法规范：
// - 枚举使用 枚举 名称 { 成员1, 成员2 } 格式
// =============================================================================

公开:

// =============================================================================
// 二元运算符枚举
// =============================================================================
// 用于二元表达式节点，表示算术、比较、位运算等操作

枚举 二元运算符 {
    // 算术运算符
    加,        // + 加法
    减,        // - 减法
    乘,        // * 乘法
    除,        // / 除法
    取模,      // % 取模
    
    // 比较运算符
    等于,      // == 等于
    不等于,    // != 不等于
    小于,      // < 小于
    大于,      // > 大于
    小于等于,  // <= 小于等于
    大于等于,  // >= 大于等于
    
    // 位运算符
    位与,      // & 按位与
    位或,      // | 按位或
    位异或,    // ^ 按位异或
    左移,      // << 左移
    右移       // >> 右移
}

// =============================================================================
// 逻辑运算符枚举
// =============================================================================
// 用于逻辑表达式节点

枚举 逻辑运算符 {
    逻辑与,    // && 逻辑与
    逻辑或     // || 逻辑或
}

// =============================================================================
// 一元运算符枚举
// =============================================================================
// 用于一元表达式节点，表示取负、取反、自增自减等操作

枚举 一元运算符 {
    逻辑非,      // ! 逻辑非
    取负,        // - 数值取负
    取地址,      // & 取地址
    解引用,      // * 解引用
    位取反,      // ~ 按位取反
    前置自增,    // ++i 前置自增
    前置自减,    // --i 前置自减
    后置自增,    // i++ 后置自增
    后置自减     // i-- 后置自减
}

// =============================================================================
// 赋值运算符枚举
// =============================================================================
// 用于赋值表达式节点

枚举 赋值运算符 {
    简单赋值,    // = 简单赋值
    加法赋值,    // += 加法赋值
    减法赋值,    // -= 减法赋值
    乘法赋值,    // *= 乘法赋值
    除法赋值,    // /= 除法赋值
    取模赋值,    // %= 取模赋值
    位与赋值,    // &= 位与赋值
    位或赋值,    // |= 位或赋值
    位异或赋值,  // ^= 位异或赋值
    左移赋值,    // <<= 左移赋值
    右移赋值     // >>= 右移赋值
}

// =============================================================================
// 字面量类型枚举
// =============================================================================
// 用于字面量表达式节点，区分不同类型的字面量

枚举 字面量类型 {
    整数字面量,    // 如 123, 0xFF, 0b1010
    浮点字面量,    // 如 3.14, 1.5e-3
    字符串字面量,  // 如 "你好"
    布尔字面量,    // 真 或 假
    空字面量,      // 无
    字符字面量     // 如 'a'
}

// =============================================================================
// 可见性枚举
// =============================================================================
// 用于声明节点，表示成员的访问权限

枚举 可见性 {
    默认可见,    // 默认可见性（非模块成员）
    公开可见,    // 公开，可被外部模块访问
    私有可见     // 私有，仅本模块可访问
}

// =============================================================================
// 导入类型枚举
// =============================================================================
// 区分不同的导入语法

枚举 导入类型 {
    全量导入,           // 导入 模块;
    选择性导入,         // 导入 模块 { 成员 };
    别名导入,           // 导入 模块(别名);
    从模块选择性导入,   // 从 模块 导入 { 成员 };
    从模块通配符导入,   // 从 模块 导入 *;
    从包导入模块        // 从 包 导入 模块;
}
