// =============================================================================
// CN语言语法分析器 - 运算符枚举定义
// =============================================================================
// 
// 本模块定义AST节点所需的各类运算符枚举
// 包括二元运算符、逻辑运算符、一元运算符、赋值运算符等
//
// 语法规范：
// - 枚举使用 枚举 名称 { 成员1, 成员2 } 格式
// - 枚举成员添加前缀以避免C代码生成时的命名冲突
// =============================================================================

公开:

// =============================================================================
// 二元运算符枚举
// =============================================================================
// 用于二元表达式节点，表示算术、比较、位运算等操作

枚举 二元运算符 {
    // 算术运算符
    二元_加,        // + 加法
    二元_减,        // - 减法
    二元_乘,        // * 乘法
    二元_除,        // / 除法
    二元_取模,      // % 取模
    
    // 比较运算符
    二元_等于,      // == 等于
    二元_不等于,    // != 不等于
    二元_小于,      // < 小于
    二元_大于,      // > 大于
    二元_小于等于,  // <= 小于等于
    二元_大于等于,  // >= 大于等于
    
    // 位运算符
    二元_位与,      // & 按位与
    二元_位或,      // | 按位或
    二元_位异或,    // ^ 按位异或
    二元_左移,      // << 左移
    二元_右移       // >> 右移
}

// =============================================================================
// 逻辑运算符枚举
// =============================================================================
// 用于逻辑表达式节点

枚举 逻辑运算符 {
    逻辑_与,    // && 逻辑与
    逻辑_或     // || 逻辑或
}

// =============================================================================
// 一元运算符枚举
// =============================================================================
// 用于一元表达式节点，表示取负、取反、自增自减等操作

枚举 一元运算符 {
    一元_逻辑非,      // ! 逻辑非
    一元_取负,        // - 数值取负
    一元_取地址,      // & 取地址
    一元_解引用,      // * 解引用
    一元_位取反,      // ~ 按位取反
    一元_前置自增,    // ++i 前置自增
    一元_前置自减,    // --i 前置自减
    一元_后置自增,    // i++ 后置自增
    一元_后置自减     // i-- 后置自减
}

// =============================================================================
// 赋值运算符枚举
// =============================================================================
// 用于赋值表达式节点

枚举 赋值运算符 {
    赋值_简单,    // = 简单赋值
    赋值_加法,    // += 加法赋值
    赋值_减法,    // -= 减法赋值
    赋值_乘法,    // *= 乘法赋值
    赋值_除法,    // /= 除法赋值
    赋值_取模,    // %= 取模赋值
    赋值_位与,    // &= 位与赋值
    赋值_位或,    // |= 位或赋值
    赋值_位异或,  // ^= 位异或赋值
    赋值_左移,    // <<= 左移赋值
    赋值_右移     // >>= 右移赋值
}

// =============================================================================
// 字面量类型枚举
// =============================================================================
// 用于字面量表达式节点，区分不同类型的字面量

枚举 字面量类型 {
    字面量_整数,    // 如 123, 0xFF, 0b1010
    字面量_浮点,    // 如 3.14, 1.5e-3
    字面量_字符串,  // 如 "你好"
    字面量_布尔,    // 真 或 假
    字面量_空,      // 无
    字面量_字符     // 如 'a'
}

// =============================================================================
// 可见性枚举
// =============================================================================
// 用于声明节点，表示成员的访问权限

枚举 可见性 {
    可见性_默认,    // 默认可见性（非模块成员）
    可见性_公开,    // 公开，可被外部模块访问
    可见性_私有     // 私有，仅本模块可访问
}

// =============================================================================
// 导入类型枚举
// =============================================================================
// 区分不同的导入语法

枚举 导入类型 {
    导入_全量,           // 导入 模块;
    导入_选择性,         // 导入 模块 { 成员 };
    导入_别名,           // 导入 模块(别名);
    导入_从模块选择性,   // 从 模块 导入 { 成员 };
    导入_从模块通配符,   // 从 模块 导入 *;
    导入_从包导入模块    // 从 包 导入 模块;
}
