// =============================================================================
// CN语言词法分析器 - 词元类型定义
// =============================================================================
// 
// 本模块定义词法分析器所需的词元类型枚举和词元结构体
// 词元（Token）是词法分析的基本单位，代表源代码中的一个最小语法单元
//
// 词元类型分类：
// - 关键字：控制流(10)、类型(7)、声明(7)、常量(3)、OOP(9)、异常(4)
// - 字面量：标识符、整数、浮点数、字符串、字符
// - 运算符：算术、比较、逻辑、位运算等
// - 分隔符：括号、分号、逗号等
// - 特殊：结束、错误
//
// 语法规范：
// - 枚举使用 枚举 名称 { 成员1, 成员2 } 格式
// - 结构体使用 结构体 名称 { 字段 } 格式
// - 函数返回类型使用 -> 类型 语法
// =============================================================================

公开:

// =============================================================================
// 词元类型枚举
// =============================================================================
// 共计83种词元类型，按功能分类定义

枚举 词元类型枚举 {
    // -------------------------------------------------------------------------
    // 关键字 - 控制流（10个）
    // -------------------------------------------------------------------------
    关键字_如果,       // 如果 - 条件判断
    关键字_否则,       // 否则 - 否则分支
    关键字_当,         // 当 - while循环
    关键字_循环,       // 循环 - for循环
    关键字_返回,       // 返回 - 返回语句
    关键字_中断,       // 中断 - break语句
    关键字_继续,       // 继续 - continue语句
    关键字_选择,       // 选择 - switch语句
    关键字_情况,       // 情况 - case标签
    关键字_默认,       // 默认 - default标签
    
    // -------------------------------------------------------------------------
    // 关键字 - 类型（7个）
    // -------------------------------------------------------------------------
    关键字_整数,       // 整数 - 整型
    关键字_小数,       // 小数 - 浮点型
    关键字_字符串,     // 字符串 - 字符串型
    关键字_布尔,       // 布尔 - 布尔型
    关键字_空类型,     // 空类型 - 无类型
    关键字_结构体,     // 结构体 - 结构体定义
    关键字_枚举,       // 枚举 - 枚举定义
    
    // -------------------------------------------------------------------------
    // 关键字 - 声明（7个）
    // -------------------------------------------------------------------------
    关键字_函数,       // 函数 - 函数声明
    关键字_变量,       // 变量 - 变量声明
    关键字_导入,       // 导入 - 导入语句
    关键字_从,         // 从 - 从...导入语法
    关键字_公开,       // 公开 - 公开可见性
    关键字_私有,       // 私有 - 私有可见性
    关键字_静态,       // 静态 - 静态局部变量
    
    // -------------------------------------------------------------------------
    // 关键字 - 常量（3个）
    // -------------------------------------------------------------------------
    关键字_真,         // 真 - 布尔真值
    关键字_假,         // 假 - 布尔假值
    关键字_无,         // 无 - 空值
    
    // -------------------------------------------------------------------------
    // 关键字 - OOP面向对象（9个）
    // -------------------------------------------------------------------------
    关键字_类,         // 类 - 类声明
    关键字_接口,       // 接口 - 接口声明
    关键字_保护,       // 保护 - 保护成员
    关键字_虚拟,       // 虚拟 - 虚函数
    关键字_重写,       // 重写 - 重写方法
    关键字_抽象,       // 抽象 - 抽象类/方法
    关键字_实现,       // 实现 - 实现接口
    关键字_自身,       // 自身 - this指针
    关键字_基类,       // 基类 - 基类访问
    
    // -------------------------------------------------------------------------
    // 关键字 - 异常处理（4个）
    // -------------------------------------------------------------------------
    关键字_尝试,       // 尝试 - try块
    关键字_捕获,       // 捕获 - catch块
    关键字_抛出,       // 抛出 - throw语句
    关键字_最终,       // 最终 - finally块
    
    // -------------------------------------------------------------------------
    // 字面量（5个）
    // -------------------------------------------------------------------------
    标识符,            // 标识符 - 变量名、函数名等
    整数字面量,        // 整数字面量 - 如 123, 0xFF, 0b1010
    浮点字面量,        // 浮点字面量 - 如 3.14, 1.5e-3
    字符串字面量,      // 字符串字面量 - 如 "你好"
    字符字面量,        // 字符字面量 - 如 'a'
    
    // -------------------------------------------------------------------------
    // 运算符 - 算术运算（5个）
    // -------------------------------------------------------------------------
    加号,              // + 加法运算
    减号,              // - 减法运算
    星号,              // * 乘法运算
    斜杠,              // / 除法运算
    百分号,            // % 取模运算
    
    // -------------------------------------------------------------------------
    // 运算符 - 比较运算（7个）
    // -------------------------------------------------------------------------
    等于,              // == 相等比较
    赋值,              // = 赋值运算
    不等于,            // != 不等比较
    小于,              // < 小于比较
    小于等于,          // <= 小于等于
    大于,              // > 大于比较
    大于等于,          // >= 大于等于
    
    // -------------------------------------------------------------------------
    // 运算符 - 逻辑运算（3个）
    // -------------------------------------------------------------------------
    逻辑与,            // && 逻辑与
    逻辑或,            // || 逻辑或
    逻辑非,            // ! 逻辑非
    
    // -------------------------------------------------------------------------
    // 运算符 - 位运算（6个）
    // -------------------------------------------------------------------------
    按位与,            // & 按位与
    按位或,            // | 按位或
    按位异或,          // ^ 按位异或
    按位取反,          // ~ 按位取反
    左移,              // << 左移
    右移,              // >> 右移
    
    // -------------------------------------------------------------------------
    // 运算符 - 自增自减（2个）
    // -------------------------------------------------------------------------
    自增,              // ++ 自增运算
    自减,              // -- 自减运算
    
    // -------------------------------------------------------------------------
    // 运算符 - 其他（1个）
    // -------------------------------------------------------------------------
    箭头,              // -> 箭头运算符
    
    // -------------------------------------------------------------------------
    // 分隔符（11个）
    // -------------------------------------------------------------------------
    左括号,            // ( 左圆括号
    右括号,            // ) 右圆括号
    左大括号,          // { 左花括号
    右大括号,          // } 右花括号
    左方括号,          // [ 左方括号
    右方括号,          // ] 右方括号
    分号,              // ; 分号
    逗号,              // , 逗号
    点,                // . 点运算符
    冒号,              // : 冒号
    问号,              // ? 问号（三元运算符）
    
    // -------------------------------------------------------------------------
    // 特殊（2个）
    // -------------------------------------------------------------------------
    结束,              // 文件结束标记
    错误               // 错误词元
};

// =============================================================================
// 词元结构体
// =============================================================================
// 存储单个词元的完整信息，包括类型、值、位置等

结构体 词元 {
    词元类型枚举 类型;    // 词元类型
    字符串 值;         // 词元文本值（词元在源码中的原始文本）
    整数 行号;         // 所在行号（从1开始）
    整数 列号;         // 所在列号（从1开始）
    整数 长度;         // 词元长度（字符数）
};

// =============================================================================
// 辅助函数实现
// =============================================================================

/// 获取词元类型名称
/// 返回词元类型对应的中文名称字符串
函数 词元类型名称(词元类型枚举 类型) -> 字符串 {
    // 关键字 - 控制流
    如果 (类型 == 关键字_如果) { 返回 "关键字_如果"; }
    如果 (类型 == 关键字_否则) { 返回 "关键字_否则"; }
    如果 (类型 == 关键字_当) { 返回 "关键字_当"; }
    如果 (类型 == 关键字_循环) { 返回 "关键字_循环"; }
    如果 (类型 == 关键字_返回) { 返回 "关键字_返回"; }
    如果 (类型 == 关键字_中断) { 返回 "关键字_中断"; }
    如果 (类型 == 关键字_继续) { 返回 "关键字_继续"; }
    如果 (类型 == 关键字_选择) { 返回 "关键字_选择"; }
    如果 (类型 == 关键字_情况) { 返回 "关键字_情况"; }
    如果 (类型 == 关键字_默认) { 返回 "关键字_默认"; }
    
    // 关键字 - 类型
    如果 (类型 == 关键字_整数) { 返回 "关键字_整数"; }
    如果 (类型 == 关键字_小数) { 返回 "关键字_小数"; }
    如果 (类型 == 关键字_字符串) { 返回 "关键字_字符串"; }
    如果 (类型 == 关键字_布尔) { 返回 "关键字_布尔"; }
    如果 (类型 == 关键字_空类型) { 返回 "关键字_空类型"; }
    如果 (类型 == 关键字_结构体) { 返回 "关键字_结构体"; }
    如果 (类型 == 关键字_枚举) { 返回 "关键字_枚举"; }
    
    // 关键字 - 声明
    如果 (类型 == 关键字_函数) { 返回 "关键字_函数"; }
    如果 (类型 == 关键字_变量) { 返回 "关键字_变量"; }
    如果 (类型 == 关键字_导入) { 返回 "关键字_导入"; }
    如果 (类型 == 关键字_从) { 返回 "关键字_从"; }
    如果 (类型 == 关键字_公开) { 返回 "关键字_公开"; }
    如果 (类型 == 关键字_私有) { 返回 "关键字_私有"; }
    如果 (类型 == 关键字_静态) { 返回 "关键字_静态"; }
    
    // 关键字 - 常量
    如果 (类型 == 关键字_真) { 返回 "关键字_真"; }
    如果 (类型 == 关键字_假) { 返回 "关键字_假"; }
    如果 (类型 == 关键字_无) { 返回 "关键字_无"; }
    
    // 关键字 - OOP
    如果 (类型 == 关键字_类) { 返回 "关键字_类"; }
    如果 (类型 == 关键字_接口) { 返回 "关键字_接口"; }
    如果 (类型 == 关键字_保护) { 返回 "关键字_保护"; }
    如果 (类型 == 关键字_虚拟) { 返回 "关键字_虚拟"; }
    如果 (类型 == 关键字_重写) { 返回 "关键字_重写"; }
    如果 (类型 == 关键字_抽象) { 返回 "关键字_抽象"; }
    如果 (类型 == 关键字_实现) { 返回 "关键字_实现"; }
    如果 (类型 == 关键字_自身) { 返回 "关键字_自身"; }
    如果 (类型 == 关键字_基类) { 返回 "关键字_基类"; }
    
    // 关键字 - 异常
    如果 (类型 == 关键字_尝试) { 返回 "关键字_尝试"; }
    如果 (类型 == 关键字_捕获) { 返回 "关键字_捕获"; }
    如果 (类型 == 关键字_抛出) { 返回 "关键字_抛出"; }
    如果 (类型 == 关键字_最终) { 返回 "关键字_最终"; }
    
    // 字面量
    如果 (类型 == 标识符) { 返回 "标识符"; }
    如果 (类型 == 整数字面量) { 返回 "整数字面量"; }
    如果 (类型 == 浮点字面量) { 返回 "浮点字面量"; }
    如果 (类型 == 字符串字面量) { 返回 "字符串字面量"; }
    如果 (类型 == 字符字面量) { 返回 "字符字面量"; }
    
    // 运算符 - 算术
    如果 (类型 == 加号) { 返回 "加号"; }
    如果 (类型 == 减号) { 返回 "减号"; }
    如果 (类型 == 星号) { 返回 "星号"; }
    如果 (类型 == 斜杠) { 返回 "斜杠"; }
    如果 (类型 == 百分号) { 返回 "百分号"; }
    
    // 运算符 - 比较
    如果 (类型 == 等于) { 返回 "等于"; }
    如果 (类型 == 赋值) { 返回 "赋值"; }
    如果 (类型 == 不等于) { 返回 "不等于"; }
    如果 (类型 == 小于) { 返回 "小于"; }
    如果 (类型 == 小于等于) { 返回 "小于等于"; }
    如果 (类型 == 大于) { 返回 "大于"; }
    如果 (类型 == 大于等于) { 返回 "大于等于"; }
    
    // 运算符 - 逻辑
    如果 (类型 == 逻辑与) { 返回 "逻辑与"; }
    如果 (类型 == 逻辑或) { 返回 "逻辑或"; }
    如果 (类型 == 逻辑非) { 返回 "逻辑非"; }
    
    // 运算符 - 位运算
    如果 (类型 == 按位与) { 返回 "按位与"; }
    如果 (类型 == 按位或) { 返回 "按位或"; }
    如果 (类型 == 按位异或) { 返回 "按位异或"; }
    如果 (类型 == 按位取反) { 返回 "按位取反"; }
    如果 (类型 == 左移) { 返回 "左移"; }
    如果 (类型 == 右移) { 返回 "右移"; }
    
    // 运算符 - 自增自减
    如果 (类型 == 自增) { 返回 "自增"; }
    如果 (类型 == 自减) { 返回 "自减"; }
    
    // 运算符 - 其他
    如果 (类型 == 箭头) { 返回 "箭头"; }
    
    // 分隔符
    如果 (类型 == 左括号) { 返回 "左括号"; }
    如果 (类型 == 右括号) { 返回 "右括号"; }
    如果 (类型 == 左大括号) { 返回 "左大括号"; }
    如果 (类型 == 右大括号) { 返回 "右大括号"; }
    如果 (类型 == 左方括号) { 返回 "左方括号"; }
    如果 (类型 == 右方括号) { 返回 "右方括号"; }
    如果 (类型 == 分号) { 返回 "分号"; }
    如果 (类型 == 逗号) { 返回 "逗号"; }
    如果 (类型 == 点) { 返回 "点"; }
    如果 (类型 == 冒号) { 返回 "冒号"; }
    如果 (类型 == 问号) { 返回 "问号"; }
    
    // 特殊
    如果 (类型 == 结束) { 返回 "结束"; }
    如果 (类型 == 错误) { 返回 "错误"; }
    
    返回 "未知词元类型";
}

/// 创建词元
/// 根据参数创建并返回一个新的词元结构体
函数 创建词元(词元类型枚举 类型, 字符串 值, 整数 行号, 整数 列号, 整数 长度值) -> 词元 {
    词元 新词元;
    新词元.类型 = 类型;
    新词元.值 = 值;
    新词元.行号 = 行号;
    新词元.列号 = 列号;
    新词元.长度 = 长度值;
    返回 新词元;
}

/// 判断是否为关键字
/// 检查词元类型是否属于关键字类别
函数 是关键字(词元类型枚举 类型) -> 布尔 {
    // 控制流关键字（10个）：关键字_如果 到 关键字_默认
    如果 (类型 >= 关键字_如果 && 类型 <= 关键字_默认) {
        返回 真;
    }
    
    // 类型关键字（7个）：关键字_整数 到 关键字_枚举
    如果 (类型 >= 关键字_整数 && 类型 <= 关键字_枚举) {
        返回 真;
    }
    
    // 声明关键字（7个）：关键字_函数 到 关键字_静态
    如果 (类型 >= 关键字_函数 && 类型 <= 关键字_静态) {
        返回 真;
    }
    
    // 常量关键字（3个）：关键字_真 到 关键字_无
    如果 (类型 >= 关键字_真 && 类型 <= 关键字_无) {
        返回 真;
    }
    
    // OOP关键字（9个）：关键字_类 到 关键字_基类
    如果 (类型 >= 关键字_类 && 类型 <= 关键字_基类) {
        返回 真;
    }
    
    // 异常关键字（4个）：关键字_尝试 到 关键字_最终
    如果 (类型 >= 关键字_尝试 && 类型 <= 关键字_最终) {
        返回 真;
    }
    
    返回 假;
}

/// 判断是否为字面量
/// 检查词元类型是否属于字面量类别
函数 是字面量(词元类型枚举 类型) -> 布尔 {
    返回 类型 >= 标识符 && 类型 <= 字符字面量;
}

/// 判断是否为运算符
/// 检查词元类型是否属于运算符类别
函数 是运算符(词元类型枚举 类型) -> 布尔 {
    返回 类型 >= 加号 && 类型 <= 箭头;
}

/// 判断是否为分隔符
/// 检查词元类型是否属于分隔符类别
函数 是分隔符(词元类型枚举 类型) -> 布尔 {
    返回 类型 >= 左括号 && 类型 <= 问号;
}
