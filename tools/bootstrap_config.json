{
    "说明": "CN语言自举测试配置文件",
    "版本": "1.0.0",
    
    "编译器路径": "build/cnc.exe",
    "源码目录": "src_cn",
    "输出目录": "build/bootstrap_test",
    
    "编译选项": [
        "-O2"
    ],
    
    "包含目录": "include",
    "库目录": "build/lib",
    "库名称": "cnrt",
    
    "超时秒数": 300,
    "C编译器": "gcc",
    
    "验证选项": {
        "比较C代码": true,
        "比较二进制": true,
        "生成差异报告": true
    },
    
    "输出选项": {
        "详细日志": false,
        "保留中间文件": false,
        "生成时间戳文件": true
    }
}
